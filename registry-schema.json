{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "nself Plugin Registry Schema",
  "type": "object",
  "required": ["plugins"],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Registry schema version (snake_case canonical field)"
    },
    "version": {
      "type": "string",
      "description": "Registry schema version (camelCase alias — accepted for backwards compat)"
    },
    "generated_at": {
      "type": "string",
      "description": "ISO 8601 timestamp when registry was generated"
    },
    "plugins_count": {
      "type": "integer",
      "description": "Total number of plugins in registry"
    },
    "last_updated": {
      "type": "string",
      "description": "Last update date (YYYY-MM-DD)"
    },
    "tier": {
      "type": "string",
      "description": "Plugin tier (free or pro)"
    },
    "checksum_algorithm": {
      "type": "string",
      "description": "Algorithm used for plugin checksums"
    },
    "note": {
      "type": "string",
      "description": "Human-readable note about this registry"
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time",
      "description": "Last time the registry was updated (camelCase alias)"
    },
    "plugins": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/plugin"
      }
    },
    "categories": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/category"
      }
    }
  },
  "definitions": {
    "plugin": {
      "type": "object",
      "required": ["version", "description"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Plugin identifier (lowercase, alphanumeric with hyphens)"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+",
          "description": "Semantic version"
        },
        "description": {
          "type": "string",
          "description": "Short description of the plugin"
        },
        "author": {
          "type": "string",
          "description": "Plugin author or organization"
        },
        "license": {
          "type": "string",
          "description": "License identifier"
        },
        "homepage": {
          "type": "string",
          "format": "uri",
          "description": "Plugin homepage URL"
        },
        "repository": {
          "type": "string",
          "format": "uri",
          "description": "Source repository URL"
        },
        "path": {
          "type": "string",
          "description": "Path to plugin directory within repository (optional)"
        },
        "min_nself_version": {
          "type": "string",
          "description": "Minimum required nself version (snake_case canonical field)"
        },
        "minNselfVersion": {
          "type": "string",
          "description": "Minimum required nself version (camelCase alias — accepted for backwards compat)"
        },
        "tarball": {
          "type": "string",
          "format": "uri",
          "description": "URL of the plugin tarball on the GitHub release"
        },
        "download_url": {
          "type": "string",
          "format": "uri",
          "description": "URL via the plugins.nself.org registry API"
        },
        "requires_license": {
          "type": "boolean",
          "description": "Whether this plugin requires a paid license"
        },
        "language": {
          "type": "string",
          "description": "Implementation language (go, typescript, etc.)"
        },
        "manifestVersion": {
          "type": "integer",
          "minimum": 1,
          "default": 1,
          "description": "Plugin manifest schema version. Default 1. Incremented when breaking manifest changes are introduced. Plugins at v1.0.9 all default to manifestVersion: 1 (S77-T07)."
        },
        "category": {
          "type": "string",
          "description": "Plugin category identifier"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Searchable tags"
        },
        "tables": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Database tables created by this plugin"
        },
        "webhooks": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Webhook events handled by this plugin"
        },
        "views": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Database views created by this plugin"
        },
        "actions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "CLI actions provided by this plugin"
        },
        "implementation": {
          "type": "object",
          "properties": {
            "language": { "type": "string" },
            "runtime": { "type": "string" },
            "minNodeVersion": { "type": "string" },
            "entryPoint": { "type": "string" },
            "cli": { "type": "string" },
            "cliName": { "type": "string" },
            "defaultPort": { "type": "integer" },
            "packageManager": { "type": "string" },
            "framework": { "type": "string" }
          },
          "description": "Implementation details for the plugin"
        },
        "cliCommands": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "description"],
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" }
            }
          },
          "description": "CLI commands provided by this plugin"
        },
        "apiEndpoints": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["method", "path", "description"],
            "properties": {
              "method": { "type": "string" },
              "path": { "type": "string" },
              "description": { "type": "string" }
            }
          },
          "description": "REST API endpoints provided by this plugin"
        },
        "envVars": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "required": { "type": "boolean" },
              "description": { "type": "string" },
              "default": { "type": "string" }
            }
          },
          "description": "Environment variables used by this plugin"
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Other plugins this plugin depends on"
        },
        "multiApp": {
          "type": "object",
          "properties": {
            "supported": {
              "type": "boolean",
              "description": "Whether the plugin supports multi-app isolation"
            },
            "isolationColumn": {
              "type": "string",
              "description": "Column name used for app isolation (typically source_account_id)"
            },
            "pkStrategy": {
              "type": "string",
              "enum": ["single", "composite", "uuid"],
              "description": "Primary key strategy: single (IDs globally unique), composite (ID + source_account_id), or uuid (UUID primary key)"
            },
            "defaultValue": {
              "type": "string",
              "description": "Default value for the isolation column (typically 'primary')"
            }
          },
          "description": "Multi-app isolation support configuration"
        },
        "checksums": {
          "type": "object",
          "properties": {
            "sha256": { "type": "string" }
          }
        },
        "tarballUrl": {
          "type": "string",
          "format": "uri",
          "description": "URL of the plugin tarball on the GitHub release"
        },
        "releaseTag": {
          "type": "string",
          "description": "Git tag of the release containing this tarball"
        },
        "signature": {
          "type": "string",
          "description": "Detached signature of the tarball (empty until signing infrastructure ships in v1.1.0)"
        },
        "status": {
          "type": "string",
          "enum": ["experimental", "planned", "beta", "stable", "deprecated", "eol"],
          "description": "Plugin lifecycle status (S58-T01). Absent defaults to stable for backwards compatibility."
        },
        "maxNselfVersion": {
          "type": "string",
          "description": "Last CLI version this plugin is compatible with. Empty means no upper bound. (S58-T06)"
        },
        "deprecation": {
          "type": "object",
          "description": "Required when status=deprecated (S58-T02).",
          "required": ["announcedDate", "eolDate", "migrationGuide"],
          "properties": {
            "announcedDate": { "type": "string", "description": "ISO 8601 date of deprecation announcement." },
            "eolDate": { "type": "string", "description": "ISO 8601 date when the plugin reaches end-of-life." },
            "replacedBy": { "type": "string", "description": "Name of the replacement plugin (optional)." },
            "migrationGuide": { "type": "string", "format": "uri", "description": "URL to migration guide." },
            "migrationScript": { "type": "string", "description": "Repo-relative path to automated migration script (optional)." }
          }
        }
      }
    },
    "category": {
      "type": "object",
      "required": ["name", "description"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Display name for the category"
        },
        "description": {
          "type": "string",
          "description": "Category description"
        },
        "icon": {
          "type": "string",
          "description": "Icon identifier"
        }
      }
    }
  }
}
