{
  "name": "link-preview",
  "version": "1.0.0",
  "description": "URL metadata extraction with Open Graph, Twitter Cards, and caching",
  "author": "nself",
  "license": "MIT",
  "lang": "go",
  "homepage": "https://github.com/nself-org/plugins/tree/main/plugins/link-preview",
  "repository": "https://github.com/nself-org/plugins",
  "minNselfVersion": "1.0.0",
  "port": 3718,
  "category": "content",
  "tags": [
    "link-preview",
    "open-graph",
    "twitter-cards",
    "metadata",
    "caching",
    "url"
  ],
  "tables": [
    "np_link_preview_cache"
  ],
  "webhooks": {},
  "actions": {
    "fetch": "Fetch preview for a URL (POST /v1/preview)",
    "get": "Get cached preview (GET /v1/preview?url=...)",
    "clear": "Clear preview cache (DELETE /v1/cache)"
  },
  "envVars": {
    "required": [
      "DATABASE_URL"
    ],
    "optional": [
      "PORT",
      "PLUGIN_INTERNAL_SECRET"
    ]
  },
  "config": {
    "cacheTtlHours": 168,
    "timeoutSeconds": 10
  },
  "hooks": {
    "postInstall": null,
    "preUninstall": null,
    "postSync": null
  },
  "multiApp": {
    "supported": false
  },
  "permissions": {
    "database": [
      "create",
      "read",
      "update",
      "delete"
    ],
    "network": [
      "outbound-http"
    ],
    "filesystem": [
      "logs"
    ]
  }
}
