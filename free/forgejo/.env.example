# =============================================================================
# Forgejo + Forgejo Actions Runner — environment variables
# Plugin: plugins/free/forgejo  (ops profile)
# SPORT:  F09-ENV-VARS.md, F10-PORT-REGISTRY (3844 HTTP · 3222 SSH)
# =============================================================================

# ─── Required ─────────────────────────────────────────────────────────────────

# Forgejo admin account (created on first boot, idempotent on restart).
NSELF_FORGEJO_ADMIN_USER=admin
NSELF_FORGEJO_ADMIN_PASSWORD=changeme_min8chars
NSELF_FORGEJO_ADMIN_EMAIL=admin@example.com

# Runner registration token.
# Option A (recommended): leave blank — forgejo-init generates the token via
#   the Forgejo API and writes it to the forgejo_runner_config volume automatically.
# Option B (re-provision): set to an existing token from Forgejo Settings →
#   Actions → Runners → "Create new runner" — skips the API call entirely.
FORGEJO_RUNNER_REGISTRATION_TOKEN=

# ─── Optional (defaults shown) ────────────────────────────────────────────────

# Network ports (must match F10-PORT-REGISTRY; do not change without updating SPORT).
FORGEJO_HTTP_PORT=3844
FORGEJO_SSH_PORT=3222

# Public domain Forgejo uses in clone URLs and webhook callbacks.
# On the ops/sentry server set this to the public hostname (e.g. ci.example.com).
FORGEJO_DOMAIN=localhost

# Runner identity + capabilities.
FORGEJO_RUNNER_NAME=nself-runner
# Labels map `runs-on:` values from workflow YAML to Docker images.
# Format: <label>:docker://<image>   (comma-separated, no spaces)
# These labels make .github/workflows/*.yml portable from GitHub Actions.
FORGEJO_RUNNER_LABELS=ubuntu-latest:docker://node:20-bullseye,ubuntu-22.04:docker://node:20-bullseye

# Maximum concurrent workflow jobs.  Start at 1 to bound resource use.
FORGEJO_RUNNER_CAPACITY=1

# Resource caps on the runner container (untrusted workflow code).
FORGEJO_RUNNER_MEMORY=192m
FORGEJO_RUNNER_CPU=0.5
