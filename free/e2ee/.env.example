# nself-e2ee — E2EE key directory plugin
#
# This server is a KEY DIRECTORY. It stores PUBLIC key material only.
# Private keys NEVER touch the server, so there is intentionally NO
# encryption-key env var here — there is nothing secret to encrypt server-side.

# Required: Postgres connection string.
DATABASE_URL=postgres://nself:nself@postgres:5432/nself

# Optional: HTTP port (default 3055).
E2EE_PLUGIN_PORT=3055

# Optional: bind host (default 0.0.0.0).
E2EE_PLUGIN_HOST=0.0.0.0

# Optional: log level (default info). Body logging is disabled by design.
E2EE_LOG_LEVEL=info

# Optional: max prekeys accepted in a single batch upload (default 100 each).
E2EE_MAX_ONE_TIME_PREKEYS=100
E2EE_MAX_KYBER_PREKEYS=100
