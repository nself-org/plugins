{
  "annotations": { "list": [] },
  "description": "PostgreSQL: QPS, connections, slow queries, replication, locks, cache hit ratio, bloat, WAL",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "QPS by Operation",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum by (datname) (rate(pg_stat_database_tup_fetched{env=\"$env\"}[$__rate_interval]))", "legendFormat": "SELECT {{datname}}" },
        { "expr": "sum by (datname) (rate(pg_stat_database_tup_inserted{env=\"$env\"}[$__rate_interval]))", "legendFormat": "INSERT {{datname}}" },
        { "expr": "sum by (datname) (rate(pg_stat_database_tup_updated{env=\"$env\"}[$__rate_interval]))", "legendFormat": "UPDATE {{datname}}" },
        { "expr": "sum by (datname) (rate(pg_stat_database_tup_deleted{env=\"$env\"}[$__rate_interval]))", "legendFormat": "DELETE {{datname}}" }
      ]
    },
    {
      "title": "Connections vs Max",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(pg_stat_activity_count{env=\"$env\"})", "legendFormat": "Active" },
        { "expr": "pg_settings_max_connections{env=\"$env\"}", "legendFormat": "Max" }
      ]
    },
    {
      "title": "Slow Queries (Top 10)",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "topk(10, pg_stat_statements_mean_time_seconds{env=\"$env\"})", "format": "table", "instant": true }
      ]
    },
    {
      "title": "Replication Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "expr": "pg_replication_lag{env=\"$env\"}", "legendFormat": "Lag" }
      ]
    },
    {
      "title": "Lock Waits",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum by (mode) (pg_locks_count{env=\"$env\"})", "legendFormat": "{{mode}}" }
      ]
    },
    {
      "title": "Deadlocks",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(rate(pg_stat_database_deadlocks{env=\"$env\"}[$__rate_interval]))", "legendFormat": "Deadlocks/s" }
      ]
    },
    {
      "title": "Cache Hit Ratio",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.9 }, { "color": "green", "value": 0.99 }] } }, "overrides": [] },
      "targets": [
        { "expr": "sum(pg_stat_database_blks_hit{env=\"$env\"}) / (sum(pg_stat_database_blks_hit{env=\"$env\"}) + sum(pg_stat_database_blks_read{env=\"$env\"}))", "legendFormat": "Hit Ratio" }
      ]
    },
    {
      "title": "Index Usage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        { "expr": "sum(pg_stat_user_tables_idx_scan{env=\"$env\"}) / (sum(pg_stat_user_tables_idx_scan{env=\"$env\"}) + sum(pg_stat_user_tables_seq_scan{env=\"$env\"}))", "legendFormat": "Index Usage" }
      ]
    },
    {
      "title": "Table Sizes (Top 20)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        { "expr": "topk(20, pg_total_relation_size_bytes{env=\"$env\"})", "legendFormat": "{{relname}}", "format": "table", "instant": true }
      ]
    },
    {
      "title": "WAL Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "targets": [
        { "expr": "rate(pg_stat_wal_bytes_total{env=\"$env\"}[$__rate_interval])", "legendFormat": "WAL bytes/s" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["nself", "database", "postgres"],
  "templating": {
    "list": [
      { "name": "env", "type": "custom", "query": "dev,staging,prod", "current": { "text": "prod", "value": "prod" } },
      { "name": "DS_PROMETHEUS", "type": "datasource", "query": "prometheus" },
      { "name": "interval", "type": "interval", "query": "1m,5m,15m,1h", "auto": true }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "06 - Database",
  "uid": "nself-database",
  "version": 1
}
