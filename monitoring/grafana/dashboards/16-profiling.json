{
  "annotations": { "list": [] },
  "description": "Runtime profiling: CPU flamegraph, allocation flamegraph, goroutine count, heap bytes",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "CPU Profile (Flamegraph)",
      "type": "flamegraph",
      "gridPos": { "h": 12, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "phlare", "uid": "${DS_PHLARE}" },
      "targets": [
        { "profileTypeId": "process_cpu:cpu:nanoseconds:cpu:nanoseconds", "labelSelector": "{service_name=\"$service\",env=\"$env\"}" }
      ]
    },
    {
      "title": "Allocation Profile (Flamegraph)",
      "type": "flamegraph",
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "phlare", "uid": "${DS_PHLARE}" },
      "targets": [
        { "profileTypeId": "memory:alloc_objects:count:space:bytes", "labelSelector": "{service_name=\"$service\",env=\"$env\"}" }
      ]
    },
    {
      "title": "Goroutine Count",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "go_goroutines{env=\"$env\",service=~\"$service\"}", "legendFormat": "{{service}}" }
      ]
    },
    {
      "title": "Heap Bytes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        { "expr": "go_memstats_heap_alloc_bytes{env=\"$env\",service=~\"$service\"}", "legendFormat": "{{service}} heap" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["nself", "profiling"],
  "templating": {
    "list": [
      { "name": "env", "type": "custom", "query": "dev,staging,prod", "current": { "text": "prod", "value": "prod" } },
      { "name": "service", "type": "query", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "query": "label_values(go_goroutines{env=\"$env\"}, service)", "multi": true, "includeAll": true },
      { "name": "DS_PROMETHEUS", "type": "datasource", "query": "prometheus" },
      { "name": "DS_PHLARE", "type": "datasource", "query": "phlare" },
      { "name": "interval", "type": "interval", "query": "1m,5m,15m,1h", "auto": true }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "16 - Profiling",
  "uid": "nself-profiling",
  "version": 1
}
