{
  "annotations": { "list": [] },
  "description": "Distributed tracing: service graph, RED metrics, slowest operations, top errors, dependency map",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "Service Graph",
      "type": "nodeGraph",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        { "queryType": "serviceMap" }
      ]
    },
    {
      "title": "RED Metrics (Rate / Error / Duration)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "expr": "sum by (service) (rate(traces_spanmetrics_calls_total{env=\"$env\"}[$__rate_interval]))", "legendFormat": "Rate: {{service}}" },
        { "expr": "sum by (service) (rate(traces_spanmetrics_calls_total{env=\"$env\",status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval]))", "legendFormat": "Errors: {{service}}" },
        { "expr": "histogram_quantile(0.95, sum by (le, service) (rate(traces_spanmetrics_latency_bucket{env=\"$env\"}[$__rate_interval])))", "legendFormat": "p95: {{service}}" }
      ]
    },
    {
      "title": "Slowest Operations",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "topk(20, histogram_quantile(0.99, sum by (le, service, span_name) (rate(traces_spanmetrics_latency_bucket{env=\"$env\"}[$__rate_interval]))))", "format": "table", "instant": true }
      ]
    },
    {
      "title": "Top Errors by Span",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "topk(20, sum by (service, span_name) (increase(traces_spanmetrics_calls_total{env=\"$env\",status_code=\"STATUS_CODE_ERROR\"}[1h])))", "format": "table", "instant": true }
      ]
    },
    {
      "title": "Service Dependency Map",
      "type": "nodeGraph",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        { "queryType": "serviceMap" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["nself", "tracing", "tempo"],
  "templating": {
    "list": [
      { "name": "env", "type": "custom", "query": "dev,staging,prod", "current": { "text": "prod", "value": "prod" } },
      { "name": "DS_PROMETHEUS", "type": "datasource", "query": "prometheus" },
      { "name": "interval", "type": "interval", "query": "1m,5m,15m,1h", "auto": true }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "11 - Tracing Overview",
  "uid": "nself-tracing-overview",
  "version": 1
}
