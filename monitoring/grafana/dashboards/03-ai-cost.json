{
  "annotations": { "list": [] },
  "description": "AI provider costs, token usage, per-model breakdown, quality scores, cost projection",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "Total Spend (24h / 7d / 30d)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "targets": [
        { "expr": "sum(increase(ai_cost_dollars_total{env=\"$env\"}[24h]))", "legendFormat": "24h" },
        { "expr": "sum(increase(ai_cost_dollars_total{env=\"$env\"}[7d]))", "legendFormat": "7d" },
        { "expr": "sum(increase(ai_cost_dollars_total{env=\"$env\"}[30d]))", "legendFormat": "30d" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Spend Per Provider",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "targets": [
        { "expr": "sum by (provider) (rate(ai_cost_dollars_total{env=\"$env\"}[$__rate_interval]))", "legendFormat": "{{provider}}" }
      ]
    },
    {
      "title": "Spend Per Model",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "targets": [
        { "expr": "sum by (model) (increase(ai_cost_dollars_total{env=\"$env\"}[24h]))", "legendFormat": "{{model}}", "format": "table", "instant": true }
      ]
    },
    {
      "title": "Tokens Per Purpose (Stacked)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "custom": { "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [
        { "expr": "sum by (purpose) (rate(ai_tokens_total{env=\"$env\"}[$__rate_interval]))", "legendFormat": "{{purpose}}" }
      ]
    },
    {
      "title": "Cost Per User (Top 20)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "targets": [
        { "rawSql": "SELECT user_id, SUM(cost_usd) as total_cost FROM np_ai_usage_log WHERE created_at > NOW() - INTERVAL '30 days' AND tenant = '$tenant' GROUP BY user_id ORDER BY total_cost DESC LIMIT 20", "format": "table" }
      ]
    },
    {
      "title": "Retries",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum by (provider) (rate(ai_retries_total{env=\"$env\"}[$__rate_interval]))", "legendFormat": "{{provider}}" }
      ]
    },
    {
      "title": "Rate Limits Hit",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum by (provider) (rate(ai_rate_limit_hits_total{env=\"$env\"}[$__rate_interval]))", "legendFormat": "{{provider}}" }
      ]
    },
    {
      "title": "Quality Score Per Model",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        { "expr": "avg by (model) (ai_quality_score{env=\"$env\"})", "legendFormat": "{{model}}" }
      ]
    },
    {
      "title": "Tokens/sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum by (model) (rate(ai_tokens_total{env=\"$env\"}[$__rate_interval]))", "legendFormat": "{{model}}" }
      ]
    },
    {
      "title": "Cost Projection (7d Linear Regression)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "targets": [
        { "expr": "predict_linear(sum(ai_cost_dollars_total{env=\"$env\"})[7d:1h], 7*24*3600)", "legendFormat": "Projected 7d" },
        { "expr": "sum(ai_cost_dollars_total{env=\"$env\"})", "legendFormat": "Current" }
      ]
    },
    {
      "title": "Per-User Per-Day Cost (DB)",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "targets": [
        { "rawSql": "SELECT date_trunc('day', created_at) as day, user_id, SUM(cost_usd) as cost, SUM(tokens_used) as tokens FROM np_ai_usage_log WHERE created_at > NOW() - INTERVAL '7 days' AND tenant = '$tenant' GROUP BY day, user_id ORDER BY day DESC, cost DESC LIMIT 100", "format": "table" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["nself", "ai", "cost"],
  "templating": {
    "list": [
      { "name": "env", "type": "custom", "query": "dev,staging,prod", "current": { "text": "prod", "value": "prod" } },
      { "name": "tenant", "type": "query", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "query": "label_values(ai_cost_dollars_total{env=\"$env\"}, tenant)", "multi": false, "includeAll": true },
      { "name": "DS_PROMETHEUS", "type": "datasource", "query": "prometheus" },
      { "name": "DS_POSTGRES", "type": "datasource", "query": "postgres" },
      { "name": "interval", "type": "interval", "query": "1m,5m,15m,1h", "auto": true }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "title": "03 - AI Cost",
  "uid": "nself-ai-cost",
  "version": 1
}
