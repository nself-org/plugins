{
  "annotations": { "list": [] },
  "description": "Frontend performance: Core Web Vitals (LCP, FID, CLS, TTFB, INP), JS errors, API latency, browser breakdown",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "LCP (Largest Contentful Paint)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 2.5 }, { "color": "red", "value": 4 }] } }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.75, sum by (le, route) (rate(webvitals_lcp_seconds_bucket{env=\"$env\"}[$__rate_interval])))", "legendFormat": "p75 {{route}}" }
      ]
    },
    {
      "title": "FID (First Input Delay)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ms", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 300 }] } }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.75, sum by (le, route) (rate(webvitals_fid_milliseconds_bucket{env=\"$env\"}[$__rate_interval])))", "legendFormat": "p75 {{route}}" }
      ]
    },
    {
      "title": "CLS (Cumulative Layout Shift)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.1 }, { "color": "red", "value": 0.25 }] } }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.75, sum by (le, route) (rate(webvitals_cls_bucket{env=\"$env\"}[$__rate_interval])))", "legendFormat": "p75 {{route}}" }
      ]
    },
    {
      "title": "TTFB (Time to First Byte)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.75, sum by (le, route) (rate(webvitals_ttfb_seconds_bucket{env=\"$env\"}[$__rate_interval])))", "legendFormat": "p75 {{route}}" }
      ]
    },
    {
      "title": "INP (Interaction to Next Paint)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ms", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 200 }, { "color": "red", "value": 500 }] } }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.75, sum by (le, route) (rate(webvitals_inp_milliseconds_bucket{env=\"$env\"}[$__rate_interval])))", "legendFormat": "p75 {{route}}" }
      ]
    },
    {
      "title": "JS Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum by (route) (rate(frontend_js_errors_total{env=\"$env\"}[$__rate_interval]))", "legendFormat": "{{route}}" }
      ]
    },
    {
      "title": "API Call Latency (from Client)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(frontend_api_duration_seconds_bucket{env=\"$env\"}[$__rate_interval])))", "legendFormat": "p95 {{endpoint}}" }
      ]
    },
    {
      "title": "Browser / Device Breakdown",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum by (browser) (increase(frontend_pageviews_total{env=\"$env\"}[24h]))", "legendFormat": "{{browser}}" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["nself", "frontend", "webvitals"],
  "templating": {
    "list": [
      { "name": "env", "type": "custom", "query": "dev,staging,prod", "current": { "text": "prod", "value": "prod" } },
      { "name": "DS_PROMETHEUS", "type": "datasource", "query": "prometheus" },
      { "name": "interval", "type": "interval", "query": "1m,5m,15m,1h", "auto": true }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "title": "14 - Frontend Web Vitals",
  "uid": "nself-frontend-webvitals",
  "version": 1
}
