{
  "annotations": { "list": [] },
  "description": "nClaw memory system: extractions, dedup, topics, graph, search, embeddings",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "Extractions/min by Kind",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum by (kind) (rate(claw_extractions_total{env=\"$env\",tenant=~\"$tenant\"}[$__rate_interval])) * 60", "legendFormat": "{{kind}}" }
      ]
    },
    {
      "title": "Dedup Ratio",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        { "expr": "sum(rate(claw_dedup_hits_total{env=\"$env\",tenant=~\"$tenant\"}[$__rate_interval])) / sum(rate(claw_extractions_total{env=\"$env\",tenant=~\"$tenant\"}[$__rate_interval]))", "legendFormat": "Dedup" }
      ]
    },
    {
      "title": "Topic Confidence",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(claw_topic_confidence_bucket{env=\"$env\",tenant=~\"$tenant\"}[$__rate_interval])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(claw_topic_confidence_bucket{env=\"$env\",tenant=~\"$tenant\"}[$__rate_interval])))", "legendFormat": "p95" }
      ]
    },
    {
      "title": "Active Topics",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(claw_topics_active{env=\"$env\",tenant=~\"$tenant\"})", "legendFormat": "Topics" }
      ]
    },
    {
      "title": "Memory Bytes / Tenant",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        { "expr": "sum by (tenant) (claw_memory_bytes{env=\"$env\"})", "legendFormat": "{{tenant}}", "format": "table", "instant": true }
      ]
    },
    {
      "title": "Graph Edges / Day",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(increase(claw_graph_edges_created_total{env=\"$env\",tenant=~\"$tenant\"}[24h]))", "legendFormat": "Edges/day" }
      ]
    },
    {
      "title": "Search Latency p95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(claw_search_duration_seconds_bucket{env=\"$env\",tenant=~\"$tenant\"}[$__rate_interval])))", "legendFormat": "p95" }
      ]
    },
    {
      "title": "Vector Index Size",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        { "expr": "sum(claw_vector_index_bytes{env=\"$env\",tenant=~\"$tenant\"})", "legendFormat": "Size" }
      ]
    },
    {
      "title": "Embedding Model Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum by (model) (increase(claw_embeddings_total{env=\"$env\",tenant=~\"$tenant\"}[24h]))", "legendFormat": "{{model}}" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["nself", "claw", "memory"],
  "templating": {
    "list": [
      { "name": "env", "type": "custom", "query": "dev,staging,prod", "current": { "text": "prod", "value": "prod" } },
      { "name": "tenant", "type": "query", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "query": "label_values(claw_extractions_total{env=\"$env\"}, tenant)", "multi": true, "includeAll": true },
      { "name": "DS_PROMETHEUS", "type": "datasource", "query": "prometheus" },
      { "name": "interval", "type": "interval", "query": "1m,5m,15m,1h", "auto": true }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "title": "08 - Claw Memory",
  "uid": "nself-claw-memory",
  "version": 1
}
