{
  "annotations": { "list": [] },
  "description": "Mux email pipeline: ingestion rates, classification, action success, false positives, latency, accuracy",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "Messages Received/min by Provider",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum by (provider) (rate(mux_messages_received_total{env=\"$env\"}[$__rate_interval])) * 60", "legendFormat": "{{provider}}" }
      ]
    },
    {
      "title": "Classification Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum by (category) (increase(mux_classifications_total{env=\"$env\"}[24h]))", "legendFormat": "{{category}}" }
      ]
    },
    {
      "title": "Action Success %",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.9 }, { "color": "green", "value": 0.95 }] } }, "overrides": [] },
      "targets": [
        { "expr": "sum(rate(mux_actions_success_total{env=\"$env\"}[$__rate_interval])) / sum(rate(mux_actions_total{env=\"$env\"}[$__rate_interval]))", "legendFormat": "Success" }
      ]
    },
    {
      "title": "False Positives",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(rate(mux_false_positives_total{env=\"$env\"}[$__rate_interval]))", "legendFormat": "False Positives/s" }
      ]
    },
    {
      "title": "Stage Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, stage) (rate(mux_stage_duration_seconds_bucket{env=\"$env\"}[$__rate_interval])))", "legendFormat": "p95 {{stage}}" }
      ]
    },
    {
      "title": "Accuracy Trend",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        { "expr": "avg_over_time(mux_classification_accuracy{env=\"$env\"}[1h])", "legendFormat": "Accuracy" }
      ]
    },
    {
      "title": "Throttling Events",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum by (provider) (rate(mux_throttle_events_total{env=\"$env\"}[$__rate_interval]))", "legendFormat": "{{provider}}" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["nself", "mux", "email"],
  "templating": {
    "list": [
      { "name": "env", "type": "custom", "query": "dev,staging,prod", "current": { "text": "prod", "value": "prod" } },
      { "name": "DS_PROMETHEUS", "type": "datasource", "query": "prometheus" },
      { "name": "interval", "type": "interval", "query": "1m,5m,15m,1h", "auto": true }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "title": "07 - Mux Email",
  "uid": "nself-mux-email",
  "version": 1
}
