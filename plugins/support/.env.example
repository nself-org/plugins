# =============================================================================
# usupport Plugin - Environment Configuration
# =============================================================================
# Helpdesk and customer support for nself-chat - ticketing, SLA, canned responses, knowledge base, analytics
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Auto-provided by nself CLI
# -----------------------------------------------------------------------------

# PostgreSQL connection string (auto-provided by nself)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# -----------------------------------------------------------------------------
# REQUIRED - Security Configuration (auto-provided by nself)
# -----------------------------------------------------------------------------

# API key for inter-plugin authentication
SUPPORT_API_KEY=your-api-key-here

# Rate limiting (requests per window)
SUPPORT_RATE_LIMIT_MAX=100

# Rate limiting window (milliseconds)
SUPPORT_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# OPTIONAL - Server Configuration
# -----------------------------------------------------------------------------

# Server port (default from plugin.json: 3111)
SUPPORT_PORT=3111

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# OPTIONAL - Plugin-Specific Configuration
# -----------------------------------------------------------------------------

# SUPPORT_EMAIL
SUPPORT_EMAIL=value

# SUPPORT_EMAIL_SMTP_HOST
SUPPORT_EMAIL_SMTP_HOST=value

# SUPPORT_EMAIL_FROM_NAME
SUPPORT_EMAIL_FROM_NAME=value

# SUPPORT_DEFAULT_FIRST_RESPONSE_MINUTES
SUPPORT_DEFAULT_FIRST_RESPONSE_MINUTES=value

# SUPPORT_DEFAULT_RESOLUTION_MINUTES
SUPPORT_DEFAULT_RESOLUTION_MINUTES=value

# SUPPORT_BUSINESS_HOURS_START
SUPPORT_BUSINESS_HOURS_START=value

# SUPPORT_BUSINESS_HOURS_END
SUPPORT_BUSINESS_HOURS_END=value

# SUPPORT_TIMEZONE
SUPPORT_TIMEZONE=value

# SUPPORT_AUTO_ASSIGNMENT
SUPPORT_AUTO_ASSIGNMENT=value

# SUPPORT_ASSIGNMENT_METHOD
SUPPORT_ASSIGNMENT_METHOD=value

# SUPPORT_MAX_TICKETS_PER_AGENT
SUPPORT_MAX_TICKETS_PER_AGENT=value

# SUPPORT_CSAT_ENABLED
SUPPORT_CSAT_ENABLED=value

# SUPPORT_CSAT_SEND_DELAY_HOURS
SUPPORT_CSAT_SEND_DELAY_HOURS=value

# SUPPORT_NPS_ENABLED
SUPPORT_NPS_ENABLED=value

# SUPPORT_NPS_SEND_INTERVAL_DAYS
SUPPORT_NPS_SEND_INTERVAL_DAYS=value

# SUPPORT_KB_ENABLED
SUPPORT_KB_ENABLED=value

# SUPPORT_KB_PUBLIC_ACCESS
SUPPORT_KB_PUBLIC_ACCESS=value

# SUPPORT_KB_SUGGEST_ARTICLES
SUPPORT_KB_SUGGEST_ARTICLES=value

# SUPPORT_NOTIFY_ON_NEW_TICKET
SUPPORT_NOTIFY_ON_NEW_TICKET=value

# SUPPORT_NOTIFY_ON_ASSIGNMENT
SUPPORT_NOTIFY_ON_ASSIGNMENT=value

# SUPPORT_NOTIFY_ON_SLA_BREACH
SUPPORT_NOTIFY_ON_SLA_BREACH=value

# SUPPORT_NOTIFY_ON_CUSTOMER_REPLY
SUPPORT_NOTIFY_ON_CUSTOMER_REPLY=value


# -----------------------------------------------------------------------------
# Additional Configuration
# -----------------------------------------------------------------------------
#
# For complete plugin documentation and configuration options, see:
# - Plugin README: plugins/${PLUGIN_NAME}/README.md
# - Plugin JSON: plugins/${PLUGIN_NAME}/plugin.json
# - nself documentation: https://github.com/acamarata/nself-plugins
#
# Note: All variables marked as REQUIRED are auto-provided by the nself CLI
# during plugin installation and do not need manual configuration.
# -----------------------------------------------------------------------------
