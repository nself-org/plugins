# =============================================================================
# Admin API Plugin - Environment Configuration
# =============================================================================
# Comprehensive admin dashboard API for system health, user management,
# and metrics
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Auto-provided by nself CLI
# -----------------------------------------------------------------------------

# PostgreSQL connection string (auto-provided by nself)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# -----------------------------------------------------------------------------
# REQUIRED - Security Configuration (auto-provided by nself)
# -----------------------------------------------------------------------------

# API key for inter-plugin authentication
ADMIN_API_KEY=your-api-key-here

# Rate limiting (requests per window)
ADMIN_RATE_LIMIT_MAX=100

# Rate limiting window (milliseconds)
ADMIN_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# OPTIONAL - Server Configuration
# -----------------------------------------------------------------------------

# Server port (default from plugin.json: 3214)
ADMIN_API_PORT=3214

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# OPTIONAL - Authentication Settings
# -----------------------------------------------------------------------------

# JWT secret for admin session tokens
# Generate with: openssl rand -hex 32
ADMIN_JWT_SECRET=your-64-character-hex-jwt-secret-here

# Admin session timeout (minutes)
# Sessions expire after this period of inactivity
ADMIN_SESSION_TIMEOUT_MINUTES=60

# -----------------------------------------------------------------------------
# OPTIONAL - Metrics Collection
# -----------------------------------------------------------------------------

# Metrics collection interval (seconds)
# How often to collect system metrics (CPU, memory, disk, etc.)
ADMIN_METRICS_COLLECTION_INTERVAL_SECONDS=60

# -----------------------------------------------------------------------------
# Admin API Features
# -----------------------------------------------------------------------------
#
# System Health:
#   - Plugin status monitoring
#   - Database health checks
#   - Service availability
#   - Resource utilization (CPU, memory, disk)
#
# User Management:
#   - View all users
#   - User activity statistics
#   - Role assignments
#   - Account status management
#
# Metrics Dashboard:
#   - Real-time system metrics
#   - Plugin performance stats
#   - API request analytics
#   - Error rate monitoring
#
# Audit Log:
#   - Admin actions logged
#   - User activity tracking
#   - System events
#   - Security events
#
# Security:
#   - JWT-based authentication
#   - Session management
#   - Rate limiting
#   - Audit logging
#
# Integration:
#   - Access all plugin APIs from single dashboard
#   - Cross-plugin user management
#   - System-wide health monitoring
#   - Centralized logging
# -----------------------------------------------------------------------------
