# =============================================================================
# Admin API Plugin - Environment Configuration
# =============================================================================
# Admin API service providing aggregated metrics, system health, session counts,
# storage breakdown, and real-time dashboard endpoints
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Auto-provided by nself CLI
# -----------------------------------------------------------------------------

# PostgreSQL connection string (auto-provided by nself)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# -----------------------------------------------------------------------------
# REQUIRED - Security Configuration (auto-provided by nself)
# -----------------------------------------------------------------------------

# API key for inter-plugin authentication
ADMIN_API_API_KEY=your-api-key-here

# Rate limiting (requests per window)
ADMIN_API_RATE_LIMIT_MAX=100

# Rate limiting window (milliseconds)
ADMIN_API_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# OPTIONAL - Server Configuration
# -----------------------------------------------------------------------------

# Server port (default from plugin.json: 3212)
ADMIN_API_PLUGIN_PORT=3212

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# OPTIONAL - Plugin-Specific Configuration
# -----------------------------------------------------------------------------

# Prometheus server URL for health checking
# PROMETHEUS_URL=http://localhost:9090

# Cache TTL in seconds for metrics responses
# ADMIN_API_CACHE_TTL=30

# Enable WebSocket support for real-time dashboard updates
# ADMIN_API_WS_ENABLED=true

# Metrics retention in days (snapshots older than this are cleaned up)
# ADMIN_API_METRICS_RETENTION_DAYS=90

# Snapshot collection interval in minutes
# ADMIN_API_SNAPSHOT_INTERVAL_MINUTES=5


# -----------------------------------------------------------------------------
# Additional Configuration
# -----------------------------------------------------------------------------
#
# For complete plugin documentation and configuration options, see:
# - Plugin README: plugins/admin-api/README.md
# - Plugin JSON: plugins/admin-api/plugin.json
# - nself documentation: https://github.com/acamarata/nself-plugins
#
# Note: All variables marked as REQUIRED are auto-provided by the nself CLI
# during plugin installation and do not need manual configuration.
# -----------------------------------------------------------------------------
