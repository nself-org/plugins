# Database Configuration (Required)
DATABASE_URL=postgresql://user:password@localhost:5432/nself
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nself
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_SSL=false

# Server Configuration
CHAT_PLUGIN_PORT=3401
CHAT_PLUGIN_HOST=0.0.0.0

# Chat Limits
CHAT_MAX_MESSAGE_LENGTH=10000
CHAT_MAX_ATTACHMENTS=10
CHAT_EDIT_WINDOW_MINUTES=15
CHAT_MAX_PARTICIPANTS=100
CHAT_MAX_PINNED=50

# Security (Optional)
CHAT_API_KEY=
CHAT_RATE_LIMIT_MAX=200
CHAT_RATE_LIMIT_WINDOW_MS=60000

# Logging
LOG_LEVEL=info
