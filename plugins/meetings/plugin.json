{
  "name": "meetings",
  "version": "1.0.0",
  "description": "Calendar integration and meeting management with room booking, Google/Outlook sync, recurring meetings, and availability tracking",
  "author": "nself",
  "license": "Source-Available",
  "homepage": "https://github.com/acamarata/nself-plugins/tree/main/plugins/meetings",
  "repository": "https://github.com/acamarata/nself-plugins",
  "minNselfVersion": "0.4.8",
  "port": 3710,
  "category": "development",
  "tags": [
    "meetings",
    "calendar",
    "rooms",
    "scheduling",
    "availability",
    "google-calendar",
    "outlook"
  ],
  "tables": [
    "np_meetings_events",
    "np_meetings_attendees",
    "np_meetings_rooms",
    "np_meetings_calendars",
    "np_meetings_calendar_shares",
    "np_meetings_external_calendars",
    "np_meetings_templates",
    "np_meetings_reminders",
    "np_meetings_waitlist"
  ],
  "webhooks": {
    "event.created": "A new meeting event was created",
    "event.updated": "A meeting event was updated",
    "event.cancelled": "A meeting event was cancelled",
    "event.deleted": "A meeting event was deleted",
    "rsvp.updated": "An attendee RSVP was updated",
    "room.booked": "A meeting room was booked",
    "room.released": "A meeting room booking was released",
    "sync.completed": "External calendar sync completed",
    "reminder.sent": "A meeting reminder was sent"
  },
  "actions": {
    "init": "Initialize meetings system",
    "server": "Start meetings server",
    "status": "View system status",
    "events": "Manage events",
    "rooms": "Manage rooms",
    "calendars": "Manage calendars",
    "templates": "Manage meeting templates"
  },
  "envVars": {
    "required": [
      "DATABASE_URL"
    ],
    "optional": [
      "MEETINGS_PLUGIN_PORT",
      "GOOGLE_CALENDAR_CLIENT_ID",
      "GOOGLE_CALENDAR_CLIENT_SECRET",
      "GOOGLE_CALENDAR_REDIRECT_URI",
      "OUTLOOK_CALENDAR_CLIENT_ID",
      "OUTLOOK_CALENDAR_CLIENT_SECRET",
      "OUTLOOK_CALENDAR_REDIRECT_URI"
    ]
  },
  "config": {
    "webhookPath": "/webhooks/meetings",
    "defaultTimezone": "UTC",
    "businessHoursStart": "09:00",
    "businessHoursEnd": "17:00",
    "slotDurationMinutes": 30,
    "defaultBufferMinutes": 15,
    "maxAdvanceBookingDays": 90
  },
  "multiApp": {
    "supported": true,
    "isolationColumn": "source_account_id",
    "pkStrategy": "single",
    "defaultValue": "primary"
  },
  "hooks": {
    "postInstall": "install.sh",
    "preUninstall": "uninstall.sh",
    "postSync": null
  },
  "permissions": {
    "database": [
      "create",
      "read",
      "update",
      "delete"
    ],
    "network": [
      "*"
    ],
    "filesystem": [
      "logs",
      "cache"
    ]
  }
}
