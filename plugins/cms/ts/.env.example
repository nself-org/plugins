# CMS Plugin Configuration

# Database (required)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nself
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_SSL=false

# Server Configuration
CMS_PLUGIN_PORT=3501
CMS_PLUGIN_HOST=0.0.0.0

# CMS Settings
CMS_MAX_BODY_LENGTH=500000
CMS_MAX_TITLE_LENGTH=500
CMS_SLUG_MAX_LENGTH=200
CMS_MAX_VERSIONS=50
CMS_SCHEDULED_CHECK_INTERVAL_MS=60000
CMS_DEFAULT_CONTENT_TYPES=post,page,recipe

# Security (optional)
CMS_API_KEY=
CMS_RATE_LIMIT_MAX=200
CMS_RATE_LIMIT_WINDOW_MS=60000

# Logging
LOG_LEVEL=info
