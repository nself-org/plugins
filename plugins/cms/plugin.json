{
  "name": "cms",
  "version": "1.0.0",
  "description": "Headless CMS plugin with content types, posts, categories, tags, and versioning",
  "author": "nself",
  "license": "Source-Available",
  "homepage": "https://github.com/acamarata/nself-plugins/tree/main/plugins/cms",
  "repository": "https://github.com/acamarata/nself-plugins",
  "minNselfVersion": "0.4.8",
  "category": "content",
  "tags": [
    "cms",
    "content",
    "blog",
    "posts",
    "headless"
  ],
  "tables": [
    "np_cms_content_types",
    "np_cms_posts",
    "np_cms_post_versions",
    "np_cms_categories",
    "np_cms_tags",
    "np_cms_post_categories",
    "np_cms_post_tags",
    "np_cms_webhook_events"
  ],
  "webhooks": {
    "post.created": "Sync new post to database",
    "post.updated": "Update post data and create version",
    "post.deleted": "Soft-delete post",
    "post.published": "Mark post as published",
    "post.unpublished": "Mark post as draft",
    "category.created": "Sync new category",
    "category.updated": "Update category data",
    "category.deleted": "Remove category",
    "tag.created": "Sync new tag",
    "tag.updated": "Update tag data",
    "tag.deleted": "Remove tag"
  },
  "actions": {
    "init": "Initialize database schema",
    "server": "Start the HTTP server",
    "status": "Show plugin status and content statistics",
    "posts": "Manage posts (list, create, update, delete)",
    "categories": "Manage categories",
    "tags": "Manage tags",
    "content-types": "Manage content types",
    "publish": "Publish a post",
    "stats": "Show content statistics"
  },
  "envVars": {
    "required": [
      "DATABASE_URL"
    ],
    "optional": [
      "CMS_PLUGIN_PORT",
      "CMS_MAX_BODY_LENGTH",
      "CMS_MAX_TITLE_LENGTH",
      "CMS_SLUG_MAX_LENGTH",
      "CMS_MAX_VERSIONS",
      "CMS_SCHEDULED_CHECK_INTERVAL_MS",
      "CMS_DEFAULT_CONTENT_TYPES",
      "CMS_API_KEY",
      "CMS_RATE_LIMIT_MAX",
      "CMS_RATE_LIMIT_WINDOW_MS"
    ]
  },
  "config": {
    "port": 3501,
    "webhookPath": "/webhooks/cms",
    "retryAttempts": 3,
    "retryDelay": 1000
  },
  "hooks": {
    "postInstall": "install.sh",
    "preUninstall": "uninstall.sh",
    "postSync": null
  },
  "multiApp": {
    "supported": true,
    "isolationColumn": "source_account_id",
    "pkStrategy": "uuid",
    "defaultValue": "primary"
  },
  "permissions": {
    "database": [
      "create",
      "read",
      "update",
      "delete"
    ],
    "network": [],
    "filesystem": [
      "logs",
      "cache"
    ]
  }
}
