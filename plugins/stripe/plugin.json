{
  "name": "stripe",
  "version": "1.0.0",
  "description": "Stripe billing data sync with webhook handling",
  "author": "nself",
  "license": "Source-Available",
  "homepage": "https://github.com/acamarata/nself-plugins/tree/main/plugins/stripe",
  "repository": "https://github.com/acamarata/nself-plugins",
  "minNselfVersion": "0.4.8",
  "category": "billing",
  "tags": ["payments", "billing", "subscriptions", "stripe", "webhooks"],

  "tables": [
    "stripe_customers",
    "stripe_products",
    "stripe_prices",
    "stripe_coupons",
    "stripe_promotion_codes",
    "stripe_subscriptions",
    "stripe_subscription_items",
    "stripe_subscription_schedules",
    "stripe_invoices",
    "stripe_invoice_items",
    "stripe_credit_notes",
    "stripe_charges",
    "stripe_refunds",
    "stripe_disputes",
    "stripe_payment_intents",
    "stripe_setup_intents",
    "stripe_payment_methods",
    "stripe_balance_transactions",
    "stripe_checkout_sessions",
    "stripe_checkout_session_line_items",
    "stripe_tax_ids",
    "stripe_tax_rates",
    "stripe_webhook_events"
  ],

  "webhooks": {
    "customer.created": "Sync new customer to database",
    "customer.updated": "Update customer data",
    "customer.deleted": "Mark customer as deleted",
    "customer.tax_id.created": "Sync new customer tax ID",
    "customer.tax_id.deleted": "Remove customer tax ID",
    "customer.tax_id.updated": "Update customer tax ID",
    "product.created": "Sync new product",
    "product.updated": "Update product data",
    "product.deleted": "Mark product as deleted",
    "price.created": "Sync new price",
    "price.updated": "Update price data",
    "price.deleted": "Mark price as deleted",
    "coupon.created": "Sync new coupon",
    "coupon.updated": "Update coupon data",
    "coupon.deleted": "Mark coupon as deleted",
    "promotion_code.created": "Sync new promotion code",
    "promotion_code.updated": "Update promotion code",
    "promotion_code.deleted": "Remove promotion code",
    "customer.subscription.created": "Track new subscription",
    "customer.subscription.updated": "Update subscription status",
    "customer.subscription.deleted": "Handle subscription cancellation",
    "customer.subscription.trial_will_end": "Trial ending notification",
    "customer.subscription.paused": "Handle subscription pause",
    "customer.subscription.resumed": "Handle subscription resume",
    "customer.subscription.pending_update_applied": "Apply pending subscription update",
    "customer.subscription.pending_update_expired": "Handle expired pending update",
    "subscription_schedule.aborted": "Handle schedule abort",
    "subscription_schedule.canceled": "Handle schedule cancellation",
    "subscription_schedule.completed": "Handle schedule completion",
    "subscription_schedule.created": "Sync new schedule",
    "subscription_schedule.expiring": "Handle expiring schedule",
    "subscription_schedule.released": "Handle schedule release",
    "subscription_schedule.updated": "Update schedule data",
    "invoice.created": "Record new invoice",
    "invoice.updated": "Update invoice data",
    "invoice.deleted": "Remove invoice",
    "invoice.finalized": "Handle invoice finalization",
    "invoice.paid": "Mark invoice as paid",
    "invoice.payment_failed": "Handle failed payment",
    "invoice.payment_succeeded": "Record successful payment",
    "invoice.voided": "Handle voided invoice",
    "invoice.marked_uncollectible": "Handle uncollectible invoice",
    "invoice.sent": "Handle sent invoice",
    "invoice.upcoming": "Handle upcoming invoice",
    "invoice.payment_action_required": "Handle payment action required",
    "invoiceitem.created": "Sync new invoice item",
    "invoiceitem.deleted": "Remove invoice item",
    "credit_note.created": "Sync new credit note",
    "credit_note.updated": "Update credit note",
    "credit_note.voided": "Handle voided credit note",
    "charge.captured": "Handle captured charge",
    "charge.expired": "Handle expired charge",
    "charge.failed": "Handle failed charge",
    "charge.pending": "Handle pending charge",
    "charge.refunded": "Handle refunded charge",
    "charge.succeeded": "Record successful charge",
    "charge.updated": "Update charge data",
    "refund.created": "Sync new refund",
    "refund.updated": "Update refund data",
    "refund.failed": "Handle failed refund",
    "charge.dispute.created": "Handle new dispute",
    "charge.dispute.updated": "Update dispute data",
    "charge.dispute.closed": "Handle closed dispute",
    "charge.dispute.funds_reinstated": "Handle reinstated dispute funds",
    "charge.dispute.funds_withdrawn": "Handle withdrawn dispute funds",
    "payment_intent.created": "Sync new payment intent",
    "payment_intent.succeeded": "Record successful payment",
    "payment_intent.payment_failed": "Handle payment failure",
    "payment_intent.canceled": "Handle canceled payment intent",
    "payment_intent.processing": "Handle processing payment intent",
    "payment_intent.requires_action": "Handle payment requiring action",
    "payment_intent.amount_capturable_updated": "Handle capturable amount update",
    "payment_intent.partially_funded": "Handle partially funded payment",
    "setup_intent.created": "Sync new setup intent",
    "setup_intent.canceled": "Handle canceled setup intent",
    "setup_intent.requires_action": "Handle setup requiring action",
    "setup_intent.setup_failed": "Handle failed setup intent",
    "setup_intent.succeeded": "Handle successful setup intent",
    "payment_method.attached": "Link payment method to customer",
    "payment_method.detached": "Unlink payment method",
    "payment_method.updated": "Update payment method",
    "payment_method.automatically_updated": "Handle auto-updated payment method",
    "checkout.session.completed": "Handle completed checkout session",
    "checkout.session.async_payment_succeeded": "Handle async checkout payment success",
    "checkout.session.async_payment_failed": "Handle async checkout payment failure",
    "checkout.session.expired": "Handle expired checkout session",
    "balance.available": "Handle balance available event",
    "tax_rate.created": "Sync new tax rate",
    "tax_rate.updated": "Update tax rate",
    "payout.canceled": "Handle canceled payout",
    "payout.created": "Sync new payout",
    "payout.failed": "Handle failed payout",
    "payout.paid": "Handle paid payout",
    "payout.reconciliation_completed": "Handle payout reconciliation",
    "payout.updated": "Update payout data"
  },

  "actions": {
    "sync": "Sync all Stripe data to database",
    "reconcile": "Re-sync recent data to catch gaps from missed webhooks",
    "customers": "Manage customer data",
    "subscriptions": "View and manage subscriptions",
    "invoices": "View invoice history",
    "webhook": "Manage webhook endpoint"
  },

  "envVars": {
    "required": [
      "STRIPE_API_KEY"
    ],
    "optional": [
      "STRIPE_WEBHOOK_SECRET",
      "STRIPE_API_KEYS",
      "STRIPE_ACCOUNT_LABELS",
      "STRIPE_WEBHOOK_SECRETS",
      "STRIPE_ACCOUNT_ID",
      "STRIPE_SYNC_INTERVAL",
      "STRIPE_API_VERSION"
    ]
  },

  "config": {
    "syncInterval": 3600,
    "apiVersion": "2024-12-18.acacia",
    "webhookPath": "/webhooks/stripe",
    "retryAttempts": 3,
    "retryDelay": 1000
  },

  "hooks": {
    "postInstall": "install.sh",
    "preUninstall": "uninstall.sh",
    "postSync": null
  },

  "multiApp": {
    "supported": true,
    "isolationColumn": "source_account_id",
    "pkStrategy": "single",
    "defaultValue": "primary"
  },

  "permissions": {
    "database": ["create", "read", "update", "delete"],
    "network": ["stripe.com"],
    "filesystem": ["logs", "cache"]
  }
}
