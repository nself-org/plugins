# =============================================================================
# ugeocoding Plugin - Environment Configuration
# =============================================================================
# Geocoding and location services plugin - forward/reverse geocoding, place search, geofences
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Auto-provided by nself CLI
# -----------------------------------------------------------------------------

# PostgreSQL connection string (auto-provided by nself)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# -----------------------------------------------------------------------------
# REQUIRED - Security Configuration (auto-provided by nself)
# -----------------------------------------------------------------------------

# API key for inter-plugin authentication
GEOCODING_API_KEY=your-api-key-here

# Rate limiting (requests per window)
GEOCODING_RATE_LIMIT_MAX=100

# Rate limiting window (milliseconds)
GEOCODING_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# OPTIONAL - Server Configuration
# -----------------------------------------------------------------------------

# Server port (default from plugin.json: 3203)
GEOCODING_PORT=3203

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# OPTIONAL - Plugin-Specific Configuration
# -----------------------------------------------------------------------------

# GEOCODING_PROVIDERS
GEOCODING_PROVIDERS=value

# GEOCODING_MAPBOX_ACCESS_TOKEN
GEOCODING_MAPBOX_ACCESS_TOKEN=value

# GEOCODING_NOMINATIM_URL
GEOCODING_NOMINATIM_URL=value

# GEOCODING_NOMINATIM_EMAIL
GEOCODING_NOMINATIM_EMAIL=value

# GEOCODING_CACHE_TTL_DAYS
GEOCODING_CACHE_TTL_DAYS=value

# GEOCODING_CACHE_ENABLED
GEOCODING_CACHE_ENABLED=value

# GEOCODING_MAX_BATCH_SIZE
GEOCODING_MAX_BATCH_SIZE=value

# GEOCODING_GEOFENCE_CHECK_TOLERANCE_METERS
GEOCODING_GEOFENCE_CHECK_TOLERANCE_METERS=value

# GEOCODING_NOTIFY_URL
GEOCODING_NOTIFY_URL=value


# -----------------------------------------------------------------------------
# Additional Configuration
# -----------------------------------------------------------------------------
#
# For complete plugin documentation and configuration options, see:
# - Plugin README: plugins/${PLUGIN_NAME}/README.md
# - Plugin JSON: plugins/${PLUGIN_NAME}/plugin.json
# - nself documentation: https://github.com/acamarata/nself-plugins
#
# Note: All variables marked as REQUIRED are auto-provided by the nself CLI
# during plugin installation and do not need manual configuration.
# -----------------------------------------------------------------------------
