# =============================================================================
# AI Plugin - Environment Configuration
# =============================================================================
# Unified AI gateway with multi-provider LLM support, embeddings, semantic
# search, prompt templates, and usage tracking
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Auto-provided by nself CLI
# -----------------------------------------------------------------------------

# PostgreSQL connection string (auto-provided by nself)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# Alternative: Individual database configuration
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=nself_db
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=password
# POSTGRES_SSL=false

# -----------------------------------------------------------------------------
# REQUIRED - Security Configuration (auto-provided by nself)
# -----------------------------------------------------------------------------

# API key for inter-plugin authentication
AI_API_KEY=your-api-key-here

# Rate limiting (requests per window)
AI_RATE_LIMIT_MAX=100

# Rate limiting window (milliseconds)
AI_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# OPTIONAL - Server Configuration
# -----------------------------------------------------------------------------

# Server port (default from plugin.json: 3101)
AI_PLUGIN_PORT=3101
PORT=3101

# Server host (bind address)
AI_PLUGIN_HOST=0.0.0.0
HOST=0.0.0.0

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# OPTIONAL - Primary LLM Provider Configuration
# -----------------------------------------------------------------------------

# Enable primary LLM provider
AI_PRIMARY_ENABLED=true

# Primary provider API key
AI_PRIMARY_API_KEY=your-primary-provider-api-key-here

# Primary provider organization ID (if applicable)
AI_PRIMARY_ORG_ID=your-org-id

# Default primary provider model
AI_PRIMARY_DEFAULT_MODEL=primary-model-name

# -----------------------------------------------------------------------------
# OPTIONAL - Alternative LLM Provider Configuration
# -----------------------------------------------------------------------------

# Enable alternative LLM provider
AI_ALTERNATIVE_ENABLED=false

# Alternative LLM API key
AI_ALTERNATIVE_API_KEY=your-alternative-llm-api-key-here

# Default alternative LLM model
AI_ALTERNATIVE_DEFAULT_MODEL=alternative-model-name

# -----------------------------------------------------------------------------
# OPTIONAL - Secondary LLM Provider Configuration
# -----------------------------------------------------------------------------

# Enable secondary LLM provider
AI_SECONDARY_ENABLED=false

# Secondary provider API key
AI_SECONDARY_API_KEY=your-secondary-provider-api-key-here

# Default secondary provider model
AI_SECONDARY_DEFAULT_MODEL=secondary-model-name

# -----------------------------------------------------------------------------
# OPTIONAL - Third-Party Provider Configuration
# -----------------------------------------------------------------------------

# Enable third-party provider
AI_THIRDPARTY_ENABLED=false

# Third-party provider API key
AI_THIRDPARTY_API_KEY=your-thirdparty-api-key-here

# -----------------------------------------------------------------------------
# OPTIONAL - Local LLM Configuration
# -----------------------------------------------------------------------------

# Enable local LLM provider (Ollama, LM Studio, etc.)
AI_LOCAL_ENABLED=false

# Local LLM base URL
AI_LOCAL_BASE_URL=http://localhost:11434

# Default local model name
AI_LOCAL_DEFAULT_MODEL=llama2

# -----------------------------------------------------------------------------
# OPTIONAL - Default Provider Settings
# -----------------------------------------------------------------------------

# Default AI provider: primary, alternative, secondary, thirdparty, local
AI_DEFAULT_PROVIDER=primary

# Default temperature (0.0 - 2.0, lower = more deterministic)
AI_DEFAULT_TEMPERATURE=0.7

# Default max tokens per response
AI_DEFAULT_MAX_TOKENS=1000

# Enable streaming responses
AI_ENABLE_STREAMING=true

# Enable function calling (tools/agents)
AI_ENABLE_FUNCTION_CALLING=true

# -----------------------------------------------------------------------------
# OPTIONAL - Embeddings Configuration
# -----------------------------------------------------------------------------

# Enable embeddings generation
AI_EMBEDDINGS_ENABLED=true

# Embeddings model name
AI_EMBEDDINGS_MODEL=text-embedding-model

# Embedding dimensions
AI_EMBEDDINGS_DIMENSIONS=1536

# -----------------------------------------------------------------------------
# OPTIONAL - Rate Limiting
# -----------------------------------------------------------------------------

# Enable rate limiting per user
AI_RATE_LIMIT_ENABLED=true

# Requests per minute per user
AI_RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Tokens per minute per user
AI_RATE_LIMIT_TOKENS_PER_MINUTE=100000

# -----------------------------------------------------------------------------
# OPTIONAL - Usage Quotas
# -----------------------------------------------------------------------------

# Default daily request quota per user
AI_DEFAULT_DAILY_REQUESTS=1000

# Default daily token quota per user
AI_DEFAULT_DAILY_TOKENS=1000000

# Default daily cost quota per user (USD)
AI_DEFAULT_DAILY_COST=10.00

# -----------------------------------------------------------------------------
# OPTIONAL - Feature Flags
# -----------------------------------------------------------------------------

# Enable chat assistant feature
AI_CHAT_ASSISTANT_ENABLED=true

# Enable summarization feature
AI_SUMMARIZATION_ENABLED=true

# Enable translation feature
AI_TRANSLATION_ENABLED=true

# Enable sentiment analysis feature
AI_SENTIMENT_ANALYSIS_ENABLED=true

# Enable smart search (semantic search via embeddings)
AI_SMART_SEARCH_ENABLED=true

# -----------------------------------------------------------------------------
# OPTIONAL - Caching
# -----------------------------------------------------------------------------

# Enable response caching (cache identical prompts)
AI_CACHE_ENABLED=true

# Cache TTL (seconds)
AI_CACHE_TTL_SECONDS=3600

# -----------------------------------------------------------------------------
# OPTIONAL - Logging and Tracking
# -----------------------------------------------------------------------------

# Log all AI requests
AI_LOG_REQUESTS=true

# Log all AI responses (may contain sensitive data)
AI_LOG_RESPONSES=false

# Track costs per request
AI_TRACK_COSTS=true

# -----------------------------------------------------------------------------
# AI Plugin Architecture
# -----------------------------------------------------------------------------
#
# Multi-Provider Support:
#   - Primary provider (commercial LLM service)
#   - Alternative providers (additional commercial services)
#   - Secondary providers (fallback services)
#   - Third-party providers
#   - Local LLM (Ollama, LM Studio, self-hosted)
#
# Features:
#   - Chat completions with streaming
#   - Text embeddings for semantic search
#   - Function calling (tools/agents)
#   - Prompt templates and variables
#   - Conversation history management
#   - Usage tracking and quotas
#   - Cost estimation and tracking
#
# Embeddings Use Cases:
#   - Semantic search (find similar documents)
#   - Content recommendations
#   - Duplicate detection
#   - Clustering and categorization
#
# Rate Limiting:
#   - Per-user request limits
#   - Per-user token limits
#   - Daily quotas
#   - Cost limits
#
# Cost Management:
#   - Track costs per request
#   - Set daily/monthly budgets
#   - Alert on quota exceeded
#   - Per-user cost tracking
#
# Provider Configuration:
#   Refer to plugin.json envVars section for complete list of
#   supported providers and their configuration variables.
# -----------------------------------------------------------------------------
