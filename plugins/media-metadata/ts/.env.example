# TMDB Configuration
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_API_READ_ACCESS_TOKEN=your_read_token_here_optional

# Server Configuration
TMDB_PLUGIN_PORT=3202
TMDB_PLUGIN_HOST=0.0.0.0

# TMDB Settings
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
TMDB_DEFAULT_LANGUAGE=en-US
TMDB_AUTO_ENRICH=true
TMDB_CONFIDENCE_THRESHOLD=0.70
TMDB_CACHE_TTL_DAYS=30

# Rate Limiting
TMDB_RATE_LIMIT_MAX=100
TMDB_RATE_LIMIT_WINDOW_MS=60000

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nself
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_SSL=false

# Logging
LOG_LEVEL=info

# Security (optional)
TMDB_API_KEY_AUTH=your_api_key_for_authentication
