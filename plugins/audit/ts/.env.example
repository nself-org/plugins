# Audit Plugin Configuration

# Server
AUDIT_PLUGIN_PORT=3303
AUDIT_PLUGIN_HOST=0.0.0.0
AUDIT_LOG_LEVEL=info

# Database (required)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nself
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_SSL=false

# Multi-app support (comma-separated)
AUDIT_APP_IDS=primary

# Fallback logging (if database fails)
AUDIT_FALLBACK_LOG_PATH=/var/log/nself/audit-fallback.jsonl

# SIEM Integration - Splunk HEC
# AUDIT_SIEM_SPLUNK_HEC_URL=https://splunk.example.com:8088/services/collector/event
# AUDIT_SIEM_SPLUNK_HEC_TOKEN=your-hec-token

# SIEM Integration - Elasticsearch/ELK
# AUDIT_SIEM_ELK_URL=https://elasticsearch.example.com:9200
# AUDIT_SIEM_ELK_INDEX=audit-logs
# AUDIT_SIEM_ELK_API_KEY=your-api-key

# SIEM Integration - Datadog
# AUDIT_SIEM_DATADOG_API_KEY=your-datadog-api-key
# AUDIT_SIEM_DATADOG_SITE=datadoghq.com

# Retention (7 years = 2555 days)
AUDIT_DEFAULT_RETENTION_DAYS=2555

# Compliance frameworks (comma-separated)
AUDIT_COMPLIANCE_FRAMEWORKS=SOC2,HIPAA,GDPR,PCI

# Alert webhook URL (global default)
# AUDIT_ALERT_WEBHOOK_URL=https://example.com/webhooks/audit-alerts

# Export limits
AUDIT_EXPORT_MAX_ROWS=100000
