# =============================================================================
# udevices Plugin - Environment Configuration
# =============================================================================
# IoT device enrollment, trust management, and command dispatch service.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Auto-provided by nself CLI
# -----------------------------------------------------------------------------

# PostgreSQL connection string (auto-provided by nself)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# -----------------------------------------------------------------------------
# REQUIRED - Security Configuration (auto-provided by nself)
# -----------------------------------------------------------------------------

# API key for inter-plugin authentication
DEVICES_API_KEY=your-api-key-here

# Rate limiting (requests per window)
DEVICES_RATE_LIMIT_MAX=100

# Rate limiting window (milliseconds)
DEVICES_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# OPTIONAL - Server Configuration
# -----------------------------------------------------------------------------

# Server port (default from plugin.json: 3603)
DEVICES_PORT=3603

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# OPTIONAL - Plugin-Specific Configuration
# -----------------------------------------------------------------------------

# DEV_ENROLLMENT_TOKEN_TTL
DEV_ENROLLMENT_TOKEN_TTL=value

# DEV_CHALLENGE_TTL
DEV_CHALLENGE_TTL=value

# DEV_HEARTBEAT_INTERVAL
DEV_HEARTBEAT_INTERVAL=value

# DEV_HEARTBEAT_TIMEOUT
DEV_HEARTBEAT_TIMEOUT=value

# DEV_COMMAND_DEFAULT_TIMEOUT
DEV_COMMAND_DEFAULT_TIMEOUT=value

# DEV_COMMAND_MAX_RETRIES
DEV_COMMAND_MAX_RETRIES=value

# DEV_TELEMETRY_RETENTION_DAYS
DEV_TELEMETRY_RETENTION_DAYS=value

# DEV_INGEST_HEARTBEAT_INTERVAL
DEV_INGEST_HEARTBEAT_INTERVAL=value

# DEV_INGEST_HEARTBEAT_TIMEOUT
DEV_INGEST_HEARTBEAT_TIMEOUT=value

# DEV_INGEST_RETRY_MAX
DEV_INGEST_RETRY_MAX=value

# DEV_INGEST_RETRY_BACKOFF_BASE
DEV_INGEST_RETRY_BACKOFF_BASE=value

# DEV_REALTIME_URL
DEV_REALTIME_URL=value

# DEV_RECORDING_URL
DEV_RECORDING_URL=value

# DEV_STREAM_GATEWAY_URL
DEV_STREAM_GATEWAY_URL=value

# DEV_APP_TV_HEARTBEAT_INTERVAL
DEV_APP_TV_HEARTBEAT_INTERVAL=value

# DEV_APP_TV_INGEST_HEARTBEAT_INTERVAL
DEV_APP_TV_INGEST_HEARTBEAT_INTERVAL=value

# PORT
PORT=value

# REDIS_URL
REDIS_URL=value


# -----------------------------------------------------------------------------
# Additional Configuration
# -----------------------------------------------------------------------------
#
# For complete plugin documentation and configuration options, see:
# - Plugin README: plugins/${PLUGIN_NAME}/README.md
# - Plugin JSON: plugins/${PLUGIN_NAME}/plugin.json
# - nself documentation: https://github.com/acamarata/nself-plugins
#
# Note: All variables marked as REQUIRED are auto-provided by the nself CLI
# during plugin installation and do not need manual configuration.
# -----------------------------------------------------------------------------
