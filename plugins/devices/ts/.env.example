# =============================================================================
# Devices Plugin Configuration
# =============================================================================
# Copy this file to .env and configure for your environment
# Documentation: See README.md for detailed configuration guide

# -----------------------------------------------------------------------------
# Required Variables (Plugin will not start without these)
# -----------------------------------------------------------------------------

# Database connection string (either DATABASE_URL or individual POSTGRES_* vars)
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# Alternative: Individual PostgreSQL connection parameters
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=nself
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_SSL=false

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# Plugin server port (default: 3603)
DEV_PLUGIN_PORT=3603
# PORT=3603  # Alternative variable name

# Plugin server host (default: 0.0.0.0)
DEV_PLUGIN_HOST=0.0.0.0
# HOST=0.0.0.0  # Alternative variable name

# Logging level (debug|info|warn|error) - default: info
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Device Enrollment Settings
# -----------------------------------------------------------------------------

# Enrollment token TTL in seconds (default: 3600 = 1 hour)
DEV_ENROLLMENT_TOKEN_TTL=3600

# Challenge TTL in seconds (default: 300 = 5 minutes)
# Used during device attestation flow
DEV_CHALLENGE_TTL=300

# -----------------------------------------------------------------------------
# Device Heartbeat Settings
# -----------------------------------------------------------------------------

# Heartbeat interval in seconds (default: 60)
# How often devices must send heartbeat to stay "online"
DEV_HEARTBEAT_INTERVAL=60

# Heartbeat timeout in seconds (default: 180)
# Device is marked offline if no heartbeat received within this time
DEV_HEARTBEAT_TIMEOUT=180

# Heartbeat offline timeout for nTV (default: 90 seconds)
# Shorter timeout for nTV apps
DEV_HEARTBEAT_OFFLINE_TIMEOUT=90

# -----------------------------------------------------------------------------
# Device Command Settings
# -----------------------------------------------------------------------------

# Default command timeout in seconds (default: 300 = 5 minutes)
DEV_COMMAND_DEFAULT_TIMEOUT=300

# Maximum command retry attempts (default: 3)
DEV_COMMAND_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# nTV Bootstrap Settings
# -----------------------------------------------------------------------------

# Bootstrap token TTL in seconds (default: 86400 = 24 hours)
# Used for initial device setup/pairing
DEV_BOOTSTRAP_TOKEN_TTL=86400

# -----------------------------------------------------------------------------
# Ingest Device Settings (for nTV capture devices)
# -----------------------------------------------------------------------------

# Ingest device heartbeat interval in seconds (default: 10)
DEV_INGEST_HEARTBEAT_INTERVAL=10

# Ingest device heartbeat timeout in seconds (default: 30)
DEV_INGEST_HEARTBEAT_TIMEOUT=30

# Maximum retry attempts for ingest operations (default: 5)
DEV_INGEST_RETRY_MAX=5

# Retry backoff base in seconds (default: 5)
# Retry delays: 5s, 10s, 20s, 40s, 80s
DEV_INGEST_RETRY_BACKOFF_BASE=5

# -----------------------------------------------------------------------------
# Telemetry Settings
# -----------------------------------------------------------------------------

# Telemetry data retention in days (default: 30)
DEV_TELEMETRY_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# External Service URLs
# -----------------------------------------------------------------------------

# Realtime Plugin URL for device notifications
DEV_REALTIME_URL=http://localhost:3101

# Recording Plugin URL for ingest device coordination
DEV_RECORDING_URL=http://localhost:3602

# Stream Gateway Plugin URL for stream management
DEV_STREAM_GATEWAY_URL=http://localhost:3601

# Redis connection URL for device state caching
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Per-App Overrides
# -----------------------------------------------------------------------------

# nTV app specific heartbeat interval (default: 30 seconds)
DEV_APP_TV_HEARTBEAT_INTERVAL=30

# nTV app specific ingest heartbeat interval (default: 5 seconds)
DEV_APP_TV_INGEST_HEARTBEAT_INTERVAL=5

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------

# Security prefix for environment variables (default: DEV)
# Used by @nself/plugin-utils loadSecurityConfig
# Security settings: device certificates, attestation, encryption, etc.
# See @nself/plugin-utils documentation for details
