{
  "name": "devices",
  "version": "1.0.0",
  "description": "IoT device enrollment, trust management, and command dispatch service.",
  "author": "nself",
  "license": "Source-Available",
  "homepage": "https://github.com/acamarata/nself-plugins/tree/main/plugins/nself-devices",
  "repository": "https://github.com/acamarata/nself-plugins",
  "minNselfVersion": "0.9.8",
  "category": "streaming",
  "tags": [
    "devices",
    "iot",
    "antbox",
    "enrollment",
    "commands",
    "ingest"
  ],
  "tables": [
    "dev_devices",
    "dev_commands",
    "dev_telemetry",
    "dev_ingest_sessions",
    "dev_audit_log"
  ],
  "views": [
    "dev_devices_by_status",
    "dev_command_success_rate",
    "dev_ingest_uptime",
    "dev_health_trends"
  ],
  "webhooks": {},
  "actions": {
    "init": {
      "description": "Initialize database schema",
      "requiresAuth": true
    },
    "server": {
      "description": "Start API server",
      "requiresAuth": true
    },
    "status": {
      "description": "Show fleet statistics",
      "requiresAuth": true
    },
    "devices list": {
      "description": "List all devices",
      "requiresAuth": true
    },
    "devices enroll": {
      "description": "Start enrollment for device",
      "requiresAuth": true
    },
    "devices revoke": {
      "description": "Revoke device trust",
      "requiresAuth": true
    },
    "devices suspend": {
      "description": "Suspend device",
      "requiresAuth": true
    },
    "commands send": {
      "description": "Send command to device",
      "requiresAuth": true
    },
    "ingest sessions": {
      "description": "List all ingest sessions",
      "requiresAuth": true
    },
    "ingest active": {
      "description": "List active ingest sessions",
      "requiresAuth": true
    },
    "health": {
      "description": "Show device health summary",
      "requiresAuth": true
    },
    "stats": {
      "description": "Show fleet-wide statistics",
      "requiresAuth": true
    }
  },
  "envVars": {
    "required": [
      "DATABASE_URL"
    ],
    "optional": [
      "DEV_ENROLLMENT_TOKEN_TTL",
      "DEV_CHALLENGE_TTL",
      "DEV_HEARTBEAT_INTERVAL",
      "DEV_HEARTBEAT_TIMEOUT",
      "DEV_COMMAND_DEFAULT_TIMEOUT",
      "DEV_COMMAND_MAX_RETRIES",
      "DEV_TELEMETRY_RETENTION_DAYS",
      "DEV_INGEST_HEARTBEAT_INTERVAL",
      "DEV_INGEST_HEARTBEAT_TIMEOUT",
      "DEV_INGEST_RETRY_MAX",
      "DEV_INGEST_RETRY_BACKOFF_BASE",
      "DEV_REALTIME_URL",
      "DEV_RECORDING_URL",
      "DEV_STREAM_GATEWAY_URL",
      "DEV_APP_TV_HEARTBEAT_INTERVAL",
      "DEV_APP_TV_INGEST_HEARTBEAT_INTERVAL",
      "DATABASE_URL",
      "PORT",
      "REDIS_URL"
    ]
  },
  "config": {
    "port": 3603,
    "webhookPath": "/webhooks/nself-devices",
    "retryAttempts": 3,
    "retryDelay": 1000
  },
  "hooks": {
    "postInstall": "install.sh",
    "preUninstall": "uninstall.sh",
    "postSync": null
  },
  "multiApp": {
    "supported": true,
    "isolationColumn": "app_id",
    "pkStrategy": "uuid",
    "defaultValue": "default"
  },
  "permissions": {
    "database": [
      "create",
      "read",
      "update",
      "delete"
    ],
    "network": [
      "*"
    ],
    "filesystem": [
      "logs",
      "cache"
    ]
  }
}
