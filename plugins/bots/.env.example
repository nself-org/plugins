# =============================================================================
# ubots Plugin - Environment Configuration
# =============================================================================
# Bot framework for nself-chat - commands, subscriptions, marketplace, API keys, reviews
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Auto-provided by nself CLI
# -----------------------------------------------------------------------------

# PostgreSQL connection string (auto-provided by nself)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# -----------------------------------------------------------------------------
# REQUIRED - Security Configuration (auto-provided by nself)
# -----------------------------------------------------------------------------

# API key for inter-plugin authentication
BOTS_API_KEY=your-api-key-here

# Rate limiting (requests per window)
BOTS_RATE_LIMIT_MAX=100

# Rate limiting window (milliseconds)
BOTS_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# OPTIONAL - Server Configuration
# -----------------------------------------------------------------------------

# Server port (default from plugin.json: 3103)
BOTS_PORT=3103

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# OPTIONAL - Plugin-Specific Configuration
# -----------------------------------------------------------------------------

# BOT_WEBHOOK_TIMEOUT
BOT_WEBHOOK_TIMEOUT=value

# BOT_WEBHOOK_RETRY_COUNT
BOT_WEBHOOK_RETRY_COUNT=value

# BOT_WEBHOOK_RETRY_DELAY
BOT_WEBHOOK_RETRY_DELAY=value

# BOT_OAUTH_ENABLED
BOT_OAUTH_ENABLED=value

# BOT_OAUTH_CALLBACK_URL
BOT_OAUTH_CALLBACK_URL=value

# BOT_MARKETPLACE_ENABLED
BOT_MARKETPLACE_ENABLED=value

# BOT_MARKETPLACE_MODERATION
BOT_MARKETPLACE_MODERATION=value

# BOT_TOKEN_EXPIRY_DAYS
BOT_TOKEN_EXPIRY_DAYS=value

# BOT_WEBHOOK_SIGNATURE_ALGORITHM
BOT_WEBHOOK_SIGNATURE_ALGORITHM=value

# BOT_MAX_MESSAGE_SIZE
BOT_MAX_MESSAGE_SIZE=value


# -----------------------------------------------------------------------------
# Additional Configuration
# -----------------------------------------------------------------------------
#
# For complete plugin documentation and configuration options, see:
# - Plugin README: plugins/${PLUGIN_NAME}/README.md
# - Plugin JSON: plugins/${PLUGIN_NAME}/plugin.json
# - nself documentation: https://github.com/acamarata/nself-plugins
#
# Note: All variables marked as REQUIRED are auto-provided by the nself CLI
# during plugin installation and do not need manual configuration.
# -----------------------------------------------------------------------------
