{
  "name": "bots",
  "version": "1.0.0",
  "description": "Bot framework for nself-chat - commands, subscriptions, marketplace, API keys, reviews",
  "author": "nself",
  "license": "Source-Available",
  "homepage": "https://github.com/acamarata/nself-plugins/tree/main/plugins/bots",
  "repository": "https://github.com/acamarata/nself-plugins",
  "minNselfVersion": "0.4.8",
  "category": "automation",
  "tags": [
    "bots",
    "commands",
    "slash-commands",
    "marketplace",
    "automation",
    "integrations",
    "webhooks"
  ],
  "tables": [
    "np_bot_bots",
    "np_bot_bot_commands",
    "np_bot_bot_subscriptions",
    "np_bot_bot_installations",
    "np_bot_bot_messages",
    "np_bot_bot_interactions",
    "np_bot_bot_reviews",
    "np_bot_bot_api_keys",
    "np_bot_bots_webhook_events"
  ],
  "webhooks": {
    "bot.created": "New bot created",
    "bot.updated": "Bot configuration updated",
    "bot.deleted": "Bot deleted",
    "bot.installed": "Bot installed in workspace",
    "bot.uninstalled": "Bot uninstalled from workspace",
    "command.registered": "Bot command registered",
    "command.executed": "Bot command executed",
    "interaction.created": "User interacted with bot message",
    "review.submitted": "Bot review submitted"
  },
  "actions": {
    "bots:create": "Create a new bot",
    "bots:list": "List bots",
    "bots:info": "Get bot details",
    "bots:delete": "Delete a bot",
    "bots:commands:register": "Register a command",
    "bots:commands:list": "List bot commands",
    "bots:token:generate": "Generate API token",
    "marketplace:search": "Search bot marketplace",
    "health": "Health check"
  },
  "envVars": {
    "required": [
      "DATABASE_URL"
    ],
    "optional": [
      "BOTS_PLUGIN_PORT",
      "BOT_WEBHOOK_TIMEOUT",
      "BOT_WEBHOOK_RETRY_COUNT",
      "BOT_WEBHOOK_RETRY_DELAY",
      "BOT_DEFAULT_RATE_LIMIT_PER_MINUTE",
      "BOT_DEFAULT_RATE_LIMIT_PER_HOUR",
      "BOT_DEFAULT_RATE_LIMIT_PER_DAY",
      "BOT_OAUTH_ENABLED",
      "BOT_OAUTH_CALLBACK_URL",
      "BOT_MARKETPLACE_ENABLED",
      "BOT_MARKETPLACE_MODERATION",
      "BOT_TOKEN_EXPIRY_DAYS",
      "BOT_WEBHOOK_SIGNATURE_ALGORITHM",
      "BOT_MAX_MESSAGE_SIZE",
      "BOTS_API_KEY",
      "BOTS_RATE_LIMIT_MAX",
      "BOTS_RATE_LIMIT_WINDOW_MS"
    ]
  },
  "config": {
    "defaultPort": 3708,
    "webhookTimeout": 30,
    "webhookRetryCount": 3,
    "defaultRateLimitPerMinute": 60,
    "defaultRateLimitPerHour": 1000,
    "defaultRateLimitPerDay": 10000,
    "tokenExpiryDays": 365,
    "maxMessageSize": 10000
  },
  "hooks": {
    "postInstall": null,
    "preUninstall": null,
    "postSync": null
  },
  "multiApp": {
    "supported": true,
    "isolationColumn": "source_account_id",
    "pkStrategy": "single",
    "defaultValue": "primary"
  },
  "permissions": {
    "database": [
      "create",
      "read",
      "update",
      "delete"
    ],
    "network": [
      "webhooks"
    ],
    "filesystem": [
      "logs"
    ]
  },
  "port": 3103
}
