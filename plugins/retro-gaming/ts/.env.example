# =============================================================================
# Retro Gaming Plugin Configuration
# =============================================================================
# Copy this file to .env and configure for your environment
# Documentation: See README.md for detailed configuration guide

# -----------------------------------------------------------------------------
# Required Variables (Plugin will not start without these)
# -----------------------------------------------------------------------------

# Database connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# Server port (default: 3033)
RETRO_GAMING_PLUGIN_PORT=3033

# Logging level (debug|info|warn|error) - default: info
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Metadata Providers (Optional)
# -----------------------------------------------------------------------------

# IGDB (Internet Game Database) Credentials
# Get credentials from: https://api.igdb.com/
# Requires Twitch Developer Account
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# MobyGames API Key (optional)
# Get your key from: https://www.mobygames.com/info/api/
MOBYGAMES_API_KEY=

# -----------------------------------------------------------------------------
# Storage Configuration
# -----------------------------------------------------------------------------

# ROM file storage path prefix
# This is the base path where ROM files are stored
# Default: /roms
RETRO_GAMING_ROM_PATH_PREFIX=/roms

# Save state storage path prefix
# Where emulator save states are stored
# Default: /save-states
RETRO_GAMING_SAVE_STATE_PATH_PREFIX=/save-states

# Emulator core storage path prefix
# Where libretro cores are stored
# Default: /cores
RETRO_GAMING_CORE_PATH_PREFIX=/cores

# -----------------------------------------------------------------------------
# CDN Configuration (Optional)
# -----------------------------------------------------------------------------

# CDN URL for serving ROM files and cores
# Leave empty to serve files directly from the plugin
# Example: https://cdn.example.com
RETRO_GAMING_CDN_URL=

# Object storage bucket name (if using cloud storage)
# Example: nself-retro-gaming
RETRO_GAMING_STORAGE_BUCKET=

# -----------------------------------------------------------------------------
# Features
# -----------------------------------------------------------------------------
# ROM Library Management:
#   - Import ROMs from filesystem
#   - Metadata enrichment from IGDB/MobyGames
#   - Platform/system detection
#   - Game artwork and screenshots
#   - Multi-region support
#
# Emulator Core Management:
#   - Libretro core database
#   - Core installation tracking
#   - Platform-to-core mappings
#   - Core download URLs
#   - Compatible with RetroArch, EmulatorJS
#
# Save State Synchronization:
#   - Cloud-synced save states
#   - Multiple save slots per ROM
#   - Save state metadata (timestamp, screenshot)
#   - Cross-device save sync
#
# Play Session Tracking:
#   - Track play time per ROM
#   - Session history
#   - Most played games
#   - Last played tracking
#
# Controller Configuration:
#   - Custom controller mappings
#   - Per-platform controller configs
#   - Keyboard remapping
#   - Touchscreen layouts

# -----------------------------------------------------------------------------
# Supported Platforms
# -----------------------------------------------------------------------------
# The plugin supports ROMs from these platforms:
#
# Nintendo: NES, SNES, N64, GameCube, Wii, Game Boy, GBC, GBA, DS, 3DS
# Sega: Master System, Genesis, Sega CD, 32X, Saturn, Dreamcast, Game Gear
# Sony: PlayStation 1, PlayStation 2, PSP
# Atari: 2600, 5200, 7800, Lynx, Jaguar
# Arcade: MAME, Neo Geo, CPS1, CPS2, CPS3
# Other: TurboGrafx-16, Neo Geo Pocket, WonderSwan, Virtual Boy

# -----------------------------------------------------------------------------
# Metadata Providers Information
# -----------------------------------------------------------------------------
# IGDB (Internet Game Database):
#   - Comprehensive game database
#   - Requires free Twitch Developer account
#   - Rate limit: 4 requests/second
#   - Provides: titles, descriptions, artwork, release dates
#   - Website: https://api.igdb.com/
#
# MobyGames:
#   - Extensive retro game database
#   - Free tier: 360 requests/hour
#   - Paid tiers available for higher limits
#   - Provides: detailed game info, screenshots, trivia
#   - Website: https://www.mobygames.com/

# -----------------------------------------------------------------------------
# Libretro Cores
# -----------------------------------------------------------------------------
# Libretro cores are emulator engines that can be used by:
# - RetroArch (desktop, mobile, consoles)
# - EmulatorJS (web-based)
# - Other libretro-compatible frontends
#
# Popular cores:
# - NES: fceumm, nestopia
# - SNES: snes9x, bsnes
# - N64: mupen64plus
# - PlayStation: pcsx_rearmed
# - Game Boy: gambatte, mgba
# - Genesis: genesis_plus_gx, picodrive
#
# Core downloads: https://buildbot.libretro.com/

# -----------------------------------------------------------------------------
# File Organization
# -----------------------------------------------------------------------------
# Recommended directory structure:
#
# /roms/
#   ├── nes/
#   ├── snes/
#   ├── n64/
#   ├── psx/
#   └── ...
#
# /save-states/
#   ├── {rom_id}/
#   │   ├── slot-1.state
#   │   ├── slot-2.state
#   │   └── auto.state
#
# /cores/
#   ├── fceumm_libretro.so
#   ├── snes9x_libretro.so
#   └── ...
