{
  "name": "workflows",
  "version": "1.0.0",
  "description": "Automation engine providing trigger-action workflow chains, conditional logic, scheduled tasks, webhook integrations, and cross-plugin orchestration",
  "author": "nself",
  "license": "Source-Available",
  "homepage": "https://github.com/acamarata/nself-plugins/tree/main/plugins/workflows",
  "repository": "https://github.com/acamarata/nself-plugins",
  "minNselfVersion": "0.4.8",
  "category": "automation",
  "tags": [
    "workflows",
    "automation",
    "triggers",
    "actions",
    "scheduling",
    "webhooks",
    "orchestration"
  ],
  "tables": [
    "np_workflows_workflows",
    "np_workflows_executions",
    "np_workflows_execution_steps",
    "np_workflows_triggers",
    "np_workflows_actions",
    "np_workflows_templates",
    "np_workflows_variables",
    "np_workflows_webhook_logs",
    "np_workflows_approvals"
  ],
  "webhooks": {
    "workflow.created": "A workflow was created",
    "workflow.published": "A workflow was published",
    "workflow.archived": "A workflow was archived",
    "execution.started": "A workflow execution started",
    "execution.completed": "A workflow execution completed successfully",
    "execution.failed": "A workflow execution failed",
    "execution.timeout": "A workflow execution timed out",
    "approval.required": "An approval gate requires attention",
    "approval.responded": "An approval was approved or rejected",
    "trigger.fired": "A trigger was fired"
  },
  "actions": {
    "init": "Initialize workflows system",
    "server": "Start workflows server",
    "status": "View system status",
    "workflows": "Manage workflows",
    "executions": "Manage executions",
    "triggers": "Manage triggers",
    "templates": "Manage templates",
    "variables": "Manage variables"
  },
  "envVars": {
    "required": [
      "DATABASE_URL"
    ],
    "optional": [
      "WORKFLOWS_PLUGIN_PORT",
      "WORKFLOWS_DEFAULT_TIMEOUT",
      "WORKFLOWS_MAX_CONCURRENT",
      "WORKFLOWS_WORKER_POOL_SIZE"
    ]
  },
  "config": {
    "port": 3712,
    "webhookPath": "/webhooks/workflows",
    "defaultTimeoutSeconds": 300,
    "maxConcurrentExecutions": 10,
    "historyRetentionDays": 90,
    "workerPoolSize": 20,
    "scheduleCheckInterval": 60,
    "maxWebhooksPerWorkflow": 5
  },
  "multiApp": {
    "supported": true,
    "isolationColumn": "source_account_id",
    "pkStrategy": "single",
    "defaultValue": "primary"
  },
  "hooks": {
    "postInstall": "install.sh",
    "preUninstall": "uninstall.sh",
    "postSync": null
  },
  "permissions": {
    "database": [
      "create",
      "read",
      "update",
      "delete"
    ],
    "network": [
      "*"
    ],
    "filesystem": [
      "logs",
      "cache"
    ]
  }
}
