# =============================================================================
# Workflows Plugin Configuration
# =============================================================================
# Copy this file to .env and configure for your environment
# Documentation: See README.md for detailed configuration guide

# -----------------------------------------------------------------------------
# Required Variables (Plugin will not start without these)
# -----------------------------------------------------------------------------

# Database connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# Server port (default: 3712)
WORKFLOWS_PLUGIN_PORT=3712

# Logging level (debug|info|warn|error) - default: info
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Execution Settings
# -----------------------------------------------------------------------------

# Default workflow timeout in seconds (default: 300 = 5 minutes)
# Workflows exceeding this time will be marked as timed out
WORKFLOWS_DEFAULT_TIMEOUT=300

# Maximum concurrent workflow executions (default: 10)
# Limits how many workflows can run simultaneously
WORKFLOWS_MAX_CONCURRENT=10

# Worker pool size (default: 20)
# Number of workers available for executing workflow steps
WORKFLOWS_WORKER_POOL_SIZE=20

# -----------------------------------------------------------------------------
# Workflow Configuration Defaults
# -----------------------------------------------------------------------------
# The following settings are configured in plugin.json:
#
# webhookPath: /webhooks/workflows
#   - Endpoint for receiving webhook triggers
#
# defaultTimeoutSeconds: 300
#   - Default timeout for workflow executions
#
# maxConcurrentExecutions: 10
#   - Maximum simultaneous workflow executions
#
# historyRetentionDays: 90
#   - How long to keep execution history
#
# workerPoolSize: 20
#   - Number of worker threads for execution
#
# scheduleCheckInterval: 60
#   - How often to check for scheduled workflows (seconds)
#
# maxWebhooksPerWorkflow: 5
#   - Maximum webhook triggers per workflow

# -----------------------------------------------------------------------------
# Workflow Features
# -----------------------------------------------------------------------------
# Triggers:
#   - Scheduled (cron expressions)
#   - Webhook-based
#   - Manual execution
#   - Event-based (from other plugins)
#
# Actions:
#   - HTTP requests
#   - Database operations
#   - Email notifications
#   - Plugin API calls
#   - Conditional logic
#   - Loops and iterations
#   - Approval gates
#
# Templates:
#   - Pre-built workflow templates
#   - Custom template creation
#   - Import/export workflows
#
# Variables:
#   - Environment variables
#   - Workflow-scoped variables
#   - Step output variables
#   - Template parameters

# -----------------------------------------------------------------------------
# Webhook Events
# -----------------------------------------------------------------------------
# The plugin emits these webhook events:
#
# workflow.created - A workflow was created
# workflow.published - A workflow was published
# workflow.archived - A workflow was archived
# execution.started - A workflow execution started
# execution.completed - A workflow execution completed successfully
# execution.failed - A workflow execution failed
# execution.timeout - A workflow execution timed out
# approval.required - An approval gate requires attention
# approval.responded - An approval was approved or rejected
# trigger.fired - A trigger was fired

# -----------------------------------------------------------------------------
# Example Use Cases
# -----------------------------------------------------------------------------
# 1. Content Automation:
#    - Trigger: New torrent download completed
#    - Actions: Extract metadata, generate thumbnails, publish to library
#
# 2. Sports Recording:
#    - Trigger: Favorite team game detected
#    - Actions: Check recording capacity, schedule recording, notify user
#
# 3. Scheduled Maintenance:
#    - Trigger: Daily at 3 AM
#    - Actions: Database backup, log cleanup, generate reports
#
# 4. Multi-step Approval:
#    - Trigger: User requests content
#    - Actions: Check entitlements, require approval, trigger download
