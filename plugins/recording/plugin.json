{
  "name": "recording",
  "version": "1.0.0",
  "description": "Recording orchestration and archive management service.",
  "author": "nself",
  "license": "Source-Available",
  "homepage": "https://github.com/acamarata/nself-plugins/tree/main/plugins/nself-recording",
  "repository": "https://github.com/acamarata/nself-plugins",
  "minNselfVersion": "0.9.8",
  "category": "streaming",
  "tags": [
    "recording",
    "dvr",
    "archive",
    "encode",
    "schedule"
  ],
  "tables": [
    "rec_recordings",
    "rec_schedules",
    "rec_encode_jobs"
  ],
  "views": [
    "rec_recordings_by_status",
    "rec_storage_by_type",
    "rec_success_rate",
    "rec_scheduled_vs_completed"
  ],
  "webhooks": {
    "sports": "Receive sports event triggers for auto-scheduling recordings",
    "device": "Receive device recording notifications"
  },
  "actions": {
    "init": {
      "description": "Initialize database schema",
      "requiresAuth": true
    },
    "server": {
      "description": "Start API server",
      "requiresAuth": true
    },
    "status": {
      "description": "Show recording service status",
      "requiresAuth": true
    },
    "recordings list": {
      "description": "List all recordings",
      "requiresAuth": true
    },
    "recordings create": {
      "description": "Create/schedule recording",
      "requiresAuth": true
    },
    "recordings cancel": {
      "description": "Cancel scheduled recording",
      "requiresAuth": true
    },
    "recordings delete": {
      "description": "Delete recording and files",
      "requiresAuth": true
    },
    "schedule": {
      "description": "Schedule recording from sports event",
      "requiresAuth": true
    },
    "archives list": {
      "description": "List archived recordings",
      "requiresAuth": true
    },
    "encode-status": {
      "description": "Show encode job queue status",
      "requiresAuth": true
    },
    "publish": {
      "description": "Publish a completed recording",
      "requiresAuth": true
    },
    "stats": {
      "description": "Show recording statistics",
      "requiresAuth": true
    }
  },
  "envVars": {
    "required": [
      "DATABASE_URL"
    ],
    "optional": [
      "REC_STORAGE_URL",
      "REC_FILE_PROCESSING_URL",
      "REC_SPORTS_URL",
      "REC_MEDIA_METADATA_URL",
      "REC_DEVICES_URL",
      "REC_DEFAULT_LEAD_TIME_MINUTES",
      "REC_DEFAULT_TRAIL_TIME_MINUTES",
      "REC_ENCODE_PROFILES",
      "REC_DEFAULT_ENCODE_PROFILE",
      "REC_AUTO_ENCODE",
      "REC_AUTO_ENRICH",
      "REC_AUTO_PUBLISH",
      "REC_MAX_CONCURRENT_RECORDINGS",
      "REC_MAX_CONCURRENT_ENCODES",
      "REC_STORAGE_PATH_TEMPLATE",
      "REC_THUMBNAIL_AT_SECONDS",
      "REC_APP_TV_MAX_CONCURRENT_RECORDINGS",
      "REC_APP_TV_AUTO_PUBLISH",
      "DATABASE_URL",
      "PORT"
    ]
  },
  "config": {
    "port": 3602,
    "webhookPath": "/webhooks/nself-recording",
    "retryAttempts": 3,
    "retryDelay": 1000
  },
  "hooks": {
    "postInstall": "install.sh",
    "preUninstall": "uninstall.sh",
    "postSync": null
  },
  "multiApp": {
    "supported": true,
    "isolationColumn": "app_id",
    "pkStrategy": "uuid",
    "defaultValue": "default"
  },
  "permissions": {
    "database": [
      "create",
      "read",
      "update",
      "delete"
    ],
    "network": [
      "*"
    ],
    "filesystem": [
      "logs",
      "cache"
    ]
  }
}
