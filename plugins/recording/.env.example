# =============================================================================
# urecording Plugin - Environment Configuration
# =============================================================================
# Recording orchestration and archive management service.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Auto-provided by nself CLI
# -----------------------------------------------------------------------------

# PostgreSQL connection string (auto-provided by nself)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# -----------------------------------------------------------------------------
# REQUIRED - Security Configuration (auto-provided by nself)
# -----------------------------------------------------------------------------

# API key for inter-plugin authentication
RECORDING_API_KEY=your-api-key-here

# Rate limiting (requests per window)
RECORDING_RATE_LIMIT_MAX=100

# Rate limiting window (milliseconds)
RECORDING_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# OPTIONAL - Server Configuration
# -----------------------------------------------------------------------------

# Server port (default from plugin.json: 3602)
RECORDING_PORT=3602

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# OPTIONAL - Plugin-Specific Configuration
# -----------------------------------------------------------------------------

# REC_STORAGE_URL
REC_STORAGE_URL=value

# REC_FILE_PROCESSING_URL
REC_FILE_PROCESSING_URL=value

# REC_SPORTS_URL
REC_SPORTS_URL=value

# REC_MEDIA_METADATA_URL
REC_MEDIA_METADATA_URL=value

# REC_DEVICES_URL
REC_DEVICES_URL=value

# REC_DEFAULT_LEAD_TIME_MINUTES
REC_DEFAULT_LEAD_TIME_MINUTES=value

# REC_DEFAULT_TRAIL_TIME_MINUTES
REC_DEFAULT_TRAIL_TIME_MINUTES=value

# REC_ENCODE_PROFILES
REC_ENCODE_PROFILES=value

# REC_DEFAULT_ENCODE_PROFILE
REC_DEFAULT_ENCODE_PROFILE=value

# REC_AUTO_ENCODE
REC_AUTO_ENCODE=value

# REC_AUTO_ENRICH
REC_AUTO_ENRICH=value

# REC_AUTO_PUBLISH
REC_AUTO_PUBLISH=value

# REC_MAX_CONCURRENT_RECORDINGS
REC_MAX_CONCURRENT_RECORDINGS=value

# REC_MAX_CONCURRENT_ENCODES
REC_MAX_CONCURRENT_ENCODES=value

# REC_STORAGE_PATH_TEMPLATE
REC_STORAGE_PATH_TEMPLATE=value

# REC_THUMBNAIL_AT_SECONDS
REC_THUMBNAIL_AT_SECONDS=value

# REC_APP_TV_MAX_CONCURRENT_RECORDINGS
REC_APP_TV_MAX_CONCURRENT_RECORDINGS=value

# REC_APP_TV_AUTO_PUBLISH
REC_APP_TV_AUTO_PUBLISH=value

# PORT
PORT=value


# -----------------------------------------------------------------------------
# Additional Configuration
# -----------------------------------------------------------------------------
#
# For complete plugin documentation and configuration options, see:
# - Plugin README: plugins/${PLUGIN_NAME}/README.md
# - Plugin JSON: plugins/${PLUGIN_NAME}/plugin.json
# - nself documentation: https://github.com/acamarata/nself-plugins
#
# Note: All variables marked as REQUIRED are auto-provided by the nself CLI
# during plugin installation and do not need manual configuration.
# -----------------------------------------------------------------------------
