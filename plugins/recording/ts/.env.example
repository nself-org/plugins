# =============================================================================
# Recording Plugin Configuration
# =============================================================================
# Copy this file to .env and configure for your environment
# Documentation: See README.md for detailed configuration guide

# -----------------------------------------------------------------------------
# Required Variables (Plugin will not start without these)
# -----------------------------------------------------------------------------

# Database connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# Server port (default: 3602)
PORT=3602

# Logging level (debug|info|warn|error) - default: info
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# External Service URLs (Optional)
# -----------------------------------------------------------------------------

# Object Storage Plugin URL (for recording file storage)
REC_STORAGE_URL=http://localhost:3015

# File Processing Plugin URL (for encoding jobs)
REC_FILE_PROCESSING_URL=http://localhost:3018

# Sports Plugin URL (for sports event metadata)
REC_SPORTS_URL=http://localhost:3035

# Media Metadata Plugin URL (for enrichment)
REC_MEDIA_METADATA_URL=http://localhost:3203

# Devices Plugin URL (for recording device coordination)
REC_DEVICES_URL=http://localhost:3603

# -----------------------------------------------------------------------------
# Recording Settings
# -----------------------------------------------------------------------------

# Default lead time before scheduled start (minutes)
# Default: 5 minutes before scheduled start
REC_DEFAULT_LEAD_TIME_MINUTES=5

# Default trail time after scheduled end (minutes)
# Default: 15 minutes after scheduled end (for sports overruns)
REC_DEFAULT_TRAIL_TIME_MINUTES=15

# Maximum concurrent recordings (default: 2)
REC_MAX_CONCURRENT_RECORDINGS=2

# -----------------------------------------------------------------------------
# Encoding Settings
# -----------------------------------------------------------------------------

# Comma-separated list of available encode profiles
# Example: h264-720p,h264-1080p,h265-1080p
REC_ENCODE_PROFILES=h264-720p,h264-1080p

# Default encode profile to use
REC_DEFAULT_ENCODE_PROFILE=h264-720p

# Maximum concurrent encoding jobs (default: 1)
REC_MAX_CONCURRENT_ENCODES=1

# Automatically encode recordings after completion (true|false)
REC_AUTO_ENCODE=true

# -----------------------------------------------------------------------------
# Post-Recording Automation
# -----------------------------------------------------------------------------

# Automatically enrich metadata after recording (true|false)
REC_AUTO_ENRICH=true

# Automatically publish to library after successful encode (true|false)
REC_AUTO_PUBLISH=false

# -----------------------------------------------------------------------------
# Storage Settings
# -----------------------------------------------------------------------------

# Storage path template for recordings
# Supports variables: {year}, {month}, {day}, {title}, {id}
# Default: recordings/{year}/{month}/{id}
REC_STORAGE_PATH_TEMPLATE=recordings/{year}/{month}/{id}

# Thumbnail generation - seek to this many seconds for thumbnail
# Default: 300 seconds (5 minutes)
REC_THUMBNAIL_AT_SECONDS=300

# -----------------------------------------------------------------------------
# Per-App Overrides (nTV)
# -----------------------------------------------------------------------------

# nTV app specific max concurrent recordings
REC_APP_TV_MAX_CONCURRENT_RECORDINGS=4

# nTV app specific auto-publish setting
REC_APP_TV_AUTO_PUBLISH=true

# -----------------------------------------------------------------------------
# Encoding Profiles Reference
# -----------------------------------------------------------------------------
# h264-720p:
#   - Codec: H.264
#   - Resolution: 1280x720
#   - Bitrate: ~3 Mbps
#   - Good for: General streaming, mobile devices
#
# h264-1080p:
#   - Codec: H.264
#   - Resolution: 1920x1080
#   - Bitrate: ~5 Mbps
#   - Good for: HD streaming, smart TVs
#
# h265-1080p:
#   - Codec: H.265 (HEVC)
#   - Resolution: 1920x1080
#   - Bitrate: ~3 Mbps
#   - Good for: Smaller file sizes, modern devices
#   - Note: Older devices may not support H.265
