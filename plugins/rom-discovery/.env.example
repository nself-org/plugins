# =============================================================================
# urom-discovery Plugin - Environment Configuration
# =============================================================================
# ROM metadata database, search, discovery, automated download orchestration, and multi-source scraping for nself-tv
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Auto-provided by nself CLI
# -----------------------------------------------------------------------------

# PostgreSQL connection string (auto-provided by nself)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# -----------------------------------------------------------------------------
# REQUIRED - Security Configuration (auto-provided by nself)
# -----------------------------------------------------------------------------

# API key for inter-plugin authentication
ROM_DISCOVERY_API_KEY=your-api-key-here

# Rate limiting (requests per window)
ROM_DISCOVERY_RATE_LIMIT_MAX=100

# Rate limiting window (milliseconds)
ROM_DISCOVERY_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# OPTIONAL - Server Configuration
# -----------------------------------------------------------------------------

# Server port (default from plugin.json: 3034)
ROM_DISCOVERY_PORT=3034

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# OPTIONAL - Plugin-Specific Configuration
# -----------------------------------------------------------------------------

# ROM_DISCOVERY_ENABLE_SCRAPERS
ROM_DISCOVERY_ENABLE_SCRAPERS=value

# ROM_DISCOVERY_SCRAPER_SCHEDULE
ROM_DISCOVERY_SCRAPER_SCHEDULE=value

# ROM_DISCOVERY_DEFAULT_QUALITY_MIN
ROM_DISCOVERY_DEFAULT_QUALITY_MIN=value

# ROM_DISCOVERY_DEFAULT_POPULARITY_MIN
ROM_DISCOVERY_DEFAULT_POPULARITY_MIN=value

# ROM_DISCOVERY_MAX_CONCURRENT_DOWNLOADS
ROM_DISCOVERY_MAX_CONCURRENT_DOWNLOADS=value

# ROM_DISCOVERY_MAX_DOWNLOAD_SIZE_MB
ROM_DISCOVERY_MAX_DOWNLOAD_SIZE_MB=value

# ROM_DISCOVERY_RETRO_GAMING_URL
ROM_DISCOVERY_RETRO_GAMING_URL=value

# ROM_DISCOVERY_CDN_URL
ROM_DISCOVERY_CDN_URL=value


# -----------------------------------------------------------------------------
# Additional Configuration
# -----------------------------------------------------------------------------
#
# For complete plugin documentation and configuration options, see:
# - Plugin README: plugins/${PLUGIN_NAME}/README.md
# - Plugin JSON: plugins/${PLUGIN_NAME}/plugin.json
# - nself documentation: https://github.com/acamarata/nself-plugins
#
# Note: All variables marked as REQUIRED are auto-provided by the nself CLI
# during plugin installation and do not need manual configuration.
# -----------------------------------------------------------------------------
