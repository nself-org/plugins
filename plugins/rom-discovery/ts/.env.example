# =============================================================================
# ROM Discovery Plugin Configuration
# =============================================================================
# Copy this file to .env and configure for your environment
# Documentation: See README.md for detailed configuration guide

# -----------------------------------------------------------------------------
# Required Variables (Plugin will not start without these)
# -----------------------------------------------------------------------------

# Database connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# Server port (default: 3034)
ROM_DISCOVERY_PLUGIN_PORT=3034

# Logging level (debug|info|warn|error) - default: info
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Scraper Configuration
# -----------------------------------------------------------------------------

# Enable automatic scrapers (true|false, default: false)
# When enabled, runs scheduled scraping jobs to discover ROMs
ROM_DISCOVERY_ENABLE_SCRAPERS=false

# Scraper schedule (cron format, default: 0 3 * * * = 3 AM daily)
# When to run scraping jobs automatically
ROM_DISCOVERY_SCRAPER_SCHEDULE=0 3 * * *

# -----------------------------------------------------------------------------
# Quality & Filtering Settings
# -----------------------------------------------------------------------------

# Minimum quality score (0-100, default: 50)
# Only ROMs with quality >= this score are included in results
ROM_DISCOVERY_DEFAULT_QUALITY_MIN=50

# Minimum popularity score (0-100, default: 0)
# Filter out unpopular/obscure ROMs
ROM_DISCOVERY_DEFAULT_POPULARITY_MIN=0

# -----------------------------------------------------------------------------
# Download Settings
# -----------------------------------------------------------------------------

# Maximum concurrent ROM downloads (default: 3)
ROM_DISCOVERY_MAX_CONCURRENT_DOWNLOADS=3

# Maximum download size in MB (default: 2048 = 2 GB)
# Prevents accidentally downloading massive ROM collections
ROM_DISCOVERY_MAX_DOWNLOAD_SIZE_MB=2048

# -----------------------------------------------------------------------------
# Integration URLs
# -----------------------------------------------------------------------------

# Retro Gaming Plugin URL (for ROM library integration)
# Used to automatically add discovered ROMs to the library
ROM_DISCOVERY_RETRO_GAMING_URL=http://localhost:3033

# CDN URL for ROM file hosting (optional)
# Leave empty to serve files directly
ROM_DISCOVERY_CDN_URL=

# -----------------------------------------------------------------------------
# Features
# -----------------------------------------------------------------------------
# ROM Metadata Database:
#   - Comprehensive database of retro game ROMs
#   - Platform, title, region, language metadata
#   - Quality and popularity scoring
#   - Version tracking (releases, patches, hacks)
#
# Search & Discovery:
#   - Search by title, platform, region
#   - Filter by quality, popularity, size
#   - Browse by platform
#   - "Best version" recommendations
#
# Multi-Source Scraping:
#   - Archive.org ROM collections
#   - No-Intro/Redump verified sets
#   - Homebrew repositories
#   - ROM hack databases
#
# Download Orchestration:
#   - Queue-based download management
#   - Automatic retry on failure
#   - Size limits and validation
#   - Integration with retro-gaming plugin

# -----------------------------------------------------------------------------
# ROM Sources
# -----------------------------------------------------------------------------
# Archive.org Collections:
#   - Internet Archive hosts many legal ROM collections
#   - No-Intro verified ROM sets (cartridge dumps)
#   - Redump verified disc images
#   - Homebrew and public domain games
#
# Quality Scoring:
#   - 90-100: Verified dumps (No-Intro, Redump)
#   - 70-89: Community verified
#   - 50-69: Likely good quality
#   - 0-49: Unknown quality, may have issues
#
# Popularity Scoring:
#   - Based on download counts, ratings, reviews
#   - Helps identify "best" versions
#   - Filters out obscure/low-quality releases

# -----------------------------------------------------------------------------
# Database Tables
# -----------------------------------------------------------------------------
# np_romdisc_metadata:
#   - ROM metadata (title, platform, region, size)
#   - Quality and popularity scores
#   - Download URLs and hashes
#   - Release information
#
# np_romdisc_download_queue:
#   - Pending ROM downloads
#   - Download status and progress
#   - Retry tracking
#
# np_romdisc_scraper_jobs:
#   - Scraping job history
#   - Platform and source tracking
#   - Job status and statistics
#
# np_romdisc_popularity:
#   - Popularity metrics per ROM
#   - Download counts, ratings
#   - Trending data

# -----------------------------------------------------------------------------
# Legal Considerations
# -----------------------------------------------------------------------------
# IMPORTANT: ROM distribution laws vary by country and jurisdiction.
#
# Generally legal:
#   - Homebrew games
#   - Public domain games
#   - Games with explicit permission from copyright holder
#   - ROMs you dump from your own legally purchased games
#
# Check your local laws:
#   - Commercial ROM distribution is illegal in most countries
#   - Personal backups may be legal in some jurisdictions
#   - Always respect copyright and intellectual property
#
# This plugin is designed for:
#   - Legal homebrew distribution
#   - Personal backup management
#   - Archival of public domain titles

# -----------------------------------------------------------------------------
# Supported Platforms
# -----------------------------------------------------------------------------
# The discovery system supports:
#
# Nintendo: NES, SNES, N64, Game Boy, GBC, GBA
# Sega: Master System, Genesis, Game Gear
# Sony: PlayStation 1, PSP
# Atari: 2600, 7800, Lynx
# Arcade: MAME, Neo Geo
# Other: TurboGrafx-16, Neo Geo Pocket, WonderSwan
#
# Each platform has curated metadata and quality ratings

# -----------------------------------------------------------------------------
# Integration with Retro Gaming Plugin
# -----------------------------------------------------------------------------
# When ROM_DISCOVERY_RETRO_GAMING_URL is set:
#   1. User searches for ROM via discovery API
#   2. User selects ROM to download
#   3. Download is queued and started
#   4. On completion, ROM is auto-added to retro-gaming library
#   5. Metadata is enriched via IGDB/MobyGames
#   6. ROM is ready to play
