# =============================================================================
# uobservability Plugin - Environment Configuration
# =============================================================================
# Unified observability platform with Prometheus metrics, structured logging to Loki, and distributed tracing to Tempo
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Auto-provided by nself CLI
# -----------------------------------------------------------------------------

# PostgreSQL connection string (auto-provided by nself)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# -----------------------------------------------------------------------------
# REQUIRED - Security Configuration (auto-provided by nself)
# -----------------------------------------------------------------------------

# API key for inter-plugin authentication
OBSERVABILITY_API_KEY=your-api-key-here

# Rate limiting (requests per window)
OBSERVABILITY_RATE_LIMIT_MAX=100

# Rate limiting window (milliseconds)
OBSERVABILITY_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# OPTIONAL - Server Configuration
# -----------------------------------------------------------------------------

# Server port (default from plugin.json: 3215)
OBSERVABILITY_PORT=3215

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# OPTIONAL - Plugin-Specific Configuration
# -----------------------------------------------------------------------------

# OBSERVABILITY_PLUGIN_HOST
OBSERVABILITY_PLUGIN_HOST=value

# PORT
PORT=value

# HOST
HOST=value

# OBSERVABILITY_PROMETHEUS_ENABLED
OBSERVABILITY_PROMETHEUS_ENABLED=value

# OBSERVABILITY_METRICS_PATH
OBSERVABILITY_METRICS_PATH=value

# OBSERVABILITY_LOKI_ENABLED
OBSERVABILITY_LOKI_ENABLED=value

# OBSERVABILITY_LOKI_URL
OBSERVABILITY_LOKI_URL=value

# OBSERVABILITY_TEMPO_ENABLED
OBSERVABILITY_TEMPO_ENABLED=value

# OBSERVABILITY_TEMPO_URL
OBSERVABILITY_TEMPO_URL=value

# OBSERVABILITY_GRAFANA_URL
OBSERVABILITY_GRAFANA_URL=value


# -----------------------------------------------------------------------------
# Additional Configuration
# -----------------------------------------------------------------------------
#
# For complete plugin documentation and configuration options, see:
# - Plugin README: plugins/${PLUGIN_NAME}/README.md
# - Plugin JSON: plugins/${PLUGIN_NAME}/plugin.json
# - nself documentation: https://github.com/acamarata/nself-plugins
#
# Note: All variables marked as REQUIRED are auto-provided by the nself CLI
# during plugin installation and do not need manual configuration.
# -----------------------------------------------------------------------------
