{
  "name": "@nself/plugin-observability",
  "version": "1.0.0",
  "description": "Observability plugin for nself with Prometheus metrics, Loki logging, and Tempo tracing",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nself-observability": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nself/plugin-utils": "file:../../../shared",
    "fastify": "^4.24.0",
    "@fastify/cors": "^8.4.0",
    "dotenv": "^16.3.1",
    "commander": "^11.1.0",
    "prom-client": "^15.1.0",
    "winston": "^3.11.0",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/sdk-trace-base": "^1.18.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.45.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "tsx": "^4.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
