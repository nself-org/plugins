{
  "name": "observability",
  "version": "1.0.0",
  "description": "Unified observability service with health probes, watchdog timers, service auto-discovery, and systemd integration",
  "author": "nself",
  "license": "Source-Available",
  "homepage": "https://github.com/acamarata/nself-plugins/tree/main/plugins/observability",
  "repository": "https://github.com/acamarata/nself-plugins",
  "minNselfVersion": "0.4.8",
  "port": 3215,
  "category": "monitoring",
  "tags": [
    "observability",
    "health-checks",
    "watchdog",
    "service-discovery",
    "monitoring"
  ],
  "tables": [
    "np_observability_services",
    "np_observability_health_history",
    "np_observability_watchdog_events"
  ],
  "webhooks": {},
  "actions": {
    "services": "List discovered services",
    "health": "Check all services",
    "watchdog": "Watchdog status",
    "events": "Recent events",
    "stats": "Show statistics"
  },
  "envVars": {
    "required": [
      "DATABASE_URL"
    ],
    "optional": [
      "OBSERVABILITY_PLUGIN_PORT",
      "OBSERVABILITY_CHECK_INTERVAL",
      "OBSERVABILITY_DOCKER_SOCKET",
      "OBSERVABILITY_WATCHDOG_ENABLED"
    ]
  },
  "config": {
    "defaultPort": 3215,
    "checkIntervalSeconds": 30,
    "watchdogTimeoutSeconds": 120,
    "healthHistoryRetainDays": 30,
    "dockerSocket": "/var/run/docker.sock"
  },
  "hooks": {
    "postInstall": null,
    "preUninstall": null,
    "postSync": null
  },
  "multiApp": {
    "supported": true,
    "isolationColumn": "source_account_id",
    "pkStrategy": "uuid",
    "defaultValue": "primary"
  },
  "permissions": {
    "database": [
      "create",
      "read",
      "update",
      "delete"
    ],
    "network": [
      "*"
    ],
    "filesystem": [
      "logs",
      "cache",
      "temp"
    ]
  }
}
