{
  "name": "@nself/plugin-photos",
  "version": "1.0.0",
  "description": "Photo album management with EXIF extraction, tagging, face grouping, and thumbnails",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nself-photos": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "dev": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "nself",
    "photos",
    "albums",
    "exif",
    "tagging",
    "faces",
    "thumbnails",
    "gallery"
  ],
  "author": "nself",
  "license": "Source-Available",
  "dependencies": {
    "@nself/plugin-utils": "file:../../../shared",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "fastify": "^4.24.0",
    "@fastify/cors": "^8.4.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  }
}
