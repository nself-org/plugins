# Analytics Plugin Configuration

# Database Connection
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nself
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_SSL=false

# Server Configuration
ANALYTICS_PLUGIN_PORT=3304
ANALYTICS_PLUGIN_HOST=0.0.0.0

# Analytics Settings
ANALYTICS_BATCH_SIZE=100
ANALYTICS_ROLLUP_INTERVAL_MS=3600000
ANALYTICS_EVENT_RETENTION_DAYS=90
ANALYTICS_COUNTER_RETENTION_DAYS=365

# Security (optional)
ANALYTICS_API_KEY=
ANALYTICS_RATE_LIMIT_MAX=500
ANALYTICS_RATE_LIMIT_WINDOW_MS=60000

# Logging
LOG_LEVEL=info
