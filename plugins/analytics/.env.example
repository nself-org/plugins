# =============================================================================
# Analytics Plugin - Environment Configuration
# =============================================================================
# Event tracking, counters, funnels, and quota management analytics engine
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Auto-provided by nself CLI
# -----------------------------------------------------------------------------

# PostgreSQL connection string (auto-provided by nself)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# -----------------------------------------------------------------------------
# REQUIRED - Security Configuration (auto-provided by nself)
# -----------------------------------------------------------------------------

# API key for inter-plugin authentication
ANALYTICS_API_KEY=your-api-key-here

# Rate limiting (requests per window)
ANALYTICS_RATE_LIMIT_MAX=100

# Rate limiting window (milliseconds)
ANALYTICS_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# OPTIONAL - Server Configuration
# -----------------------------------------------------------------------------

# Server port (default from plugin.json: 3206)
ANALYTICS_PLUGIN_PORT=3206

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# OPTIONAL - Event Processing
# -----------------------------------------------------------------------------

# Batch size for event processing
# Events are batched for better performance
ANALYTICS_BATCH_SIZE=100

# Counter rollup interval (milliseconds)
# How often to aggregate counter data (default: 1 hour)
ANALYTICS_ROLLUP_INTERVAL_MS=3600000

# -----------------------------------------------------------------------------
# OPTIONAL - Data Retention
# -----------------------------------------------------------------------------

# Event retention (days)
# Raw events are deleted after this period
ANALYTICS_EVENT_RETENTION_DAYS=90

# Counter retention (days)
# Aggregated counter data is kept longer than raw events
ANALYTICS_COUNTER_RETENTION_DAYS=365

# -----------------------------------------------------------------------------
# Analytics Features
# -----------------------------------------------------------------------------
#
# Event Tracking:
#   - Track any event with custom properties
#   - User events, system events, custom events
#   - Automatic timestamp and user tracking
#   - Batch processing for high throughput
#
# Counters:
#   - Increment/decrement counters
#   - Daily, weekly, monthly rollups
#   - Per-user, per-resource, global counters
#   - Example: page views, downloads, API calls
#
# Funnels:
#   - Multi-step conversion tracking
#   - Drop-off analysis
#   - Time-to-conversion metrics
#   - Example: signup → verify → first-login
#
# Quotas:
#   - Set usage limits per user/resource
#   - Automatic quota checking
#   - Violation tracking and alerts
#   - Reset periods (daily, weekly, monthly)
#
# Use Cases:
#   - User behavior tracking
#   - Feature usage analytics
#   - API rate limiting
#   - Business metrics (DAU, MAU, retention)
#   - Performance monitoring
#
# Example Events:
#   - user.signup
#   - post.created
#   - video.watched
#   - api.request
#   - payment.completed
#
# Example Counters:
#   - page_views (daily, total)
#   - active_users (daily, weekly, monthly)
#   - api_calls (per user, per endpoint)
#   - storage_used (per user)
#
# Example Funnels:
#   - Signup: visit → signup → verify → complete
#   - Purchase: browse → cart → checkout → payment
#   - Onboarding: signup → profile → settings → first-action
# -----------------------------------------------------------------------------
