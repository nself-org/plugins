{
  "name": "data-operations",
  "version": "1.0.0",
  "description": "Comprehensive data operations platform with GDPR-compliant export/deletion, bulk import/export, cross-platform migration, backup/restore, and data portability",
  "author": "nself",
  "license": "Source-Available",
  "homepage": "https://github.com/acamarata/nself-plugins/tree/main/plugins/data-operations",
  "repository": "https://github.com/acamarata/nself-plugins",
  "minNselfVersion": "0.4.8",
  "port": 3306,
  "category": "data",
  "tags": [
    "gdpr",
    "export",
    "import",
    "migration",
    "backup",
    "restore",
    "deletion",
    "compliance",
    "privacy",
    "data-transfer"
  ],
  "tables": [
    "np_dataops_export_requests",
    "np_dataops_import_requests",
    "np_dataops_deletion_requests",
    "np_dataops_migration_jobs",
    "np_dataops_backup_snapshots",
    "np_dataops_restore_jobs",
    "np_dataops_transform_templates",
    "np_dataops_plugin_registry",
    "np_dataops_transfer_audit",
    "np_dataops_backup_schedule",
    "np_dataops_webhook_events"
  ],
  "webhooks": {
    "export.completed": "Data export completed",
    "export.failed": "Data export failed",
    "import.completed": "Data import completed",
    "import.failed": "Data import failed",
    "deletion.completed": "GDPR deletion completed",
    "migration.completed": "Data migration completed",
    "backup.completed": "Backup snapshot created",
    "restore.completed": "Data restore completed"
  },
  "actions": {
    "init": "Initialize data-operations database schema",
    "server": "Start data-operations HTTP server",
    "export": "Create and manage data exports",
    "import": "Create and manage data imports",
    "delete": "Request GDPR data deletion",
    "migrate": "Manage cross-platform migrations",
    "backup": "Manage backup snapshots",
    "restore": "Manage restore jobs",
    "transform": "Manage data transformation templates",
    "plugins": "Manage plugin registry for export/deletion",
    "audit": "View data transfer audit log",
    "status": "View overall statistics and job statuses",
    "stats": "View detailed statistics"
  },
  "envVars": {
    "required": [
      "DATABASE_URL"
    ],
    "optional": [
      "DATAOPS_PLUGIN_PORT",
      "DATAOPS_APP_IDS",
      "DATAOPS_STORAGE_PATH",
      "DATAOPS_TEMP_PATH",
      "DATAOPS_DOWNLOAD_EXPIRY_HOURS",
      "DATAOPS_DELETION_COOLDOWN_HOURS",
      "DATAOPS_MAX_EXPORT_SIZE_MB",
      "DATAOPS_MAX_FILE_SIZE_GB",
      "DATAOPS_VERIFICATION_CODE_LENGTH",
      "DATAOPS_EXPORT_RETENTION_DAYS",
      "DATAOPS_IMPORT_MAX_FILE_SIZE_GB",
      "DATAOPS_BACKUP_STORAGE_BACKEND",
      "DATAOPS_BACKUP_RETENTION_DAYS",
      "DATAOPS_MIGRATION_BATCH_SIZE",
      "DATAOPS_MIGRATION_RATE_LIMIT_MS",
      "DATAOPS_QUEUE_CONCURRENCY",
      "DATAOPS_QUEUE_TIMEOUT_MINUTES",
      "DATAOPS_COMPRESSION_LEVEL",
      "DATAOPS_COMPRESSION_ALGORITHM",
      "DATAOPS_API_KEY",
      "DATAOPS_RATE_LIMIT_MAX",
      "DATAOPS_RATE_LIMIT_WINDOW_MS"
    ]
  },
  "config": {
    "port": 3306,
    "storagePath": "/tmp/nself-data-operations",
    "tempPath": "/tmp/nself-imports",
    "downloadExpiryHours": 24,
    "deletionCooldownHours": 24,
    "maxExportSizeMB": 500,
    "maxFileSizeGB": 10,
    "verificationCodeLength": 6,
    "exportRetentionDays": 30,
    "backupStorageBackend": "local",
    "backupRetentionDays": 90,
    "migrationBatchSize": 100,
    "compressionLevel": 6,
    "compressionAlgorithm": "gzip",
    "queueConcurrency": 5,
    "rateLimitMax": 100,
    "rateLimitWindowMs": 60000
  },
  "hooks": {
    "postInstall": null,
    "preUninstall": null,
    "postSync": null
  },
  "multiApp": {
    "supported": true,
    "isolationColumn": "source_account_id",
    "pkStrategy": "single",
    "defaultValue": "primary"
  },
  "permissions": {
    "database": [
      "create",
      "read",
      "update",
      "delete"
    ],
    "network": [],
    "filesystem": [
      "logs",
      "exports",
      "imports",
      "backups",
      "temp"
    ]
  }
}
