# =============================================================================
# udata-operations Plugin - Environment Configuration
# =============================================================================
# Comprehensive data operations platform with GDPR-compliant export/deletion, bulk import/export, cross-platform migration, backup/restore, and data portability
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Auto-provided by nself CLI
# -----------------------------------------------------------------------------

# PostgreSQL connection string (auto-provided by nself)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# -----------------------------------------------------------------------------
# REQUIRED - Security Configuration (auto-provided by nself)
# -----------------------------------------------------------------------------

# API key for inter-plugin authentication
DATA_OPERATIONS_API_KEY=your-api-key-here

# Rate limiting (requests per window)
DATA_OPERATIONS_RATE_LIMIT_MAX=100

# Rate limiting window (milliseconds)
DATA_OPERATIONS_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# OPTIONAL - Server Configuration
# -----------------------------------------------------------------------------

# Server port (default from plugin.json: 3306)
DATA_OPERATIONS_PORT=3306

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# OPTIONAL - Plugin-Specific Configuration
# -----------------------------------------------------------------------------

# DATAOPS_APP_IDS
DATAOPS_APP_IDS=value

# DATAOPS_STORAGE_PATH
DATAOPS_STORAGE_PATH=value

# DATAOPS_TEMP_PATH
DATAOPS_TEMP_PATH=value

# DATAOPS_DOWNLOAD_EXPIRY_HOURS
DATAOPS_DOWNLOAD_EXPIRY_HOURS=value

# DATAOPS_DELETION_COOLDOWN_HOURS
DATAOPS_DELETION_COOLDOWN_HOURS=value

# DATAOPS_MAX_EXPORT_SIZE_MB
DATAOPS_MAX_EXPORT_SIZE_MB=value

# DATAOPS_MAX_FILE_SIZE_GB
DATAOPS_MAX_FILE_SIZE_GB=value

# DATAOPS_VERIFICATION_CODE_LENGTH
DATAOPS_VERIFICATION_CODE_LENGTH=value

# DATAOPS_EXPORT_RETENTION_DAYS
DATAOPS_EXPORT_RETENTION_DAYS=value

# DATAOPS_IMPORT_MAX_FILE_SIZE_GB
DATAOPS_IMPORT_MAX_FILE_SIZE_GB=value

# DATAOPS_BACKUP_STORAGE_BACKEND
DATAOPS_BACKUP_STORAGE_BACKEND=value

# DATAOPS_BACKUP_RETENTION_DAYS
DATAOPS_BACKUP_RETENTION_DAYS=value

# DATAOPS_MIGRATION_BATCH_SIZE
DATAOPS_MIGRATION_BATCH_SIZE=value

# DATAOPS_QUEUE_CONCURRENCY
DATAOPS_QUEUE_CONCURRENCY=value

# DATAOPS_QUEUE_TIMEOUT_MINUTES
DATAOPS_QUEUE_TIMEOUT_MINUTES=value

# DATAOPS_COMPRESSION_LEVEL
DATAOPS_COMPRESSION_LEVEL=value

# DATAOPS_COMPRESSION_ALGORITHM
DATAOPS_COMPRESSION_ALGORITHM=value


# -----------------------------------------------------------------------------
# Additional Configuration
# -----------------------------------------------------------------------------
#
# For complete plugin documentation and configuration options, see:
# - Plugin README: plugins/${PLUGIN_NAME}/README.md
# - Plugin JSON: plugins/${PLUGIN_NAME}/plugin.json
# - nself documentation: https://github.com/acamarata/nself-plugins
#
# Note: All variables marked as REQUIRED are auto-provided by the nself CLI
# during plugin installation and do not need manual configuration.
# -----------------------------------------------------------------------------
