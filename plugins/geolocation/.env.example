# =============================================================================
# ugeolocation Plugin - Environment Configuration
# =============================================================================
# Real-time location sharing, history tracking, geofencing, and proximity queries
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Auto-provided by nself CLI
# -----------------------------------------------------------------------------

# PostgreSQL connection string (auto-provided by nself)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# -----------------------------------------------------------------------------
# REQUIRED - Security Configuration (auto-provided by nself)
# -----------------------------------------------------------------------------

# API key for inter-plugin authentication
GEOLOCATION_API_KEY=your-api-key-here

# Rate limiting (requests per window)
GEOLOCATION_RATE_LIMIT_MAX=100

# Rate limiting window (milliseconds)
GEOLOCATION_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# OPTIONAL - Server Configuration
# -----------------------------------------------------------------------------

# Server port (default from plugin.json: 3026)
GEOLOCATION_PORT=3026

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# OPTIONAL - Plugin-Specific Configuration
# -----------------------------------------------------------------------------

# GEO_PLUGIN_HOST
GEO_PLUGIN_HOST=value

# GEO_LOG_LEVEL
GEO_LOG_LEVEL=value

# GEO_APP_IDS
GEO_APP_IDS=value

# GEO_POSTGIS_ENABLED
GEO_POSTGIS_ENABLED=value

# GEO_HISTORY_RETENTION_DAYS
GEO_HISTORY_RETENTION_DAYS=value

# GEO_BATCH_MAX_POINTS
GEO_BATCH_MAX_POINTS=value

# GEO_MIN_UPDATE_INTERVAL_SECONDS
GEO_MIN_UPDATE_INTERVAL_SECONDS=value

# GEO_GEOFENCE_CHECK_ON_UPDATE
GEO_GEOFENCE_CHECK_ON_UPDATE=value

# GEO_REVERSE_GEOCODE_ENABLED
GEO_REVERSE_GEOCODE_ENABLED=value

# GEO_REVERSE_GEOCODE_PROVIDER
GEO_REVERSE_GEOCODE_PROVIDER=value

# GEO_LOW_BATTERY_THRESHOLD
GEO_LOW_BATTERY_THRESHOLD=value


# -----------------------------------------------------------------------------
# Additional Configuration
# -----------------------------------------------------------------------------
#
# For complete plugin documentation and configuration options, see:
# - Plugin README: plugins/${PLUGIN_NAME}/README.md
# - Plugin JSON: plugins/${PLUGIN_NAME}/plugin.json
# - nself documentation: https://github.com/acamarata/nself-plugins
#
# Note: All variables marked as REQUIRED are auto-provided by the nself CLI
# during plugin installation and do not need manual configuration.
# -----------------------------------------------------------------------------
