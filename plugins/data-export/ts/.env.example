# Database Configuration (Required)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nself
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_SSL=false

# Server Configuration
EXPORT_PLUGIN_PORT=3306
EXPORT_PLUGIN_HOST=0.0.0.0

# Storage Configuration
EXPORT_STORAGE_PATH=/tmp/nself-exports
EXPORT_DOWNLOAD_EXPIRY_HOURS=24
EXPORT_MAX_EXPORT_SIZE_MB=500

# Deletion Configuration
EXPORT_DELETION_COOLDOWN_HOURS=24
EXPORT_VERIFICATION_CODE_LENGTH=6

# Security Configuration
EXPORT_API_KEY=your_api_key_here
EXPORT_RATE_LIMIT_MAX=50
EXPORT_RATE_LIMIT_WINDOW_MS=60000

# Logging
LOG_LEVEL=info
