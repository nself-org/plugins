{
  "name": "@nself/plugin-metadata-enrichment",
  "version": "1.0.0",
  "description": "Metadata enrichment with TMDB, TVDB, and MusicBrainz integration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "cli": "node dist/cli.js"
  },
  "keywords": ["metadata", "tmdb", "tvdb", "musicbrainz", "enrichment"],
  "author": "nself",
  "license": "MIT",
  "dependencies": {
    "@nself/plugin-utils": "workspace:*",
    "fastify": "^4.26.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^9.0.1",
    "moviedb-promise": "^3.2.0",
    "axios": "^1.6.7",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "dotenv": "^16.4.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.16",
    "@types/pg": "^8.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
