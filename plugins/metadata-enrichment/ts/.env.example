# =============================================================================
# Metadata Enrichment Configuration
# =============================================================================
# Copy this file to .env and configure for your environment
# Documentation: See README.md for detailed configuration guide

# -----------------------------------------------------------------------------
# Required Variables (Plugin will not start without these)
# -----------------------------------------------------------------------------

# Database connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# TMDB API Key (required for movie and TV metadata)
# Get your key from: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# Server port (default: 3203)
METADATA_ENRICHMENT_PORT=3203

# Logging level (debug|info|warn|error) - default: info
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Optional Metadata Providers
# -----------------------------------------------------------------------------

# TVDB API Key (optional - for supplementary TV metadata)
# Get your key from: https://thetvdb.com/api-information
TVDB_API_KEY=

# MusicBrainz User Agent (optional - for music metadata)
# Format: YourAppName/Version (contact@yourdomain.com)
# Default: nself-tv/1.0.0
MUSICBRAINZ_USER_AGENT=nself-tv/1.0.0

# -----------------------------------------------------------------------------
# API Information
# -----------------------------------------------------------------------------
# TMDB: https://www.themoviedb.org/
#   - Free API key available
#   - Rate limit: 40 requests per 10 seconds
#   - Provides movie and TV show metadata, images, cast, crew
#
# TVDB: https://thetvdb.com/
#   - Free API key available
#   - Supplementary TV show data
#   - Good for episode guides and airdates
#
# MusicBrainz: https://musicbrainz.org/
#   - No API key required
#   - Rate limit: 1 request per second
#   - Music metadata and album information
