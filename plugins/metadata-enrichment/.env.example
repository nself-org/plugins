# =============================================================================
# Metadata Enrichment Plugin - Environment Configuration
# =============================================================================
# Multi-source metadata aggregation for movies, TV shows, and music with
# automatic poster/backdrop downloads and object storage integration
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Auto-provided by nself CLI
# -----------------------------------------------------------------------------

# PostgreSQL connection string (auto-provided by nself)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# -----------------------------------------------------------------------------
# REQUIRED - External API Keys
# -----------------------------------------------------------------------------

# TMDB (The Movie Database) API Key
# Get your API key at: https://www.themoviedb.org/settings/api
# Used for movies and TV shows metadata
TMDB_API_KEY=your-tmdb-api-key-here

# -----------------------------------------------------------------------------
# REQUIRED - Security Configuration (auto-provided by nself)
# -----------------------------------------------------------------------------

# API key for inter-plugin authentication
METADATA_ENRICHMENT_API_KEY=your-api-key-here

# Rate limiting (requests per window)
METADATA_ENRICHMENT_RATE_LIMIT_MAX=100

# Rate limiting window (milliseconds)
METADATA_ENRICHMENT_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# OPTIONAL - Server Configuration
# -----------------------------------------------------------------------------

# Server port (default from plugin.json: 3203)
METADATA_ENRICHMENT_PORT=3203

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# OPTIONAL - Additional API Keys
# -----------------------------------------------------------------------------

# TVDB (TheTVDB) API Key
# Get your API key at: https://thetvdb.com/api-information
# Used as fallback/supplement for TV show metadata
TVDB_API_KEY=your-tvdb-api-key

# -----------------------------------------------------------------------------
# OPTIONAL - MusicBrainz Configuration
# -----------------------------------------------------------------------------

# MusicBrainz User Agent (for music metadata)
# Format: AppName/Version (Contact)
# Example: nself-tv/1.0.0 (admin@example.com)
MUSICBRAINZ_USER_AGENT=nself-tv/1.0.0

# -----------------------------------------------------------------------------
# OPTIONAL - Object Storage Integration
# -----------------------------------------------------------------------------

# Object Storage Plugin URL
# Used for uploading posters, backdrops, and other media assets
# Leave empty to store files locally
OBJECT_STORAGE_URL=http://localhost:3301

# -----------------------------------------------------------------------------
# Metadata Source Notes
# -----------------------------------------------------------------------------
#
# TMDB (The Movie Database):
#   - Primary source for movies and TV shows
#   - Comprehensive metadata (cast, crew, ratings, etc.)
#   - High-quality posters and backdrops
#   - Multiple languages supported
#   - Free tier: 40 requests/10 seconds
#
# TVDB (TheTVDB):
#   - TV show specialist
#   - Episode-level metadata
#   - Air dates and episode names
#   - Multiple language support
#   - Used as supplement to TMDB
#
# MusicBrainz:
#   - Music metadata (albums, artists, tracks)
#   - Community-maintained
#   - No API key required
#   - Rate limit: 1 request/second (respect User-Agent)
#
# Image Handling:
#   - Posters and backdrops automatically downloaded
#   - Multiple sizes available (original, large, medium, small)
#   - Uploaded to Object Storage if configured
#   - Cached locally to reduce API calls
#
# Multi-Language Support:
#   - Metadata available in 50+ languages
#   - Automatic fallback to English
#   - User preference support via API
#
# Integration Flow:
#   1. Content Acquisition requests metadata
#   2. Search TMDB for movies/TV
#   3. Supplement with TVDB if needed
#   4. Download posters/backdrops
#   5. Upload to Object Storage
#   6. Return enriched metadata to caller
# -----------------------------------------------------------------------------
