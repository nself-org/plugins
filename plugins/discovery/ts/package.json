{
  "name": "@nself/plugin-discovery",
  "version": "1.0.0",
  "description": "Content discovery feeds - trending, popular, recent, continue watching",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "cli": "node dist/cli.js"
  },
  "keywords": [
    "discovery",
    "trending",
    "popular",
    "continue-watching",
    "recommendations",
    "feeds",
    "media",
    "cache",
    "redis"
  ],
  "author": "nself",
  "license": "MIT",
  "dependencies": {
    "@nself/plugin-utils": "file:../../../shared",
    "fastify": "^4.26.0",
    "@fastify/cors": "^9.0.1",
    "commander": "^12.0.0",
    "pg": "^8.11.3",
    "ioredis": "^5.3.2",
    "dotenv": "^16.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.16",
    "@types/pg": "^8.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
