{
  "name": "@nself/plugin-recommendation-engine",
  "version": "1.0.0",
  "description": "Hybrid recommendation engine for nself",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nself-recommendation-engine": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "nself",
    "recommendations",
    "collaborative-filtering",
    "content-based",
    "tfidf",
    "machine-learning",
    "personalization"
  ],
  "author": "nself",
  "license": "Source-Available",
  "dependencies": {
    "@nself/plugin-utils": "file:../../../shared",
    "@fastify/cors": "^8.4.0",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "fastify": "^4.24.0",
    "ioredis": "^5.3.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
