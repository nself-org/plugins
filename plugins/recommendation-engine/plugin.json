{
  "name": "recommendation-engine",
  "version": "1.0.0",
  "description": "Hybrid collaborative and content-based filtering recommendation engine with TF-IDF, cosine similarity, cold-start handling, and Redis caching",
  "author": "nself",
  "license": "Source-Available",
  "homepage": "https://github.com/acamarata/nself-plugins/tree/main/plugins/recommendation-engine",
  "repository": "https://github.com/acamarata/nself-plugins",
  "minNselfVersion": "0.4.8",
  "port": 5004,
  "category": "media",
  "tags": [
    "recommendations",
    "collaborative-filtering",
    "content-based",
    "tfidf",
    "machine-learning",
    "personalization",
    "media"
  ],
  "tables": [
    "np_recom_user_profiles",
    "np_recom_item_profiles",
    "np_recom_cached_recommendations",
    "np_recom_similar_items",
    "np_recom_model_state"
  ],
  "webhooks": {
    "model.rebuilt": "Recommendation model was rebuilt",
    "model.rebuild_failed": "Recommendation model rebuild failed",
    "cache.invalidated": "Recommendation cache was invalidated"
  },
  "actions": {
    "init": "Initialize recommendation engine schema",
    "server": "Start recommendation engine server",
    "status": "View model and system status",
    "rebuild": "Trigger model rebuild",
    "recommendations": "Get recommendations for a user"
  },
  "envVars": {
    "required": [
      "DATABASE_URL"
    ],
    "optional": [
      "RECOMMENDATION_PORT",
      "REDIS_URL",
      "COLLABORATIVE_WEIGHT",
      "CONTENT_WEIGHT",
      "CACHE_TTL_SECONDS",
      "REBUILD_INTERVAL_HOURS",
      "MIN_INTERACTIONS_FOR_COLLABORATIVE"
    ]
  },
  "config": {
    "webhookPath": "/webhooks/recommendation-engine",
    "collaborativeWeight": 0.6,
    "contentWeight": 0.4,
    "cacheTtlSeconds": 3600,
    "rebuildIntervalHours": 24,
    "minInteractionsForCollaborative": 5
  },
  "multiApp": {
    "supported": true,
    "isolationColumn": "source_account_id",
    "pkStrategy": "uuid",
    "defaultValue": "primary"
  },
  "hooks": {
    "postInstall": "install.sh",
    "preUninstall": "uninstall.sh",
    "postSync": null
  },
  "permissions": {
    "database": [
      "create",
      "read",
      "update",
      "delete"
    ],
    "network": [
      "localhost"
    ],
    "filesystem": [
      "logs",
      "cache"
    ]
  }
}
