{
  "name": "@nself/plugin-tmdb",
  "version": "1.0.0",
  "description": "Media metadata enrichment from TMDB/IMDb with auto-matching and manual review queue",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nself-tmdb": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "dev": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": ["nself", "tmdb", "metadata", "movies", "tv-shows", "imdb", "matching"],
  "author": "nself",
  "license": "Source-Available",
  "dependencies": {
    "@nself/plugin-utils": "file:../../../shared",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "fastify": "^4.24.0",
    "@fastify/cors": "^8.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  }
}
