{
  "name": "tmdb",
  "version": "1.0.0",
  "description": "Comprehensive media metadata enrichment from TMDB/IMDb/TVDB/MusicBrainz with auto-matching, manual review queue, and multi-provider support",
  "author": "nself",
  "license": "Source-Available",
  "minNselfVersion": "0.4.8",
  "category": "media",
  "tags": [
    "tmdb",
    "metadata",
    "movies",
    "tv-shows",
    "imdb",
    "tvdb",
    "musicbrainz",
    "media",
    "matching",
    "enrichment"
  ],
  "tables": [
    "np_tmdb_movies",
    "np_tmdb_tv_shows",
    "np_tmdb_tv_seasons",
    "np_tmdb_tv_episodes",
    "np_tmdb_genres",
    "np_tmdb_match_queue",
    "np_tmdb_webhook_events"
  ],
  "webhooks": {},
  "actions": {
    "search": "Search TMDB for movies/TV shows",
    "match": "Match a media file to TMDB",
    "match-batch": "Batch match media files",
    "queue": "View match review queue",
    "confirm": "Confirm a match",
    "refresh": "Refresh cached metadata",
    "sync": "Sync genres and configuration",
    "status": "Show sync status"
  },
  "envVars": {
    "required": [
      "DATABASE_URL",
      "TMDB_API_KEY"
    ],
    "optional": [
      "TMDB_PLUGIN_PORT",
      "TMDB_APP_IDS",
      "TMDB_API_READ_ACCESS_TOKEN",
      "OMDB_API_KEY",
      "TVDB_API_KEY",
      "MUSICBRAINZ_USER_AGENT",
      "TMDB_AUTO_ACCEPT_THRESHOLD",
      "TMDB_DEFAULT_LANGUAGE",
      "TMDB_CACHE_TTL_DAYS",
      "TMDB_REFRESH_CRON"
    ]
  },
  "multiApp": {
    "supported": true,
    "isolationColumn": "source_account_id",
    "pkStrategy": "single",
    "defaultValue": "primary"
  },
  "config": {
    "autoAcceptThreshold": 0.85,
    "defaultLanguage": "en-US",
    "cacheTtlDays": 30,
    "refreshCron": "0 6 * * 0",
    "posterSize": "w500",
    "backdropSize": "w1280"
  },
  "permissions": {
    "database": [
      "create",
      "read",
      "update",
      "delete"
    ],
    "network": [
      "api.themoviedb.org",
      "www.omdbapi.com",
      "api.thetvdb.com",
      "musicbrainz.org"
    ],
    "filesystem": [
      "logs",
      "cache"
    ]
  },
  "homepage": "https://github.com/acamarata/nself-plugins/tree/main/plugins/tmdb",
  "repository": "https://github.com/acamarata/nself-plugins",
  "port": 3032
}
