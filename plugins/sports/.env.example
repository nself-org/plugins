# =============================================================================
# usports Plugin - Environment Configuration
# =============================================================================
# Comprehensive sports data plugin with live scores, schedules, standings, team rosters, player stats, and real-time game updates
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Auto-provided by nself CLI
# -----------------------------------------------------------------------------

# PostgreSQL connection string (auto-provided by nself)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# -----------------------------------------------------------------------------
# REQUIRED - Security Configuration (auto-provided by nself)
# -----------------------------------------------------------------------------

# API key for inter-plugin authentication
SPORTS_API_KEY=your-api-key-here

# Rate limiting (requests per window)
SPORTS_RATE_LIMIT_MAX=100

# Rate limiting window (milliseconds)
SPORTS_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# OPTIONAL - Server Configuration
# -----------------------------------------------------------------------------

# Server port (default from plugin.json: 3035)
SPORTS_PORT=3035

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# OPTIONAL - Plugin-Specific Configuration
# -----------------------------------------------------------------------------

# SPORTS_APP_IDS
SPORTS_APP_IDS=value

# SPORTS_PROVIDER
SPORTS_PROVIDER=value

# SPORTS_PROVIDERS
SPORTS_PROVIDERS=value

# SPORTS_ESPN_API_URL
SPORTS_ESPN_API_URL=value

# SPORTS_SPORTSDATA_API_URL
SPORTS_SPORTSDATA_API_URL=value

# SPORTS_LEAGUE_IDS
SPORTS_LEAGUE_IDS=value

# SPORTS_SYNC_INTERVAL
SPORTS_SYNC_INTERVAL=value

# SPORTS_LIVE_POLL_INTERVAL
SPORTS_LIVE_POLL_INTERVAL=value

# SPORTS_LIVE_GAME_POLL_SECONDS
SPORTS_LIVE_GAME_POLL_SECONDS=value

# SPORTS_ENABLED_SPORTS
SPORTS_ENABLED_SPORTS=value

# SPORTS_ENABLED_LEAGUES
SPORTS_ENABLED_LEAGUES=value

# SPORTS_LOCK_WINDOW_MINUTES
SPORTS_LOCK_WINDOW_MINUTES=value

# SPORTS_LOCK_AUTO
SPORTS_LOCK_AUTO=value

# SPORTS_RECORDING_PLUGIN_URL
SPORTS_RECORDING_PLUGIN_URL=value

# SPORTS_AUTO_TRIGGER_RECORDINGS
SPORTS_AUTO_TRIGGER_RECORDINGS=value

# SPORTS_RECORDING_LEAD_TIME_MINUTES
SPORTS_RECORDING_LEAD_TIME_MINUTES=value

# SPORTS_RECORDING_TRAIL_TIME_MINUTES
SPORTS_RECORDING_TRAIL_TIME_MINUTES=value

# SPORTS_CACHE_SCHEDULE_TTL
SPORTS_CACHE_SCHEDULE_TTL=value

# SPORTS_CACHE_LIVE_TTL
SPORTS_CACHE_LIVE_TTL=value

# SPORTS_CACHE_ENABLED
SPORTS_CACHE_ENABLED=value


# -----------------------------------------------------------------------------
# Additional Configuration
# -----------------------------------------------------------------------------
#
# For complete plugin documentation and configuration options, see:
# - Plugin README: plugins/${PLUGIN_NAME}/README.md
# - Plugin JSON: plugins/${PLUGIN_NAME}/plugin.json
# - nself documentation: https://github.com/acamarata/nself-plugins
#
# Note: All variables marked as REQUIRED are auto-provided by the nself CLI
# during plugin installation and do not need manual configuration.
# -----------------------------------------------------------------------------
