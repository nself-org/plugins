{
  "name": "sports",
  "version": "1.0.0",
  "description": "Sports schedule and metadata synchronization plugin - ingests game schedules, team rosters, scores, and standings",
  "author": "nself",
  "license": "Source-Available",
  "homepage": "https://github.com/acamarata/nself-plugins/tree/main/plugins/sports",
  "repository": "https://github.com/acamarata/nself-plugins",
  "minNselfVersion": "0.4.8",
  "category": "external-data",
  "tags": ["sports", "nfl", "schedules", "scores", "live-data", "espn"],

  "tables": [
    "sports_leagues",
    "sports_teams",
    "sports_events",
    "sports_provider_syncs",
    "sports_schedule_cache",
    "sports_webhook_events"
  ],

  "views": [
    "sports_upcoming_events",
    "sports_live_events",
    "sports_untriggered_recordings"
  ],

  "webhooks": {
    "game.score_updated": "Live score update during game",
    "game.started": "Game has started"
  },

  "actions": {
    "init": "Initialize database schema",
    "server": "Start the API server",
    "sync": "Sync from all providers or specific provider/sport/league",
    "reconcile": "Reconcile recent data",
    "status": "Show sync statistics",
    "leagues": "List all leagues",
    "teams": "List teams in a league",
    "events": "Show events (today, live, upcoming)",
    "lock": "Lock an event",
    "override": "Manual schedule override",
    "cache": "Manage schedule cache"
  },

  "envVars": {
    "required": [
      "DATABASE_URL"
    ],
    "optional": [
      "SPORTS_PLUGIN_PORT",
      "SPORTS_PROVIDERS",
      "SPORTS_ESPN_API_URL",
      "SPORTS_SPORTSDATA_API_KEY",
      "SPORTS_SPORTSDATA_API_URL",
      "SPORTS_SYNC_INTERVAL",
      "SPORTS_LIVE_POLL_INTERVAL",
      "SPORTS_ENABLED_SPORTS",
      "SPORTS_ENABLED_LEAGUES",
      "SPORTS_LOCK_WINDOW_MINUTES",
      "SPORTS_LOCK_AUTO",
      "SPORTS_RECORDING_PLUGIN_URL",
      "SPORTS_AUTO_TRIGGER_RECORDINGS",
      "SPORTS_RECORDING_LEAD_TIME_MINUTES",
      "SPORTS_RECORDING_TRAIL_TIME_MINUTES",
      "SPORTS_CACHE_SCHEDULE_TTL",
      "SPORTS_CACHE_LIVE_TTL",
      "SPORTS_CACHE_ENABLED",
      "SPORTS_API_KEY",
      "SPORTS_RATE_LIMIT_MAX",
      "SPORTS_RATE_LIMIT_WINDOW_MS"
    ]
  },

  "config": {
    "port": 3201,
    "webhookPath": "/webhooks/sports",
    "retryAttempts": 3,
    "retryDelay": 1000
  },

  "hooks": {
    "postInstall": null,
    "preUninstall": null,
    "postSync": null
  },

  "multiApp": {
    "supported": true,
    "isolationColumn": "source_account_id",
    "pkStrategy": "single",
    "defaultValue": "primary"
  },

  "permissions": {
    "database": ["create", "read", "update", "delete"],
    "network": ["site.api.espn.com", "api.sportsdata.io", "thesportsdb.com"],
    "filesystem": ["logs", "cache"]
  }
}
