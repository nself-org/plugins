# =============================================================================
# Sports Plugin Configuration
# =============================================================================
# Copy this file to .env and configure for your environment
# Documentation: See README.md for detailed configuration guide

# -----------------------------------------------------------------------------
# Required Variables (Plugin will not start without these)
# -----------------------------------------------------------------------------

# Database connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# Server port (default: 3035)
SPORTS_PLUGIN_PORT=3035

# Logging level (debug|info|warn|error) - default: info
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Multi-App Configuration (Optional)
# -----------------------------------------------------------------------------

# Comma-separated list of app IDs to serve
# If not set, serves all apps
SPORTS_APP_IDS=

# -----------------------------------------------------------------------------
# Sports Data Providers
# -----------------------------------------------------------------------------

# Primary provider (espn|sportsdata|thesportsdb)
# Default: espn (free, no API key required)
SPORTS_PROVIDER=espn

# Comma-separated list of enabled providers
# Multiple providers can be used for redundancy
SPORTS_PROVIDERS=espn

# ESPN API Configuration (optional - for premium features)
SPORTS_ESPN_API_KEY=
SPORTS_ESPN_API_URL=https://site.api.espn.com/apis/site/v2/sports

# SportsData.io API Configuration (optional)
# Get your key from: https://sportsdata.io/
SPORTS_SPORTSDATA_API_KEY=
SPORTS_SPORTSDATA_API_URL=https://api.sportsdata.io

# -----------------------------------------------------------------------------
# Sports and Leagues Configuration
# -----------------------------------------------------------------------------

# Enabled sports (comma-separated)
# Available: football, basketball, baseball, hockey, soccer
SPORTS_ENABLED_SPORTS=football,basketball,baseball

# Enabled leagues (comma-separated)
# NFL, NBA, MLB, NHL, MLS, etc.
SPORTS_ENABLED_LEAGUES=NFL,NBA,MLB

# Specific league IDs to track (optional)
SPORTS_LEAGUE_IDS=

# -----------------------------------------------------------------------------
# Sync Settings
# -----------------------------------------------------------------------------

# Sync interval in minutes (default: 60)
# How often to sync schedule and standings data
SPORTS_SYNC_INTERVAL=60

# Live game poll interval in seconds (default: 30)
# How often to check for score updates during live games
SPORTS_LIVE_POLL_INTERVAL=30
SPORTS_LIVE_GAME_POLL_SECONDS=30

# -----------------------------------------------------------------------------
# Event Locking
# -----------------------------------------------------------------------------

# Lock window in minutes before event start (default: 60)
# Events are locked to prevent schedule changes within this window
SPORTS_LOCK_WINDOW_MINUTES=60

# Automatically lock events (true|false, default: true)
SPORTS_LOCK_AUTO=true

# -----------------------------------------------------------------------------
# Recording Integration
# -----------------------------------------------------------------------------

# Recording Plugin URL (for auto-triggering recordings)
SPORTS_RECORDING_PLUGIN_URL=http://localhost:3602

# Automatically trigger recordings for favorite teams (true|false)
SPORTS_AUTO_TRIGGER_RECORDINGS=false

# Recording lead time in minutes (start before game)
SPORTS_RECORDING_LEAD_TIME_MINUTES=15

# Recording trail time in minutes (continue after scheduled end)
SPORTS_RECORDING_TRAIL_TIME_MINUTES=60

# -----------------------------------------------------------------------------
# Caching Settings
# -----------------------------------------------------------------------------

# Enable caching (true|false, default: true)
SPORTS_CACHE_ENABLED=true

# Schedule cache TTL in seconds (default: 3600 = 1 hour)
SPORTS_CACHE_SCHEDULE_TTL=3600

# Live score cache TTL in seconds (default: 30)
SPORTS_CACHE_LIVE_TTL=30

# -----------------------------------------------------------------------------
# API Security (Optional)
# -----------------------------------------------------------------------------

# API key for securing plugin endpoints
SPORTS_API_KEY=

# Rate limiting - max requests per window
SPORTS_RATE_LIMIT_MAX=100

# Rate limiting - window duration in milliseconds (default: 60000 = 1 minute)
SPORTS_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# Provider Information
# -----------------------------------------------------------------------------
# ESPN:
#   - Free API access (no key required)
#   - NFL, NBA, MLB, NHL, MLS, College sports
#   - Real-time scores and play-by-play
#   - Rate limit: ~100 requests/hour
#
# SportsData.io:
#   - Paid API service
#   - Free tier: 1000 calls/month
#   - Very comprehensive data including player stats
#   - Website: https://sportsdata.io/
#
# TheSportsDB:
#   - Free API (Patreon supporters get more features)
#   - Good for team info, logos, historical data
#   - Website: https://www.thesportsdb.com/
