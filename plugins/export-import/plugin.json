{
  "name": "export-import",
  "version": "1.0.0",
  "description": "Bulk data export/import with multiple format support, migration tools, backup/restore, and cross-platform data transfer",
  "author": "nself",
  "license": "Source-Available",
  "homepage": "https://github.com/acamarata/nself-plugins/tree/main/plugins/export-import",
  "repository": "https://github.com/acamarata/nself-plugins",
  "minNselfVersion": "0.4.8",
  "category": "data-management",
  "tags": ["export", "import", "migration", "backup", "restore", "data-transfer"],

  "tables": [
    "ei_export_jobs",
    "ei_import_jobs",
    "ei_migration_jobs",
    "ei_backup_snapshots",
    "ei_restore_jobs",
    "ei_transform_templates",
    "ei_data_transfer_audit",
    "ei_backup_schedule"
  ],

  "webhooks": {},

  "actions": {
    "export": "Manage data exports",
    "import": "Manage data imports",
    "migrate": "Manage cross-platform migrations",
    "backup": "Manage backup snapshots",
    "restore": "Manage restore jobs",
    "transform": "Manage data transformation templates",
    "audit": "View data transfer audit log",
    "status": "View overall statistics"
  },

  "envVars": {
    "required": [
      "DATABASE_URL"
    ],
    "optional": [
      "EI_PLUGIN_PORT",
      "EXPORT_STORAGE_PATH",
      "EXPORT_MAX_FILE_SIZE_GB",
      "EXPORT_RETENTION_DAYS",
      "IMPORT_MAX_FILE_SIZE_GB",
      "IMPORT_TEMP_PATH",
      "BACKUP_STORAGE_BACKEND",
      "BACKUP_RETENTION_DAYS",
      "MIGRATION_BATCH_SIZE",
      "MIGRATION_RATE_LIMIT_MS",
      "EXPORT_IMPORT_QUEUE_CONCURRENCY",
      "EXPORT_IMPORT_QUEUE_TIMEOUT_MINUTES",
      "COMPRESSION_LEVEL",
      "COMPRESSION_ALGORITHM",
      "EI_API_KEY",
      "EI_RATE_LIMIT_MAX",
      "EI_RATE_LIMIT_WINDOW_MS"
    ]
  },

  "config": {
    "port": 3717,
    "exportRetentionDays": 30,
    "backupStorageBackend": "local",
    "backupRetentionDays": 90,
    "migrationBatchSize": 100,
    "compressionLevel": 6,
    "compressionAlgorithm": "gzip",
    "queueConcurrency": 5,
    "rateLimitMax": 100,
    "rateLimitWindowMs": 60000
  },

  "hooks": {
    "postInstall": null,
    "preUninstall": null,
    "postSync": null
  },

  "multiApp": {
    "supported": true,
    "isolationColumn": "source_account_id",
    "pkStrategy": "uuid",
    "defaultValue": "primary"
  },

  "permissions": {
    "database": ["create", "read", "update", "delete"],
    "network": [],
    "filesystem": ["logs", "exports", "imports", "backups"]
  }
}
