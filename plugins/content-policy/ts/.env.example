# Content Policy Plugin Configuration

# Database (Required)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nself
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_SSL=false

# Server Configuration
CP_PLUGIN_PORT=3504
CP_PLUGIN_HOST=0.0.0.0

# Policy Settings
CP_DEFAULT_ACTION=flag
CP_PROFANITY_ENABLED=true
CP_MAX_CONTENT_LENGTH=100000
CP_EVALUATION_LOG_ENABLED=true

# Security
CP_API_KEY=
CP_RATE_LIMIT_MAX=200
CP_RATE_LIMIT_WINDOW_MS=60000

# Logging
LOG_LEVEL=info
