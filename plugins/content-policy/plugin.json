{
  "name": "content-policy",
  "version": "1.0.0",
  "description": "Content policy evaluation and moderation engine with rule-based filtering",
  "author": "nself",
  "license": "Source-Available",
  "homepage": "https://github.com/acamarata/nself-plugins/tree/main/plugins/content-policy",
  "repository": "https://github.com/acamarata/nself-plugins",
  "minNselfVersion": "0.4.8",
  "category": "content",
  "tags": ["content", "moderation", "policy", "filtering", "compliance"],

  "tables": [
    "cp_policies",
    "cp_rules",
    "cp_evaluations",
    "cp_word_lists",
    "cp_overrides"
  ],

  "webhooks": {},

  "actions": {
    "evaluate": "Evaluate content against policies",
    "policies": "Manage content policies",
    "word-lists": "Manage word lists",
    "queue": "View flagged content",
    "stats": "View moderation statistics"
  },

  "envVars": {
    "required": [
      "DATABASE_URL"
    ],
    "optional": [
      "CP_PLUGIN_PORT",
      "CP_DEFAULT_ACTION",
      "CP_PROFANITY_ENABLED",
      "CP_MAX_CONTENT_LENGTH",
      "CP_EVALUATION_LOG_ENABLED",
      "CP_API_KEY",
      "CP_RATE_LIMIT_MAX",
      "CP_RATE_LIMIT_WINDOW_MS"
    ]
  },

  "config": {
    "port": 3504,
    "defaultAction": "flag",
    "profanityEnabled": true,
    "maxContentLength": 100000,
    "evaluationLogEnabled": true,
    "rateLimitMax": 200,
    "rateLimitWindowMs": 60000
  },

  "hooks": {
    "postInstall": null,
    "preUninstall": null,
    "postSync": null
  },

  "multiApp": {
    "supported": true,
    "isolationColumn": "source_account_id",
    "pkStrategy": "uuid",
    "defaultValue": "primary"
  },

  "permissions": {
    "database": ["create", "read", "update", "delete"],
    "network": [],
    "filesystem": ["logs", "cache"]
  }
}
