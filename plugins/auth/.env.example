# =============================================================================
# uauth Plugin - Environment Configuration
# =============================================================================
# Advanced authentication: OAuth, WebAuthn/passkeys, TOTP 2FA, magic links, device-code flow
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Auto-provided by nself CLI
# -----------------------------------------------------------------------------

# PostgreSQL connection string (auto-provided by nself)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# -----------------------------------------------------------------------------
# REQUIRED - Security Configuration (auto-provided by nself)
# -----------------------------------------------------------------------------

# API key for inter-plugin authentication
AUTH_API_KEY=your-api-key-here

# Rate limiting (requests per window)
AUTH_RATE_LIMIT_MAX=100

# Rate limiting window (milliseconds)
AUTH_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# OPTIONAL - Server Configuration
# -----------------------------------------------------------------------------

# Server port (default from plugin.json: 3014)
AUTH_PORT=3014

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# OPTIONAL - Plugin-Specific Configuration
# -----------------------------------------------------------------------------

# AUTH_PLUGIN_HOST
AUTH_PLUGIN_HOST=value

# AUTH_LOG_LEVEL
AUTH_LOG_LEVEL=value

# AUTH_APP_IDS
AUTH_APP_IDS=value

# AUTH_GOOGLE_CLIENT_ID
AUTH_GOOGLE_CLIENT_ID=value

# AUTH_GOOGLE_CLIENT_SECRET
AUTH_GOOGLE_CLIENT_SECRET=value

# AUTH_GOOGLE_SCOPES
AUTH_GOOGLE_SCOPES=value

# AUTH_APPLE_CLIENT_ID
AUTH_APPLE_CLIENT_ID=value

# AUTH_APPLE_TEAM_ID
AUTH_APPLE_TEAM_ID=value

# AUTH_APPLE_KEY_ID
AUTH_APPLE_KEY_ID=value

# AUTH_APPLE_PRIVATE_KEY
AUTH_APPLE_PRIVATE_KEY=value

# AUTH_FACEBOOK_APP_ID
AUTH_FACEBOOK_APP_ID=value

# AUTH_FACEBOOK_APP_SECRET
AUTH_FACEBOOK_APP_SECRET=value

# AUTH_GITHUB_CLIENT_ID
AUTH_GITHUB_CLIENT_ID=value

# AUTH_GITHUB_CLIENT_SECRET
AUTH_GITHUB_CLIENT_SECRET=value

# AUTH_MICROSOFT_CLIENT_ID
AUTH_MICROSOFT_CLIENT_ID=value

# AUTH_MICROSOFT_CLIENT_SECRET
AUTH_MICROSOFT_CLIENT_SECRET=value

# AUTH_WEBAUTHN_RP_NAME
AUTH_WEBAUTHN_RP_NAME=value

# AUTH_WEBAUTHN_RP_ID
AUTH_WEBAUTHN_RP_ID=value

# AUTH_WEBAUTHN_ORIGIN
AUTH_WEBAUTHN_ORIGIN=value

# AUTH_TOTP_ISSUER
AUTH_TOTP_ISSUER=value

# AUTH_TOTP_ALGORITHM
AUTH_TOTP_ALGORITHM=value

# AUTH_TOTP_DIGITS
AUTH_TOTP_DIGITS=value

# AUTH_TOTP_PERIOD
AUTH_TOTP_PERIOD=value

# AUTH_TOTP_BACKUP_CODE_COUNT
AUTH_TOTP_BACKUP_CODE_COUNT=value

# AUTH_MAGIC_LINK_EXPIRY_SECONDS
AUTH_MAGIC_LINK_EXPIRY_SECONDS=value

# AUTH_MAGIC_LINK_BASE_URL
AUTH_MAGIC_LINK_BASE_URL=value

# AUTH_DEVICE_CODE_EXPIRY_SECONDS
AUTH_DEVICE_CODE_EXPIRY_SECONDS=value

# AUTH_DEVICE_CODE_POLL_INTERVAL
AUTH_DEVICE_CODE_POLL_INTERVAL=value

# AUTH_DEVICE_CODE_LENGTH
AUTH_DEVICE_CODE_LENGTH=value

# AUTH_SESSION_MAX_PER_USER
AUTH_SESSION_MAX_PER_USER=value

# AUTH_SESSION_IDLE_TIMEOUT_HOURS
AUTH_SESSION_IDLE_TIMEOUT_HOURS=value

# AUTH_SESSION_ABSOLUTE_TIMEOUT_HOURS
AUTH_SESSION_ABSOLUTE_TIMEOUT_HOURS=value

# AUTH_LOGIN_MAX_ATTEMPTS
AUTH_LOGIN_MAX_ATTEMPTS=value

# AUTH_LOGIN_LOCKOUT_MINUTES
AUTH_LOGIN_LOCKOUT_MINUTES=value

# AUTH_CLEANUP_CRON
AUTH_CLEANUP_CRON=value


