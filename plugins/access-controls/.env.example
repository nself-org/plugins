# =============================================================================
# Access Controls Plugin - Environment Configuration
# =============================================================================
# Role-based and attribute-based access control (RBAC + ABAC) with policy engine
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Auto-provided by nself CLI
# -----------------------------------------------------------------------------

# PostgreSQL connection string (auto-provided by nself)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# -----------------------------------------------------------------------------
# REQUIRED - Security Configuration (auto-provided by nself)
# -----------------------------------------------------------------------------

# API key for inter-plugin authentication
ACL_API_KEY=your-api-key-here

# Rate limiting (requests per window)
ACL_RATE_LIMIT_MAX=100

# Rate limiting window (milliseconds)
ACL_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# OPTIONAL - Server Configuration
# -----------------------------------------------------------------------------

# Server port (default from plugin.json: 3027)
ACL_PLUGIN_PORT=3027

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# OPTIONAL - Access Control Settings
# -----------------------------------------------------------------------------

# Cache TTL for authorization decisions (seconds)
# Caching improves performance but may delay permission updates
ACL_CACHE_TTL_SECONDS=300

# Maximum role hierarchy depth (prevent infinite loops)
# Roles can inherit from parent roles up to this depth
ACL_MAX_ROLE_DEPTH=10

# Default deny mode (true = deny by default, false = allow by default)
# Recommended: true (fail-safe)
ACL_DEFAULT_DENY=true

# -----------------------------------------------------------------------------
# RBAC vs ABAC
# -----------------------------------------------------------------------------
#
# RBAC (Role-Based Access Control):
#   - Assign roles to users (e.g., admin, editor, viewer)
#   - Assign permissions to roles (e.g., posts.create, posts.delete)
#   - Role hierarchy support (admin inherits editor permissions)
#
# ABAC (Attribute-Based Access Control):
#   - Policy engine for complex rules
#   - Conditions based on user attributes, resource attributes, context
#   - Example: Allow edit if user.id == post.author_id AND time < post.deadline
#
# Use Cases:
#   - Simple permissions: Use RBAC
#   - Complex conditional access: Use ABAC policies
#   - Mix both for comprehensive access control
# -----------------------------------------------------------------------------
