# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nself
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_SSL=false

# Server Configuration
ACL_PLUGIN_PORT=3027
ACL_PLUGIN_HOST=0.0.0.0

# ACL Configuration
ACL_CACHE_TTL_SECONDS=300
ACL_MAX_ROLE_DEPTH=10
ACL_DEFAULT_DENY=true

# Security (optional)
ACL_API_KEY=
ACL_RATE_LIMIT_MAX=200
ACL_RATE_LIMIT_WINDOW_MS=60000

# Logging
LOG_LEVEL=info
NODE_ENV=development
