# =============================================================================
# EPG (Electronic Program Guide) Configuration
# =============================================================================
# Copy this file to .env and configure for your environment
# Documentation: See README.md for detailed configuration guide

# -----------------------------------------------------------------------------
# Required Variables (Plugin will not start without these)
# -----------------------------------------------------------------------------

# Database connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# Server port (default: 3031)
EPG_PLUGIN_PORT=3031

# Logging level (debug|info|warn|error) - default: info
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Multi-App Configuration (Optional)
# -----------------------------------------------------------------------------

# Comma-separated list of app IDs to serve
# If not set, serves all apps
EPG_APP_IDS=

# -----------------------------------------------------------------------------
# EPG Data Sources
# -----------------------------------------------------------------------------

# XMLTV feed URLs (comma-separated)
# Example: http://example.com/feed1.xml,http://example.com/feed2.xml
EPG_XMLTV_URLS=

# Schedules Direct credentials (optional)
# Get account at: https://www.schedulesdirect.org/
EPG_SCHEDULES_DIRECT_USERNAME=
EPG_SCHEDULES_DIRECT_PASSWORD=

# -----------------------------------------------------------------------------
# EPG Settings
# -----------------------------------------------------------------------------

# Default timezone for schedule display
# Example: America/New_York, America/Los_Angeles, Europe/London
# Default: America/New_York
EPG_DEFAULT_TIMEZONE=America/New_York

# Number of days ahead to fetch guide data (default: 14)
EPG_GUIDE_DAYS_AHEAD=14

# Number of days to retain old schedule data (default: 7)
# Older data is automatically cleaned up
EPG_GUIDE_DAYS_RETAIN=7

# -----------------------------------------------------------------------------
# Primetime Configuration
# -----------------------------------------------------------------------------

# Primetime hours are configurable via plugin.json config section:
# - primetimeStart: "19:00" (7 PM)
# - primetimeEnd: "23:00" (11 PM)

# -----------------------------------------------------------------------------
# Data Sources Information
# -----------------------------------------------------------------------------
# XMLTV:
#   - Standard XML format for EPG data
#   - Many free and commercial sources available
#   - Set EPG_XMLTV_URLS with comma-separated URLs
#
# Schedules Direct:
#   - Commercial service with accurate US/Canada listings
#   - $25/year subscription required
#   - Provides 14 days of guide data
#   - Website: https://www.schedulesdirect.org/
