{
  "name": "calendar",
  "version": "1.0.0",
  "description": "Calendar and event management with recurring events, iCal export, and RSVP tracking",
  "author": "nself",
  "license": "Source-Available",
  "homepage": "https://github.com/acamarata/nself-plugins/tree/main/plugins/calendar",
  "repository": "https://github.com/acamarata/nself-plugins",
  "minNselfVersion": "0.4.8",
  "category": "content",
  "tags": ["calendar", "events", "scheduling", "ical", "recurring", "rsvp"],

  "tables": [
    "calendar_calendars",
    "calendar_events",
    "calendar_attendees",
    "calendar_reminders",
    "calendar_ical_feeds",
    "calendar_webhook_events"
  ],

  "webhooks": {},

  "actions": {
    "server": "Start the calendar API server",
    "events": "Manage calendar events",
    "calendars": "Manage calendars",
    "reminders": "View and manage reminders",
    "ical": "Manage iCalendar feeds",
    "stats": "View calendar statistics"
  },

  "envVars": {
    "required": [
      "DATABASE_URL"
    ],
    "optional": [
      "CALENDAR_PLUGIN_PORT",
      "CALENDAR_DEFAULT_TIMEZONE",
      "CALENDAR_MAX_ATTENDEES",
      "CALENDAR_REMINDER_CHECK_INTERVAL_MS",
      "CALENDAR_MAX_RECURRENCE_EXPAND",
      "CALENDAR_ICAL_TOKEN_LENGTH",
      "CALENDAR_API_KEY",
      "CALENDAR_RATE_LIMIT_MAX",
      "CALENDAR_RATE_LIMIT_WINDOW_MS"
    ]
  },

  "config": {
    "defaultPort": 3505,
    "defaultTimezone": "UTC",
    "maxAttendees": 500,
    "reminderCheckInterval": 60000,
    "maxRecurrenceExpand": 365,
    "icalTokenLength": 64
  },

  "hooks": {
    "postInstall": null,
    "preUninstall": null,
    "postSync": null
  },

  "multiApp": {
    "supported": true,
    "isolationColumn": "source_account_id",
    "pkStrategy": "single",
    "defaultValue": "primary"
  },

  "permissions": {
    "database": ["create", "read", "update", "delete"],
    "network": [],
    "filesystem": ["logs", "cache"]
  }
}
