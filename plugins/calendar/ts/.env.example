# Database Configuration (Required)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nself
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_SSL=false

# Server Configuration
CALENDAR_PLUGIN_PORT=3505
CALENDAR_PLUGIN_HOST=0.0.0.0

# Calendar Settings
CALENDAR_DEFAULT_TIMEZONE=UTC
CALENDAR_MAX_ATTENDEES=500
CALENDAR_REMINDER_CHECK_INTERVAL_MS=60000
CALENDAR_MAX_RECURRENCE_EXPAND=365
CALENDAR_ICAL_TOKEN_LENGTH=64

# Security (Optional)
CALENDAR_API_KEY=
CALENDAR_RATE_LIMIT_MAX=200
CALENDAR_RATE_LIMIT_WINDOW_MS=60000

# Logging
LOG_LEVEL=info
