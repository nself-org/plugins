# =============================================================================
# ucompliance Plugin - Environment Configuration
# =============================================================================
# Comprehensive compliance and audit platform with GDPR/CCPA/HIPAA/SOC2/PCI management, DSARs, consent tracking, data retention, breach notification, immutable audit logging, SIEM integration, and compliance reporting
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Auto-provided by nself CLI
# -----------------------------------------------------------------------------

# PostgreSQL connection string (auto-provided by nself)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# -----------------------------------------------------------------------------
# REQUIRED - Security Configuration (auto-provided by nself)
# -----------------------------------------------------------------------------

# API key for inter-plugin authentication
COMPLIANCE_API_KEY=your-api-key-here

# Rate limiting (requests per window)
COMPLIANCE_RATE_LIMIT_MAX=100

# Rate limiting window (milliseconds)
COMPLIANCE_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# OPTIONAL - Server Configuration
# -----------------------------------------------------------------------------

# Server port (default from plugin.json: 3211)
COMPLIANCE_PORT=3211

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# OPTIONAL - Plugin-Specific Configuration
# -----------------------------------------------------------------------------

# COMPLIANCE_PLUGIN_HOST
COMPLIANCE_PLUGIN_HOST=value

# COMPLIANCE_APP_IDS
COMPLIANCE_APP_IDS=value

# COMPLIANCE_LOG_LEVEL
COMPLIANCE_LOG_LEVEL=value

# COMPLIANCE_GDPR_ENABLED
COMPLIANCE_GDPR_ENABLED=value

# COMPLIANCE_CCPA_ENABLED
COMPLIANCE_CCPA_ENABLED=value

# COMPLIANCE_HIPAA_ENABLED
COMPLIANCE_HIPAA_ENABLED=value

# COMPLIANCE_SOC2_ENABLED
COMPLIANCE_SOC2_ENABLED=value

# COMPLIANCE_PCI_ENABLED
COMPLIANCE_PCI_ENABLED=value

# COMPLIANCE_DSAR_DEADLINE_DAYS
COMPLIANCE_DSAR_DEADLINE_DAYS=value

# COMPLIANCE_BREACH_NOTIFICATION_HOURS
COMPLIANCE_BREACH_NOTIFICATION_HOURS=value

# COMPLIANCE_CONSENT_REQUIRED
COMPLIANCE_CONSENT_REQUIRED=value

# COMPLIANCE_CONSENT_EXPIRY_DAYS
COMPLIANCE_CONSENT_EXPIRY_DAYS=value

# COMPLIANCE_RETENTION_ENABLED
COMPLIANCE_RETENTION_ENABLED=value

# COMPLIANCE_AUDIT_ENABLED
COMPLIANCE_AUDIT_ENABLED=value

# COMPLIANCE_AUDIT_RETENTION_DAYS
COMPLIANCE_AUDIT_RETENTION_DAYS=value

# COMPLIANCE_EXPORT_FORMAT
COMPLIANCE_EXPORT_FORMAT=value

# COMPLIANCE_EXPORT_EXPIRY_HOURS
COMPLIANCE_EXPORT_EXPIRY_HOURS=value

# COMPLIANCE_EXPORT_MAX_ROWS
COMPLIANCE_EXPORT_MAX_ROWS=value

# AUDIT_FALLBACK_LOG_PATH
AUDIT_FALLBACK_LOG_PATH=value

# AUDIT_SIEM_SPLUNK_HEC_URL
AUDIT_SIEM_SPLUNK_HEC_URL=value

# AUDIT_SIEM_SPLUNK_HEC_TOKEN
AUDIT_SIEM_SPLUNK_HEC_TOKEN=value

# AUDIT_SIEM_ELK_URL
AUDIT_SIEM_ELK_URL=value

# AUDIT_SIEM_ELK_INDEX
AUDIT_SIEM_ELK_INDEX=value

# AUDIT_SIEM_DATADOG_SITE
AUDIT_SIEM_DATADOG_SITE=value

# AUDIT_DEFAULT_RETENTION_DAYS
AUDIT_DEFAULT_RETENTION_DAYS=value

# AUDIT_COMPLIANCE_FRAMEWORKS
AUDIT_COMPLIANCE_FRAMEWORKS=value

# AUDIT_ALERT_WEBHOOK_URL
AUDIT_ALERT_WEBHOOK_URL=value


# -----------------------------------------------------------------------------
# Additional Configuration
# -----------------------------------------------------------------------------
#
# For complete plugin documentation and configuration options, see:
# - Plugin README: plugins/${PLUGIN_NAME}/README.md
# - Plugin JSON: plugins/${PLUGIN_NAME}/plugin.json
# - nself documentation: https://github.com/acamarata/nself-plugins
#
# Note: All variables marked as REQUIRED are auto-provided by the nself CLI
# during plugin installation and do not need manual configuration.
# -----------------------------------------------------------------------------
