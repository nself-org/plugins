{
  "name": "media-processing",
  "version": "1.0.0",
  "description": "FFmpeg-based media encoding and processing with HLS streaming support",
  "author": "nself",
  "license": "Source-Available",
  "homepage": "https://github.com/acamarata/nself-plugins/tree/main/plugins/media-processing",
  "repository": "https://github.com/acamarata/nself-plugins",
  "minNselfVersion": "0.4.8",
  "port": 3019,
  "category": "media",
  "tags": [
    "media",
    "video",
    "encoding",
    "ffmpeg",
    "hls",
    "dash",
    "cmaf",
    "streaming",
    "transcoding"
  ],
  "tables": [
    "np_mediap_encoding_profiles",
    "np_mediap_jobs",
    "np_mediap_job_outputs",
    "np_mediap_hls_manifests",
    "np_mediap_subtitles",
    "np_mediap_trickplay",
    "np_mediap_webhook_events",
    "np_mediap_watcher_events",
    "np_mediap_uploads"
  ],
  "webhooks": {
    "job.created": "Job submitted for processing",
    "job.downloading": "Downloading input file",
    "job.analyzing": "Analyzing media file",
    "job.encoding": "Encoding in progress",
    "job.packaging": "Creating HLS manifests",
    "job.uploading": "Uploading outputs",
    "job.completed": "Job completed successfully",
    "job.failed": "Job failed",
    "job.cancelled": "Job cancelled by user",
    "job.qa_failed": "Job failed QA validation",
    "job.progress": "Encoding progress update",
    "watcher.file_detected": "New file detected in drop folder",
    "watcher.job_submitted": "Job auto-submitted from watcher"
  },
  "actions": {
    "init": "Initialize database schema",
    "server": "Start HTTP API server",
    "submit": "Submit new encoding job",
    "jobs": "List and manage jobs",
    "profiles": "Manage encoding profiles",
    "analyze": "Analyze media file metadata",
    "stats": "View processing statistics",
    "watch": "Watch drop folder for new media files"
  },
  "envVars": {
    "required": [
      "DATABASE_URL"
    ],
    "optional": [
      "MP_PLUGIN_PORT",
      "MP_FFMPEG_PATH",
      "MP_FFPROBE_PATH",
      "MP_OUTPUT_BASE_PATH",
      "MP_MAX_CONCURRENT_JOBS",
      "MP_MAX_INPUT_SIZE_GB",
      "MP_HARDWARE_ACCEL",
      "MP_API_KEY",
      "MP_RATE_LIMIT_MAX",
      "MP_RATE_LIMIT_WINDOW_MS",
      "MP_PACKAGER",
      "MP_SHAKA_PACKAGER_PATH",
      "MP_OUTPUT_FORMATS",
      "MP_DROP_FOLDER_PATH",
      "MP_SETTLE_CHECK_SECONDS",
      "MP_SETTLE_CHECK_INTERVALS",
      "MP_METADATA_ENRICHMENT_URL",
      "MP_OBJECT_STORAGE_URL"
    ]
  },
  "config": {
    "maxConcurrentJobs": 2,
    "maxInputSizeGb": 50,
    "outputBasePath": "/data/media-processing",
    "ffmpegPath": "ffmpeg",
    "ffprobePath": "ffprobe",
    "packager": "ffmpeg-only",
    "outputFormats": [
      "hls"
    ]
  },
  "systemDependencies": {
    "required": [
      {
        "name": "ffmpeg",
        "minVersion": "5.0",
        "apt": "ffmpeg",
        "brew": "ffmpeg",
        "verify": "ffmpeg -version"
      },
      {
        "name": "ffprobe",
        "minVersion": "5.0",
        "apt": "ffmpeg",
        "brew": "ffmpeg",
        "verify": "ffprobe -version"
      }
    ],
    "recommended": [
      {
        "name": "shaka-packager",
        "custom_install": "curl -L https://github.com/shaka-project/shaka-packager/releases/latest/download/packager-linux-x64 -o /usr/local/bin/packager && chmod +x /usr/local/bin/packager",
        "verify": "packager --version",
        "note": "Required for CMAF HLS+DASH dual output. Falls back to FFmpeg-only HLS if not installed."
      },
      {
        "name": "guessit",
        "custom_install": "pip3 install guessit",
        "verify": "guessit --version",
        "note": "Python-based filename parser. Plugin uses built-in regex parser as fallback."
      }
    ]
  },
  "hooks": {
    "postInstall": null,
    "preUninstall": null,
    "postSync": null
  },
  "multiApp": {
    "supported": true,
    "isolationColumn": "source_account_id",
    "pkStrategy": "uuid",
    "defaultValue": "primary"
  },
  "permissions": {
    "database": [
      "create",
      "read",
      "update",
      "delete"
    ],
    "network": [
      "*"
    ],
    "filesystem": [
      "logs",
      "cache",
      "media"
    ]
  }
}
