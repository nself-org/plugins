# =============================================================================
# Media Processing Plugin - Environment Configuration
# =============================================================================
# Video transcoding, HLS/DASH packaging, hardware acceleration, drop-folder
# watching, and object storage integration
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Auto-provided by nself CLI
# -----------------------------------------------------------------------------

# PostgreSQL connection string (auto-provided by nself)
# Can also be set via individual POSTGRES_* variables
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# Alternative: Individual database configuration
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=nself_db
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=password
# POSTGRES_SSL=false

# -----------------------------------------------------------------------------
# REQUIRED - Security Configuration (auto-provided by nself)
# -----------------------------------------------------------------------------

# API key for inter-plugin authentication
MP_API_KEY=your-api-key-here

# Rate limiting (requests per window)
MP_RATE_LIMIT_MAX=100

# Rate limiting window (milliseconds)
MP_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# OPTIONAL - Server Configuration
# -----------------------------------------------------------------------------

# Server port (default from plugin.json: 3019)
MP_PLUGIN_PORT=3019

# Server host (bind address)
MP_PLUGIN_HOST=0.0.0.0

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# OPTIONAL - FFmpeg Configuration
# -----------------------------------------------------------------------------

# Path to ffmpeg binary
# Default: Uses system PATH
MP_FFMPEG_PATH=ffmpeg

# Path to ffprobe binary
# Default: Uses system PATH
MP_FFPROBE_PATH=ffprobe

# Output base path for transcoded files
# Must have sufficient disk space and write permissions
MP_OUTPUT_BASE_PATH=/data/media-processing

# Maximum concurrent transcoding jobs
# Set based on CPU cores and performance requirements
MP_MAX_CONCURRENT_JOBS=2

# Maximum input file size (GB)
# Reject files larger than this limit
MP_MAX_INPUT_SIZE_GB=50

# -----------------------------------------------------------------------------
# OPTIONAL - Hardware Acceleration
# -----------------------------------------------------------------------------

# Hardware acceleration: none, nvenc, vaapi, qsv
# - none: CPU-only (slow but compatible)
# - nvenc: NVIDIA GPU (requires CUDA/nvenc support)
# - vaapi: Intel/AMD GPU (Linux only)
# - qsv: Intel Quick Sync Video
MP_HARDWARE_ACCEL=none

# -----------------------------------------------------------------------------
# OPTIONAL - Packaging Configuration
# -----------------------------------------------------------------------------

# Packager: shaka, bento4, ffmpeg-only
# - shaka: Shaka Packager (DASH/HLS/CMAF)
# - bento4: Bento4 tools (MP4/HLS/DASH)
# - ffmpeg-only: FFmpeg HLS only (no DASH/CMAF)
MP_PACKAGER=ffmpeg-only

# Path to Shaka Packager binary (if using shaka packager)
# Download from: https://github.com/shaka-project/shaka-packager
MP_SHAKA_PACKAGER_PATH=packager

# Output formats (comma-separated): hls, dash, cmaf
# - hls: Apple HLS (m3u8 playlists)
# - dash: MPEG-DASH (mpd manifests)
# - cmaf: Common Media Application Format
MP_OUTPUT_FORMATS=hls

# -----------------------------------------------------------------------------
# OPTIONAL - Drop-Folder Watcher
# -----------------------------------------------------------------------------

# Path to watch for new media files
# Leave empty to disable drop-folder watching
MP_DROP_FOLDER_PATH=/data/drop-folder

# Settle check interval (seconds)
# Wait this long between file size checks to ensure upload is complete
MP_SETTLE_CHECK_SECONDS=5

# Number of settle check intervals
# File must be stable for (SECONDS * INTERVALS) before processing
MP_SETTLE_CHECK_INTERVALS=3

# -----------------------------------------------------------------------------
# OPTIONAL - Content Identification
# -----------------------------------------------------------------------------

# Metadata Enrichment Plugin URL
# Used for automatic content identification from filenames
MP_METADATA_ENRICHMENT_URL=http://localhost:3203

# -----------------------------------------------------------------------------
# OPTIONAL - Object Storage Integration
# -----------------------------------------------------------------------------

# Object Storage Plugin URL
# Used for uploading transcoded files to S3/MinIO/etc.
MP_OBJECT_STORAGE_URL=http://localhost:3301

# -----------------------------------------------------------------------------
# Media Processing Pipeline
# -----------------------------------------------------------------------------
#
# Transcoding Profiles:
#   - 4K (3840x2160): H.265, 15 Mbps
#   - 1080p (1920x1080): H.264, 5 Mbps
#   - 720p (1280x720): H.264, 2.5 Mbps
#   - 480p (854x480): H.264, 1 Mbps
#   - Audio: AAC, 128 kbps
#
# Hardware Acceleration:
#   - NVENC (NVIDIA): 5-10x faster than CPU
#   - VAAPI (Intel/AMD): 3-5x faster than CPU
#   - QSV (Intel): 4-8x faster than CPU
#   - Requires compatible GPU and drivers
#
# HLS Output:
#   - Adaptive bitrate streaming
#   - Multiple quality tiers
#   - 6-second segments
#   - Master playlist + variant playlists
#
# DASH Output:
#   - ISO BMFF format
#   - MPEG-DASH manifests
#   - Compatible with modern browsers
#
# Drop-Folder Workflow:
#   1. New file detected in drop folder
#   2. Wait for file to settle (upload complete)
#   3. Identify content via Metadata Enrichment
#   4. Transcode to configured profiles
#   5. Package as HLS/DASH
#   6. Upload to Object Storage
#   7. Update media library
#
# Performance Tips:
#   - Use hardware acceleration when available
#   - Set MAX_CONCURRENT_JOBS based on CPU cores
#   - Monitor disk I/O and space
#   - Use SSD for temp files if possible
#
# Integration:
#   - Content Acquisition: Automatic post-download processing
#   - Metadata Enrichment: Content identification
#   - Object Storage: Upload transcoded files
#   - Stream Gateway: Serve transcoded content
# -----------------------------------------------------------------------------
