# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/nself
# OR
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nself
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_SSL=false

# Server Configuration
MP_PLUGIN_PORT=3019
MP_PLUGIN_HOST=0.0.0.0

# FFmpeg Configuration
MP_FFMPEG_PATH=ffmpeg
MP_FFPROBE_PATH=ffprobe
MP_OUTPUT_BASE_PATH=/data/media-processing

# Processing Configuration
MP_MAX_CONCURRENT_JOBS=2
MP_MAX_INPUT_SIZE_GB=50

# Hardware Acceleration (none, nvenc, vaapi, qsv)
MP_HARDWARE_ACCEL=none

# Security (Optional)
MP_API_KEY=your_api_key_here

# Rate Limiting (Optional)
MP_RATE_LIMIT_MAX=50
MP_RATE_LIMIT_WINDOW_MS=60000

# Logging
LOG_LEVEL=info
