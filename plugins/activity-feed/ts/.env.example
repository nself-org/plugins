# Activity Feed Plugin Configuration

# Database Configuration (Required)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself

# PostgreSQL Connection Details (Alternative to DATABASE_URL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nself
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_SSL=false

# Server Configuration
FEED_PLUGIN_PORT=3503
FEED_PLUGIN_HOST=0.0.0.0

# Feed Strategy
# - "read": Fan-out-on-read (query subscriptions at read time, no materialized feed)
# - "write": Fan-out-on-write (materialize feed items when activities are created)
FEED_STRATEGY=read

# Feed Settings
FEED_MAX_FEED_SIZE=200
FEED_AGGREGATION_WINDOW_MINUTES=60
FEED_RETENTION_DAYS=90

# Security (Optional)
FEED_API_KEY=
FEED_RATE_LIMIT_MAX=200
FEED_RATE_LIMIT_WINDOW_MS=60000

# Logging
LOG_LEVEL=info
