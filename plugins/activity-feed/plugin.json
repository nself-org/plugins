{
  "name": "activity-feed",
  "version": "1.0.0",
  "description": "Universal activity feed system with fan-out-on-read/write, aggregation, and subscriptions",
  "author": "nself",
  "license": "Source-Available",
  "homepage": "https://github.com/acamarata/nself-plugins/tree/main/plugins/activity-feed",
  "repository": "https://github.com/acamarata/nself-plugins",
  "minNselfVersion": "0.4.8",
  "port": 3503,
  "category": "content",
  "tags": [
    "activity",
    "feed",
    "notifications",
    "social",
    "events"
  ],
  "tables": [
    "np_activityfeed_activities",
    "np_activityfeed_user_feeds",
    "np_activityfeed_subscriptions",
    "np_activityfeed_webhook_events"
  ],
  "webhooks": {
    "activity.created": "Record new activity to the system",
    "activity.updated": "Update existing activity data",
    "activity.deleted": "Remove activity from feeds",
    "subscription.created": "Track new feed subscription",
    "subscription.deleted": "Remove feed subscription",
    "feed.read": "Mark feed items as read",
    "feed.hidden": "Hide activities from user feed"
  },
  "actions": {
    "activities": "Manage and query activities",
    "feed": "View personalized activity feeds",
    "subscriptions": "Manage user subscriptions",
    "fanout": "Trigger manual fan-out operations",
    "stats": "View feed statistics"
  },
  "envVars": {
    "required": [
      "DATABASE_URL"
    ],
    "optional": [
      "FEED_PLUGIN_PORT",
      "FEED_STRATEGY",
      "FEED_MAX_FEED_SIZE",
      "FEED_AGGREGATION_WINDOW_MINUTES",
      "FEED_RETENTION_DAYS",
      "FEED_API_KEY",
      "FEED_RATE_LIMIT_MAX",
      "FEED_RATE_LIMIT_WINDOW_MS"
    ]
  },
  "config": {
    "port": 3503,
    "strategy": "read",
    "maxFeedSize": 200,
    "aggregationWindowMinutes": 60,
    "retentionDays": 90
  },
  "hooks": {
    "postInstall": null,
    "preUninstall": null,
    "postSync": null
  },
  "multiApp": {
    "supported": true,
    "isolationColumn": "source_account_id",
    "pkStrategy": "uuid",
    "defaultValue": "primary"
  },
  "permissions": {
    "database": [
      "create",
      "read",
      "update",
      "delete"
    ],
    "network": [],
    "filesystem": [
      "logs",
      "cache"
    ]
  }
}
