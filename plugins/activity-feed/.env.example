# =============================================================================
# Activity Feed Plugin - Environment Configuration
# =============================================================================
# Universal activity feed system with fan-out-on-read/write, aggregation,
# and subscriptions
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Auto-provided by nself CLI
# -----------------------------------------------------------------------------

# PostgreSQL connection string (auto-provided by nself)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# -----------------------------------------------------------------------------
# REQUIRED - Security Configuration (auto-provided by nself)
# -----------------------------------------------------------------------------

# API key for inter-plugin authentication
FEED_API_KEY=your-api-key-here

# Rate limiting (requests per window)
FEED_RATE_LIMIT_MAX=100

# Rate limiting window (milliseconds)
FEED_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# OPTIONAL - Server Configuration
# -----------------------------------------------------------------------------

# Server port (default from plugin.json: 3209)
FEED_PLUGIN_PORT=3209

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# OPTIONAL - Feed Strategy
# -----------------------------------------------------------------------------

# Fan-out strategy: read, write, hybrid
# - read: Fan-out on read (slower read, faster write)
# - write: Fan-out on write (faster read, slower write)
# - hybrid: Mix of both based on follower count
FEED_STRATEGY=read

# Maximum feed size per user
# Older items are pruned when this limit is exceeded
FEED_MAX_FEED_SIZE=200

# -----------------------------------------------------------------------------
# OPTIONAL - Aggregation Settings
# -----------------------------------------------------------------------------

# Aggregation window (minutes)
# Group similar activities within this time window
# Example: "John and 5 others liked your post"
FEED_AGGREGATION_WINDOW_MINUTES=60

# -----------------------------------------------------------------------------
# OPTIONAL - Retention Settings
# -----------------------------------------------------------------------------

# Feed retention (days)
# Automatically delete activities older than this
FEED_RETENTION_DAYS=90

# -----------------------------------------------------------------------------
# Feed Architecture
# -----------------------------------------------------------------------------
#
# Fan-out on Write:
#   - When activity is created, copy to all followers' feeds
#   - Pros: Fast reads (feed is pre-computed)
#   - Cons: Slow writes (if user has many followers)
#   - Best for: Most users have < 1000 followers
#
# Fan-out on Read:
#   - When feed is requested, query activities from followed users
#   - Pros: Fast writes
#   - Cons: Slow reads (must aggregate from many sources)
#   - Best for: Users with many followers (celebrities)
#
# Hybrid:
#   - Fan-out on write for normal users
#   - Fan-out on read for users with > 10k followers
#
# Activity Types:
#   - user.followed
#   - post.created
#   - post.liked
#   - comment.created
#   - Custom activity types via API
#
# Aggregation Example:
#   Before: "John liked post", "Jane liked post", "Bob liked post"
#   After:  "John, Jane, and Bob liked post"
# -----------------------------------------------------------------------------
