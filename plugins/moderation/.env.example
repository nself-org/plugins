# =============================================================================
# umoderation Plugin - Environment Configuration
# =============================================================================
# Unified content moderation platform with profanity filtering, toxicity detection, AI-powered review, rule-based policies, automated actions, manual review workflows, user strikes, and appeals management
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Auto-provided by nself CLI
# -----------------------------------------------------------------------------

# PostgreSQL connection string (auto-provided by nself)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# -----------------------------------------------------------------------------
# REQUIRED - Security Configuration (auto-provided by nself)
# -----------------------------------------------------------------------------

# API key for inter-plugin authentication
MODERATION_API_KEY=your-api-key-here

# Rate limiting (requests per window)
MODERATION_RATE_LIMIT_MAX=100

# Rate limiting window (milliseconds)
MODERATION_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# OPTIONAL - Server Configuration
# -----------------------------------------------------------------------------

# Server port (default from plugin.json: 3208)
MODERATION_PORT=3208

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# OPTIONAL - Plugin-Specific Configuration
# -----------------------------------------------------------------------------

# MODERATION_PLUGIN_HOST
MODERATION_PLUGIN_HOST=value

# MODERATION_APP_IDS
MODERATION_APP_IDS=value

# MODERATION_LOG_LEVEL
MODERATION_LOG_LEVEL=value

# MODERATION_PROVIDER
MODERATION_PROVIDER=value

# MODERATION_TOXICITY_ENABLED
MODERATION_TOXICITY_ENABLED=value

# MODERATION_TOXICITY_PROVIDER
MODERATION_TOXICITY_PROVIDER=value

# MODERATION_TOXICITY_THRESHOLD
MODERATION_TOXICITY_THRESHOLD=value

# MODERATION_AUTO_DELETE_ENABLED
MODERATION_AUTO_DELETE_ENABLED=value

# MODERATION_AUTO_DELETE_THRESHOLD
MODERATION_AUTO_DELETE_THRESHOLD=value

# MODERATION_AUTO_MUTE_ENABLED
MODERATION_AUTO_MUTE_ENABLED=value

# MODERATION_AUTO_MUTE_VIOLATIONS
MODERATION_AUTO_MUTE_VIOLATIONS=value

# MODERATION_APPEALS_ENABLED
MODERATION_APPEALS_ENABLED=value

# MODERATION_APPEALS_TIME_LIMIT_DAYS
MODERATION_APPEALS_TIME_LIMIT_DAYS=value

# MODERATION_CLEANUP_ENABLED
MODERATION_CLEANUP_ENABLED=value

# MODERATION_CLEANUP_INTERVAL_MINUTES
MODERATION_CLEANUP_INTERVAL_MINUTES=value

# MOD_GOOGLE_VISION_KEY
MOD_GOOGLE_VISION_KEY=value

# MOD_AWS_REKOGNITION_KEY
MOD_AWS_REKOGNITION_KEY=value

# MOD_AWS_REKOGNITION_SECRET
MOD_AWS_REKOGNITION_SECRET=value

# MOD_AWS_REKOGNITION_REGION
MOD_AWS_REKOGNITION_REGION=value

# MOD_AUTO_APPROVE_BELOW
MOD_AUTO_APPROVE_BELOW=value

# MOD_AUTO_REJECT_ABOVE
MOD_AUTO_REJECT_ABOVE=value

# MOD_FLAG_THRESHOLD
MOD_FLAG_THRESHOLD=value

# MOD_STRIKE_WARN_THRESHOLD
MOD_STRIKE_WARN_THRESHOLD=value

# MOD_STRIKE_BAN_THRESHOLD
MOD_STRIKE_BAN_THRESHOLD=value

# MOD_STRIKE_EXPIRY_DAYS
MOD_STRIKE_EXPIRY_DAYS=value

# MOD_REVIEW_SLA_HOURS
MOD_REVIEW_SLA_HOURS=value

# MOD_QUEUE_WORKER_CONCURRENCY
MOD_QUEUE_WORKER_CONCURRENCY=value

# CP_DEFAULT_ACTION
CP_DEFAULT_ACTION=value

# CP_PROFANITY_ENABLED
CP_PROFANITY_ENABLED=value

# CP_MAX_CONTENT_LENGTH
CP_MAX_CONTENT_LENGTH=value

# CP_EVALUATION_LOG_ENABLED
CP_EVALUATION_LOG_ENABLED=value


