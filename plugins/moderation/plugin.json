{
  "name": "moderation",
  "version": "1.0.0",
  "description": "Unified content moderation platform with profanity filtering, toxicity detection, AI-powered review, rule-based policies, automated actions, manual review workflows, user strikes, and appeals management",
  "author": "nself",
  "license": "Source-Available",
  "homepage": "https://github.com/acamarata/nself-plugins/tree/main/plugins/moderation",
  "repository": "https://github.com/acamarata/nself-plugins",
  "minNselfVersion": "0.4.8",
  "category": "content",
  "tags": [
    "moderation",
    "profanity",
    "toxicity",
    "content-filter",
    "safety",
    "review-queue",
    "appeals",
    "policy-engine",
    "ai-moderation",
    "strikes"
  ],
  "tables": [
    "np_moderation_rules",
    "np_moderation_wordlists",
    "np_moderation_actions",
    "np_moderation_flags",
    "np_moderation_appeals",
    "np_moderation_reports",
    "np_moderation_toxicity_scores",
    "np_moderation_user_stats",
    "np_moderation_audit_log",
    "np_moderation_mod_reviews",
    "np_moderation_mod_policies",
    "np_moderation_mod_user_strikes",
    "np_moderation_cp_policies",
    "np_moderation_cp_rules",
    "np_moderation_cp_evaluations",
    "np_moderation_cp_word_lists",
    "np_moderation_cp_overrides",
    "np_moderation_webhook_events"
  ],
  "webhooks": {
    "action.created": "New moderation action taken",
    "action.revoked": "Moderation action revoked",
    "flag.created": "Content flagged for review",
    "flag.reviewed": "Flagged content reviewed",
    "appeal.created": "New appeal submitted",
    "appeal.reviewed": "Appeal reviewed",
    "report.created": "New user report submitted",
    "rule.created": "New moderation rule created",
    "rule.updated": "Moderation rule updated",
    "review.approved": "Content auto-approved",
    "review.flagged": "Content flagged for manual review",
    "review.rejected": "Content rejected",
    "review.manual.completed": "Manual review completed",
    "user.strike.added": "Strike added to user",
    "user.strike.threshold": "User reached strike threshold"
  },
  "actions": {
    "init": "Initialize moderation database schema",
    "server": "Start moderation HTTP server",
    "analyze": "Analyze content for moderation issues",
    "evaluate": "Evaluate content against policies",
    "check-profanity": "Check content for profanity matches",
    "queue": "View and manage the moderation review queue",
    "review": "Make review decision on flagged content",
    "actions": "Manage moderation actions (warn, mute, ban)",
    "appeals": "Manage user appeals",
    "rules": "Manage moderation rules and wordlists",
    "policies": "Manage content policies",
    "word-lists": "Manage word lists",
    "user-status": "Check user moderation status and strikes",
    "stats": "View moderation statistics"
  },
  "envVars": {
    "required": [
      "DATABASE_URL"
    ],
    "optional": [
      "MODERATION_PLUGIN_PORT",
      "MODERATION_PLUGIN_HOST",
      "MODERATION_APP_IDS",
      "MODERATION_LOG_LEVEL",
      "MODERATION_PROVIDER",
      "MODERATION_TOXICITY_ENABLED",
      "MODERATION_TOXICITY_PROVIDER",
      "MODERATION_TOXICITY_THRESHOLD",
      "MODERATION_AUTO_DELETE_ENABLED",
      "MODERATION_AUTO_DELETE_THRESHOLD",
      "MODERATION_AUTO_MUTE_ENABLED",
      "MODERATION_AUTO_MUTE_VIOLATIONS",
      "MODERATION_APPEALS_ENABLED",
      "MODERATION_APPEALS_TIME_LIMIT_DAYS",
      "MODERATION_CLEANUP_ENABLED",
      "MODERATION_CLEANUP_INTERVAL_MINUTES",
      "MODERATION_API_KEY",
      "MODERATION_RATE_LIMIT_MAX",
      "MODERATION_RATE_LIMIT_WINDOW_MS",
      "MOD_OPENAI_API_KEY",
      "MOD_GOOGLE_VISION_KEY",
      "MOD_AWS_REKOGNITION_KEY",
      "MOD_AWS_REKOGNITION_SECRET",
      "MOD_AWS_REKOGNITION_REGION",
      "MOD_AUTO_APPROVE_BELOW",
      "MOD_AUTO_REJECT_ABOVE",
      "MOD_FLAG_THRESHOLD",
      "MOD_STRIKE_WARN_THRESHOLD",
      "MOD_STRIKE_BAN_THRESHOLD",
      "MOD_STRIKE_EXPIRY_DAYS",
      "MOD_REVIEW_SLA_HOURS",
      "MOD_QUEUE_WORKER_CONCURRENCY",
      "CP_DEFAULT_ACTION",
      "CP_PROFANITY_ENABLED",
      "CP_MAX_CONTENT_LENGTH",
      "CP_EVALUATION_LOG_ENABLED"
    ]
  },
  "config": {
    "defaultPort": 3704,
    "toxicityEnabled": false,
    "toxicityThreshold": 0.8,
    "autoDeleteEnabled": true,
    "autoDeleteThreshold": 0.95,
    "appealsEnabled": true,
    "appealsTimeLimitDays": 7
  },
  "hooks": {
    "postInstall": null,
    "preUninstall": null,
    "postSync": null
  },
  "multiApp": {
    "supported": true,
    "isolationColumn": "source_account_id",
    "pkStrategy": "single",
    "defaultValue": "primary"
  },
  "permissions": {
    "database": [
      "create",
      "read",
      "update",
      "delete"
    ],
    "network": [
      "api.openai.com",
      "vision.googleapis.com",
      "rekognition.*.amazonaws.com"
    ],
    "filesystem": [
      "logs",
      "cache",
      "temp"
    ]
  },
  "port": 3208
}
