{
  "name": "podcast",
  "version": "1.0.0",
  "description": "Podcast service with RSS feed parsing, episode management, playback position sync, and subscription management",
  "author": "nself",
  "license": "Source-Available",
  "homepage": "https://github.com/acamarata/nself-plugins/tree/main/plugins/podcast",
  "repository": "https://github.com/acamarata/nself-plugins",
  "minNselfVersion": "0.4.8",
  "port": 3210,
  "category": "media",
  "tags": [
    "podcast",
    "rss",
    "audio",
    "episodes",
    "subscriptions",
    "playback"
  ],
  "tables": [
    "np_podcast_podcasts",
    "np_podcast_episodes",
    "np_podcast_subscriptions",
    "np_podcast_playback_positions",
    "np_podcast_categories"
  ],
  "webhooks": {},
  "actions": {
    "feeds": "List feeds",
    "subscribe": "Subscribe to podcast",
    "episodes": "List episodes",
    "sync": "Sync RSS feeds",
    "search": "Search podcasts",
    "stats": "Show statistics"
  },
  "envVars": {
    "required": [
      "DATABASE_URL"
    ],
    "optional": [
      "PODCAST_PLUGIN_PORT",
      "PODCAST_RSS_POLL_INTERVAL",
      "PODCAST_MAX_EPISODES",
      "PODCAST_STORAGE_BACKEND"
    ]
  },
  "config": {
    "defaultPort": 3210,
    "rssPollIntervalMinutes": 60,
    "maxEpisodesPerFeed": 500,
    "storageBackend": "database",
    "feedTimeoutSeconds": 30,
    "cleanupOldEpisodesDays": 365
  },
  "hooks": {
    "postInstall": null,
    "preUninstall": null,
    "postSync": null
  },
  "multiApp": {
    "supported": true,
    "isolationColumn": "source_account_id",
    "pkStrategy": "uuid",
    "defaultValue": "primary"
  },
  "permissions": {
    "database": [
      "create",
      "read",
      "update",
      "delete"
    ],
    "network": [
      "*"
    ],
    "filesystem": [
      "logs",
      "cache",
      "temp"
    ]
  }
}
