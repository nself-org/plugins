# =============================================================================
# Podcast Plugin - Environment Configuration
# =============================================================================
# Podcast service with RSS feed parsing, episode management, playback position
# sync, and subscription management
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Auto-provided by nself CLI
# -----------------------------------------------------------------------------

# PostgreSQL connection string (auto-provided by nself)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# -----------------------------------------------------------------------------
# REQUIRED - Security Configuration (auto-provided by nself)
# -----------------------------------------------------------------------------

# API key for inter-plugin authentication
PODCAST_API_KEY=your-api-key-here

# Rate limiting (requests per window)
PODCAST_RATE_LIMIT_MAX=100

# Rate limiting window (milliseconds)
PODCAST_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# OPTIONAL - Server Configuration
# -----------------------------------------------------------------------------

# Server port (default from plugin.json: 3210)
PODCAST_PLUGIN_PORT=3210

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# OPTIONAL - Plugin-Specific Configuration
# -----------------------------------------------------------------------------

# RSS poll interval in minutes (default: 60)
PODCAST_RSS_POLL_INTERVAL=60

# Maximum episodes to store per feed (default: 500)
PODCAST_MAX_EPISODES=500

# Storage backend: database, minio (default: database)
PODCAST_STORAGE_BACKEND=database

# Feed fetch timeout in seconds (default: 30)
PODCAST_FEED_TIMEOUT=30

# Days to retain old episodes before cleanup (default: 365)
PODCAST_CLEANUP_OLD_EPISODES_DAYS=365


# -----------------------------------------------------------------------------
# Additional Configuration
# -----------------------------------------------------------------------------
#
# For complete plugin documentation and configuration options, see:
# - Plugin README: plugins/podcast/README.md
# - Plugin JSON: plugins/podcast/plugin.json
# - nself documentation: https://github.com/acamarata/nself-plugins
#
# Note: All variables marked as REQUIRED are auto-provided by the nself CLI
# during plugin installation and do not need manual configuration.
# -----------------------------------------------------------------------------
