{
  "name": "subsonic",
  "version": "1.0.0",
  "description": "Subsonic API server for music client compatibility (Symfonium, Ultrasonic, play:Sub, Amperfy)",
  "author": "nself",
  "license": "Source-Available",
  "homepage": "https://github.com/acamarata/nself-plugins/tree/main/plugins/subsonic",
  "repository": "https://github.com/acamarata/nself-plugins",
  "minNselfVersion": "0.4.8",
  "category": "media",
  "tags": [
    "music",
    "subsonic",
    "streaming",
    "media-server",
    "audio"
  ],
  "tables": [
    "np_sub_artists",
    "np_sub_albums",
    "np_sub_songs",
    "np_sub_playlists",
    "np_sub_playlist_songs",
    "np_sub_scrobbles",
    "np_sub_music_folders"
  ],
  "webhooks": {},
  "actions": {
    "scan": "Scan music library and index all files",
    "server": "Start the Subsonic API server",
    "status": "Show library statistics",
    "playlists": "Manage playlists"
  },
  "envVars": {
    "required": [
      "DATABASE_URL"
    ],
    "optional": [
      "SUBSONIC_PORT",
      "SUBSONIC_MUSIC_PATHS",
      "SUBSONIC_ADMIN_PASSWORD",
      "SUBSONIC_TRANSCODE_ENABLED",
      "SUBSONIC_MAX_BITRATE",
      "SUBSONIC_COVER_ART_PATH"
    ]
  },
  "config": {
    "syncInterval": 3600,
    "defaultPort": 3024,
    "apiVersion": "1.16.1"
  },
  "hooks": {
    "postInstall": "install.sh",
    "preUninstall": "uninstall.sh",
    "postSync": null
  },
  "multiApp": {
    "supported": true,
    "isolationColumn": "source_account_id",
    "pkStrategy": "uuid",
    "defaultValue": "primary"
  },
  "permissions": {
    "database": [
      "create",
      "read",
      "update",
      "delete"
    ],
    "network": [],
    "filesystem": [
      "logs",
      "cache",
      "music-read",
      "cover-art"
    ]
  },
  "port": 3303
}
