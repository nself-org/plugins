{
  "name": "cloudflare",
  "version": "1.0.0",
  "description": "Cloudflare zone, DNS, R2, cache, and analytics management",
  "author": "nself",
  "license": "Source-Available",
  "homepage": "https://github.com/acamarata/nself-plugins/tree/main/plugins/cloudflare",
  "repository": "https://github.com/acamarata/nself-plugins",
  "minNselfVersion": "0.4.8",
  "category": "infrastructure",
  "tags": [
    "cloudflare",
    "cdn",
    "dns",
    "r2",
    "cache",
    "analytics"
  ],
  "tables": [
    "cf_zones",
    "cf_dns_records",
    "cf_r2_buckets",
    "cf_cache_purge_log",
    "cf_analytics",
    "cf_webhook_events"
  ],
  "webhooks": {
    "cf.zone.synced": "Zone data synced from Cloudflare",
    "cf.dns.created": "DNS record created",
    "cf.dns.updated": "DNS record updated",
    "cf.dns.deleted": "DNS record deleted",
    "cf.cache.purged": "Cache purge completed",
    "cf.r2.bucket.created": "R2 bucket created",
    "cf.analytics.synced": "Analytics data synced"
  },
  "actions": {
    "init": "Initialize cloudflare database schema",
    "server": "Start cloudflare HTTP server",
    "sync": "Sync data from Cloudflare",
    "zones": "List zones",
    "dns": "Manage DNS records",
    "cache": "Manage CDN cache",
    "r2": "Manage R2 buckets",
    "analytics": "View zone analytics",
    "status": "Show sync status",
    "stats": "Show cloudflare statistics"
  },
  "envVars": {
    "required": [
      "CF_API_TOKEN",
      "DATABASE_URL"
    ],
    "optional": [
      "CF_PLUGIN_PORT",
      "CF_PLUGIN_HOST",
      "CF_LOG_LEVEL",
      "CF_APP_IDS",
      "CF_ZONE_IDS",
      "CF_R2_ACCESS_KEY",
      "CF_R2_SECRET_KEY",
      "CF_ACCOUNT_ID",
      "CF_SYNC_INTERVAL"
    ]
  },
  "config": {
    "port": 3024,
    "syncInterval": 3600,
    "analyticsSyncCron": "0 1 * * *"
  },
  "multiApp": {
    "supported": true,
    "isolationColumn": "source_account_id",
    "pkStrategy": "uuid",
    "defaultValue": "primary"
  },
  "hooks": {
    "postInstall": null,
    "preUninstall": null,
    "postSync": null
  },
  "permissions": {
    "database": [
      "create",
      "read",
      "update",
      "delete"
    ],
    "network": [
      "api.cloudflare.com"
    ],
    "filesystem": [
      "logs",
      "cache"
    ]
  }
}
