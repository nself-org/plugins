# =============================================================================
# Stream Gateway Configuration
# =============================================================================
# Copy this file to .env and configure for your environment
# Documentation: See README.md for detailed configuration guide

# -----------------------------------------------------------------------------
# Required Variables (Plugin will not start without these)
# -----------------------------------------------------------------------------

# Database connection string (either DATABASE_URL or individual POSTGRES_* vars)
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# Alternative: Individual PostgreSQL connection parameters
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=nself
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_SSL=false

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# Plugin server port (default: 3601)
SG_PLUGIN_PORT=3601
# PORT=3601  # Alternative variable name

# Plugin server host (default: 0.0.0.0)
SG_PLUGIN_HOST=0.0.0.0
# HOST=0.0.0.0  # Alternative variable name

# Logging level (debug|info|warn|error) - default: info
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Stream Session Settings
# -----------------------------------------------------------------------------

# Heartbeat interval in seconds (default: 30)
# How often clients must send heartbeat to maintain active session
SG_HEARTBEAT_INTERVAL=30

# Heartbeat timeout in seconds (default: 90)
# Session is terminated if no heartbeat received within this time
SG_HEARTBEAT_TIMEOUT=90

# Default maximum concurrent streams per user (default: 3)
SG_DEFAULT_MAX_CONCURRENT=3

# Default maximum streams per device (default: 1)
SG_DEFAULT_MAX_DEVICE_STREAMS=1

# Maximum session duration in hours (default: 12)
# Sessions are automatically terminated after this duration
SG_SESSION_MAX_DURATION_HOURS=12

# Analytics collection interval in seconds (default: 300)
SG_ANALYTICS_INTERVAL=300

# -----------------------------------------------------------------------------
# Per-App Overrides
# -----------------------------------------------------------------------------

# nTV app specific limits
SG_APP_TV_MAX_CONCURRENT=5
SG_APP_TV_MAX_DEVICE_STREAMS=1

# nFamily app specific limits
SG_APP_FAMILY_MAX_CONCURRENT=2

# -----------------------------------------------------------------------------
# External Service URLs
# -----------------------------------------------------------------------------

# Realtime Plugin URL for WebSocket notifications
SG_REALTIME_URL=http://localhost:3101

# Redis connection URL for session caching
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# URL Signing (nTV v1 API)
# -----------------------------------------------------------------------------

# Secret key for signing stream URLs (generate with: openssl rand -base64 32)
SG_SIGNING_SECRET=

# Signed URL expiry duration in seconds (default: 3600 = 1 hour)
SG_SIGNED_URL_EXPIRY_SECONDS=3600

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------

# Security prefix for environment variables (default: SG)
# Used by @nself/plugin-utils loadSecurityConfig
# Security settings: encryption keys, CORS, rate limits, etc.
# See @nself/plugin-utils documentation for details
