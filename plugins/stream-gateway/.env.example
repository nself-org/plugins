# =============================================================================
# Stream Gateway Plugin - Environment Configuration
# =============================================================================
# Stream session management, concurrency control, analytics, and URL signing
# for secure media delivery
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Auto-provided by nself CLI
# -----------------------------------------------------------------------------

# PostgreSQL connection string (auto-provided by nself)
# Can also be set via individual POSTGRES_* variables
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# Alternative: Individual database configuration
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=nself_db
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=password
# POSTGRES_SSL=false

# -----------------------------------------------------------------------------
# REQUIRED - Security Configuration (auto-provided by nself)
# -----------------------------------------------------------------------------

# API key for inter-plugin authentication
SG_API_KEY=your-api-key-here

# Rate limiting (requests per window)
SG_RATE_LIMIT_MAX=100

# Rate limiting window (milliseconds)
SG_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# REQUIRED - URL Signing (nTV v1 API)
# -----------------------------------------------------------------------------

# Secret key for signing stream URLs
# Must be shared with Media Processing plugin for URL validation
# Generate with: openssl rand -hex 32
SG_SIGNING_SECRET=your-64-character-hex-signing-secret-here

# -----------------------------------------------------------------------------
# OPTIONAL - Server Configuration
# -----------------------------------------------------------------------------

# Server port (default from plugin.json: 3601)
SG_PLUGIN_PORT=3601

# Server host (bind address)
SG_PLUGIN_HOST=0.0.0.0

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# OPTIONAL - Session Management
# -----------------------------------------------------------------------------

# Heartbeat interval (seconds)
# How often clients should send heartbeat to keep session alive
SG_HEARTBEAT_INTERVAL=30

# Heartbeat timeout (seconds)
# Mark session as inactive if no heartbeat for this duration
SG_HEARTBEAT_TIMEOUT=90

# Maximum session duration (hours)
# Automatically expire sessions after this duration
SG_SESSION_MAX_DURATION_HOURS=12

# -----------------------------------------------------------------------------
# OPTIONAL - Concurrency Control
# -----------------------------------------------------------------------------

# Default maximum concurrent streams per user (global default)
SG_DEFAULT_MAX_CONCURRENT=3

# Default maximum streams per device
SG_DEFAULT_MAX_DEVICE_STREAMS=1

# App-specific overrides (nTV application)
SG_APP_TV_MAX_CONCURRENT=5
SG_APP_TV_MAX_DEVICE_STREAMS=1

# App-specific overrides (nFamily application)
SG_APP_FAMILY_MAX_CONCURRENT=2

# -----------------------------------------------------------------------------
# OPTIONAL - Analytics Configuration
# -----------------------------------------------------------------------------

# Analytics snapshot interval (seconds)
# How often to record viewing statistics
SG_ANALYTICS_INTERVAL=300

# -----------------------------------------------------------------------------
# OPTIONAL - Integration URLs
# -----------------------------------------------------------------------------

# Realtime Plugin URL (for live session updates)
SG_REALTIME_URL=http://localhost:3101

# Redis URL (for session caching and pub/sub)
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# OPTIONAL - Signed URL Configuration
# -----------------------------------------------------------------------------

# Signed URL expiry (seconds)
# How long signed URLs remain valid
SG_SIGNED_URL_EXPIRY_SECONDS=3600

# -----------------------------------------------------------------------------
# Stream Gateway Architecture
# -----------------------------------------------------------------------------
#
# Session Lifecycle:
#   1. Start Session: POST /api/sessions/start
#      - Validate user permissions
#      - Check concurrency limits
#      - Generate session ID
#      - Return signed stream URL
#
#   2. Heartbeat: POST /api/sessions/:id/heartbeat
#      - Update last_heartbeat timestamp
#      - Track playback progress
#      - Maintain session as active
#
#   3. End Session: POST /api/sessions/:id/end
#      - Mark session as completed
#      - Record final analytics
#      - Free concurrency slot
#
# Concurrency Control:
#   - Per-user limits (e.g., 3 streams max)
#   - Per-device limits (e.g., 1 stream per device)
#   - Per-app overrides (nTV, nFamily)
#   - Real-time enforcement
#
# URL Signing:
#   - HMAC-SHA256 signed URLs
#   - Time-limited expiry
#   - Prevents URL sharing/hotlinking
#   - Validated by Media Processing plugin
#
# Analytics Tracking:
#   - Watch duration
#   - Playback quality
#   - Device information
#   - Geographic data
#   - Buffering events
#
# Integration:
#   - Realtime Plugin: Live session updates
#   - Redis: Session caching and pub/sub
#   - Media Processing: URL validation
#   - nTV Backend: User permissions
# -----------------------------------------------------------------------------
