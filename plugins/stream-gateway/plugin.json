{
  "name": "stream-gateway",
  "version": "1.0.0",
  "description": "Stream admission and governance service.",
  "author": "nself",
  "license": "Source-Available",
  "homepage": "https://github.com/acamarata/nself-plugins/tree/main/plugins/nself-stream-gateway",
  "repository": "https://github.com/acamarata/nself-plugins",
  "minNselfVersion": "0.9.8",
  "category": "streaming",
  "tags": [
    "streaming",
    "admission",
    "concurrency",
    "governance",
    "live"
  ],
  "tables": [
    "sg_stream_sessions",
    "sg_streams",
    "sg_admission_rules",
    "sg_viewer_analytics"
  ],
  "views": [
    "sg_concurrent_viewers_over_time",
    "sg_denial_rates",
    "sg_stream_duration_distribution",
    "sg_device_type_breakdown"
  ],
  "webhooks": {},
  "actions": {
    "init": {
      "description": "Initialize database schema",
      "requiresAuth": true
    },
    "server": {
      "description": "Start API server",
      "requiresAuth": true
    },
    "status": {
      "description": "Show gateway status",
      "requiresAuth": true
    },
    "streams list": {
      "description": "List all streams",
      "requiresAuth": true
    },
    "streams active": {
      "description": "List active streams with viewer counts",
      "requiresAuth": true
    },
    "sessions list": {
      "description": "List all sessions",
      "requiresAuth": true
    },
    "sessions active": {
      "description": "List active sessions",
      "requiresAuth": true
    },
    "admit": {
      "description": "Manually admit user to stream",
      "requiresAuth": true
    },
    "evict": {
      "description": "Evict a session",
      "requiresAuth": true
    },
    "rules list": {
      "description": "List admission rules",
      "requiresAuth": true
    },
    "rules create": {
      "description": "Create admission rule",
      "requiresAuth": true
    },
    "analytics summary": {
      "description": "Show overall analytics",
      "requiresAuth": true
    },
    "stats": {
      "description": "Show gateway statistics",
      "requiresAuth": true
    }
  },
  "envVars": {
    "required": [
      "DATABASE_URL"
    ],
    "optional": [
      "SG_HEARTBEAT_INTERVAL",
      "SG_HEARTBEAT_TIMEOUT",
      "SG_DEFAULT_MAX_CONCURRENT",
      "SG_DEFAULT_MAX_DEVICE_STREAMS",
      "SG_SESSION_MAX_DURATION_HOURS",
      "SG_ANALYTICS_INTERVAL",
      "SG_REALTIME_URL",
      "SG_APP_TV_MAX_CONCURRENT",
      "SG_APP_TV_MAX_DEVICE_STREAMS",
      "SG_APP_FAMILY_MAX_CONCURRENT",
      "DATABASE_URL",
      "PORT",
      "REDIS_URL"
    ]
  },
  "config": {
    "port": 3601,
    "webhookPath": "/webhooks/nself-stream-gateway",
    "retryAttempts": 3,
    "retryDelay": 1000
  },
  "hooks": {
    "postInstall": "install.sh",
    "preUninstall": "uninstall.sh",
    "postSync": null
  },
  "multiApp": {
    "supported": true,
    "isolationColumn": "app_id",
    "pkStrategy": "uuid",
    "defaultValue": "default"
  },
  "permissions": {
    "database": [
      "create",
      "read",
      "update",
      "delete"
    ],
    "network": [
      "*"
    ],
    "filesystem": [
      "logs",
      "cache"
    ]
  }
}
