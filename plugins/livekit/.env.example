# =============================================================================
# ulivekit Plugin - Environment Configuration
# =============================================================================
# LiveKit voice/video infrastructure - room management, participant tracking, recording/egress, quality monitoring
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Auto-provided by nself CLI
# -----------------------------------------------------------------------------

# PostgreSQL connection string (auto-provided by nself)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself_db

# -----------------------------------------------------------------------------
# REQUIRED - Security Configuration (auto-provided by nself)
# -----------------------------------------------------------------------------

# API key for inter-plugin authentication
LIVEKIT_API_KEY=your-api-key-here

# Rate limiting (requests per window)
LIVEKIT_RATE_LIMIT_MAX=100

# Rate limiting window (milliseconds)
LIVEKIT_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# OPTIONAL - Server Configuration
# -----------------------------------------------------------------------------

# Server port (default from plugin.json: 3107)
LIVEKIT_PORT=3107

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# OPTIONAL - Plugin-Specific Configuration
# -----------------------------------------------------------------------------

# LIVEKIT_EGRESS_ENABLED
LIVEKIT_EGRESS_ENABLED=value

# LIVEKIT_RECORDINGS_PATH
LIVEKIT_RECORDINGS_PATH=value

# LIVEKIT_RECORDINGS_S3_BUCKET
LIVEKIT_RECORDINGS_S3_BUCKET=value

# LIVEKIT_QUALITY_MONITORING_ENABLED
LIVEKIT_QUALITY_MONITORING_ENABLED=value

# LIVEKIT_QUALITY_SAMPLE_INTERVAL
LIVEKIT_QUALITY_SAMPLE_INTERVAL=value

# LIVEKIT_TOKEN_DEFAULT_TTL
LIVEKIT_TOKEN_DEFAULT_TTL=value

# LIVEKIT_TOKEN_MAX_TTL
LIVEKIT_TOKEN_MAX_TTL=value

# LIVEKIT_ROOM_DEFAULT_MAX_PARTICIPANTS
LIVEKIT_ROOM_DEFAULT_MAX_PARTICIPANTS=value

# LIVEKIT_ROOM_EMPTY_TIMEOUT
LIVEKIT_ROOM_EMPTY_TIMEOUT=value

# LIVEKIT_MAX_CONCURRENT_ROOMS
LIVEKIT_MAX_CONCURRENT_ROOMS=value

# LIVEKIT_MAX_PARTICIPANTS_PER_ROOM
LIVEKIT_MAX_PARTICIPANTS_PER_ROOM=value

# LIVEKIT_API_KEY_AUTH
LIVEKIT_API_KEY_AUTH=value


# -----------------------------------------------------------------------------
# Additional Configuration
# -----------------------------------------------------------------------------
#
# For complete plugin documentation and configuration options, see:
# - Plugin README: plugins/${PLUGIN_NAME}/README.md
# - Plugin JSON: plugins/${PLUGIN_NAME}/plugin.json
# - nself documentation: https://github.com/acamarata/nself-plugins
#
# Note: All variables marked as REQUIRED are auto-provided by the nself CLI
# during plugin installation and do not need manual configuration.
# -----------------------------------------------------------------------------
