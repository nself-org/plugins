{
  "name": "search",
  "version": "1.0.0",
  "description": "Full-text search engine with PostgreSQL FTS and MeiliSearch support",
  "author": "nself",
  "license": "Source-Available",
  "homepage": "https://github.com/acamarata/nself-plugins/tree/main/plugins/search",
  "repository": "https://github.com/acamarata/nself-plugins",
  "minNselfVersion": "0.4.8",
  "category": "infrastructure",
  "tags": ["search", "fts", "full-text", "postgres", "meilisearch", "autocomplete"],

  "tables": [
    "search_indexes",
    "search_documents",
    "search_synonyms",
    "search_queries",
    "search_webhook_events"
  ],

  "webhooks": {
    "index.created": "New search index created",
    "index.updated": "Search index settings updated",
    "index.deleted": "Search index removed",
    "document.indexed": "Document added to index",
    "document.updated": "Document updated in index",
    "document.deleted": "Document removed from index"
  },

  "actions": {
    "reindex": "Re-index all documents from source tables",
    "search": "Search across indexes",
    "indexes": "Manage search indexes",
    "synonyms": "Manage search synonyms",
    "analytics": "View search analytics"
  },

  "envVars": {
    "required": [
      "DATABASE_URL"
    ],
    "optional": [
      "SEARCH_PLUGIN_PORT",
      "SEARCH_ENGINE",
      "SEARCH_MEILISEARCH_URL",
      "SEARCH_MEILISEARCH_API_KEY",
      "SEARCH_DEFAULT_LIMIT",
      "SEARCH_MAX_RESULTS",
      "SEARCH_REINDEX_BATCH_SIZE",
      "SEARCH_ANALYTICS_ENABLED",
      "SEARCH_ANALYTICS_RETENTION_DAYS",
      "SEARCH_API_KEY",
      "SEARCH_RATE_LIMIT_MAX",
      "SEARCH_RATE_LIMIT_WINDOW_MS"
    ]
  },

  "config": {
    "defaultPort": 3302,
    "defaultEngine": "postgres",
    "defaultLimit": 20,
    "maxResults": 1000,
    "reindexBatchSize": 500,
    "analyticsEnabled": true,
    "analyticsRetentionDays": 90
  },

  "hooks": {
    "postInstall": null,
    "preUninstall": null,
    "postSync": null
  },

  "multiApp": {
    "supported": true,
    "isolationColumn": "source_account_id",
    "pkStrategy": "single",
    "defaultValue": "primary"
  },

  "permissions": {
    "database": ["create", "read", "update", "delete"],
    "network": ["meilisearch"],
    "filesystem": ["logs", "cache"]
  }
}
