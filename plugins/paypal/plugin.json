{
  "name": "paypal",
  "version": "1.0.0",
  "description": "PayPal payment data sync with webhook handling",
  "author": "nself",
  "license": "Source-Available",
  "homepage": "https://github.com/acamarata/nself-plugins/tree/main/plugins/paypal",
  "repository": "https://github.com/acamarata/nself-plugins",
  "minNselfVersion": "0.4.8",
  "category": "payments",
  "tags": [
    "payments",
    "donations",
    "subscriptions",
    "paypal",
    "webhooks"
  ],
  "tables": [
    "paypal_transactions",
    "paypal_orders",
    "paypal_captures",
    "paypal_authorizations",
    "paypal_refunds",
    "paypal_subscriptions",
    "paypal_subscription_plans",
    "paypal_products",
    "paypal_disputes",
    "paypal_payouts",
    "paypal_invoices",
    "paypal_payers",
    "paypal_balances",
    "paypal_webhook_events"
  ],
  "webhooks": {
    "PAYMENT.CAPTURE.COMPLETED": "Handle completed payment capture",
    "PAYMENT.CAPTURE.DENIED": "Handle denied payment capture",
    "PAYMENT.CAPTURE.REFUNDED": "Handle refunded payment capture",
    "PAYMENT.CAPTURE.REVERSED": "Handle reversed payment capture",
    "PAYMENT.CAPTURE.PENDING": "Handle pending payment capture",
    "CHECKOUT.ORDER.COMPLETED": "Handle completed checkout order",
    "CHECKOUT.ORDER.APPROVED": "Handle approved checkout order",
    "CHECKOUT.ORDER.VOIDED": "Handle voided checkout order",
    "BILLING.SUBSCRIPTION.CREATED": "Handle new subscription",
    "BILLING.SUBSCRIPTION.ACTIVATED": "Handle activated subscription",
    "BILLING.SUBSCRIPTION.UPDATED": "Handle updated subscription",
    "BILLING.SUBSCRIPTION.CANCELLED": "Handle cancelled subscription",
    "BILLING.SUBSCRIPTION.SUSPENDED": "Handle suspended subscription",
    "BILLING.SUBSCRIPTION.EXPIRED": "Handle expired subscription",
    "CUSTOMER.DISPUTE.CREATED": "Handle new dispute",
    "CUSTOMER.DISPUTE.UPDATED": "Handle updated dispute",
    "CUSTOMER.DISPUTE.RESOLVED": "Handle resolved dispute",
    "CUSTOMER.DISPUTE.OTHER": "Handle other dispute event",
    "PAYMENT.PAYOUTSBATCH.SUCCESS": "Handle successful payout batch",
    "PAYMENT.PAYOUTSBATCH.DENIED": "Handle denied payout batch",
    "PAYMENT.PAYOUTSBATCH.PROCESSING": "Handle processing payout batch",
    "INVOICING.INVOICE.PAID": "Handle paid invoice",
    "INVOICING.INVOICE.CANCELLED": "Handle cancelled invoice",
    "PAYMENT.SALE.REFUNDED": "Handle refunded sale"
  },
  "actions": {
    "sync": "Sync all PayPal data to database",
    "reconcile": "Re-sync recent data to catch gaps from missed webhooks",
    "server": "Start the PayPal plugin server",
    "status": "Show sync status and statistics"
  },
  "envVars": {
    "required": [
      "DATABASE_URL",
      "PAYPAL_CLIENT_ID",
      "PAYPAL_CLIENT_SECRET"
    ],
    "optional": [
      "PAYPAL_CLIENT_IDS",
      "PAYPAL_CLIENT_SECRETS",
      "PAYPAL_ACCOUNT_LABELS",
      "PAYPAL_WEBHOOK_IDS",
      "PAYPAL_WEBHOOK_SECRETS",
      "PAYPAL_ENVIRONMENT",
      "PAYPAL_SYNC_INTERVAL"
    ]
  },
  "multiApp": {
    "supported": true,
    "isolationColumn": "source_account_id",
    "pkStrategy": "single",
    "defaultValue": "primary"
  },
  "config": {
    "syncInterval": 3600,
    "webhookPath": "/webhooks/paypal",
    "retryAttempts": 3,
    "retryDelay": 1000,
    "port": 3004
  },
  "hooks": {
    "postInstall": "install.sh",
    "preUninstall": "uninstall.sh",
    "postSync": null
  },
  "permissions": {
    "database": [
      "create",
      "read",
      "update",
      "delete"
    ],
    "network": [
      "paypal.com",
      "api-m.paypal.com",
      "api-m.sandbox.paypal.com"
    ],
    "filesystem": [
      "logs",
      "cache"
    ]
  }
}
