# Database Configuration (Required)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nself
# Or individual settings:
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=nself
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_SSL=false

# Server Configuration (Optional)
SOCIAL_PLUGIN_PORT=3502
SOCIAL_PLUGIN_HOST=0.0.0.0

# Social Settings (Optional)
SOCIAL_MAX_POST_LENGTH=5000
SOCIAL_MAX_COMMENT_LENGTH=2000
SOCIAL_MAX_COMMENT_DEPTH=5
SOCIAL_EDIT_WINDOW_MINUTES=30
SOCIAL_REACTIONS_ALLOWED=👍,❤️,😂,😮,😢,🔥

# Security (Optional)
SOCIAL_API_KEY=
SOCIAL_RATE_LIMIT_MAX=200
SOCIAL_RATE_LIMIT_WINDOW_MS=60000

# Logging (Optional)
LOG_LEVEL=info
