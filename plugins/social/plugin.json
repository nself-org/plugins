{
  "name": "social",
  "version": "1.0.0",
  "description": "Universal social features plugin with posts, comments, reactions, follows, and bookmarks",
  "author": "nself",
  "license": "Source-Available",
  "homepage": "https://github.com/acamarata/nself-plugins/tree/main/plugins/social",
  "repository": "https://github.com/acamarata/nself-plugins",
  "minNselfVersion": "0.4.8",
  "category": "content",
  "tags": [
    "social",
    "posts",
    "comments",
    "reactions",
    "follows",
    "bookmarks",
    "content"
  ],
  "tables": [
    "np_social_posts",
    "np_social_comments",
    "np_social_reactions",
    "np_social_follows",
    "np_social_bookmarks",
    "np_social_shares",
    "np_social_webhook_events"
  ],
  "webhooks": {
    "post.created": "Handle new post creation",
    "post.updated": "Handle post updates",
    "post.deleted": "Handle post deletion",
    "comment.created": "Handle new comment",
    "comment.updated": "Handle comment updates",
    "comment.deleted": "Handle comment deletion",
    "reaction.added": "Handle reaction addition",
    "reaction.removed": "Handle reaction removal",
    "follow.created": "Handle new follow",
    "follow.deleted": "Handle unfollow",
    "bookmark.created": "Handle new bookmark",
    "bookmark.deleted": "Handle bookmark removal",
    "share.created": "Handle new share/repost"
  },
  "actions": {
    "init": "Initialize database schema",
    "server": "Start webhook and API server",
    "status": "Show plugin status and statistics",
    "posts": "Manage posts",
    "comments": "Manage comments",
    "reactions": "Manage reactions",
    "follows": "Manage follows",
    "stats": "Show detailed statistics"
  },
  "envVars": {
    "required": [
      "DATABASE_URL"
    ],
    "optional": [
      "SOCIAL_PLUGIN_PORT",
      "SOCIAL_MAX_POST_LENGTH",
      "SOCIAL_MAX_COMMENT_LENGTH",
      "SOCIAL_MAX_COMMENT_DEPTH",
      "SOCIAL_EDIT_WINDOW_MINUTES",
      "SOCIAL_REACTIONS_ALLOWED",
      "SOCIAL_API_KEY",
      "SOCIAL_RATE_LIMIT_MAX",
      "SOCIAL_RATE_LIMIT_WINDOW_MS"
    ]
  },
  "config": {
    "port": 3502,
    "maxPostLength": 5000,
    "maxCommentLength": 2000,
    "maxCommentDepth": 5,
    "editWindowMinutes": 30,
    "reactionsAllowed": [
      "👍",
      "❤️",
      "😂",
      "😮",
      "😢",
      "🔥"
    ],
    "webhookPath": "/webhooks/social"
  },
  "hooks": {
    "postInstall": null,
    "preUninstall": null,
    "postSync": null
  },
  "multiApp": {
    "supported": true,
    "isolationColumn": "source_account_id",
    "pkStrategy": "single",
    "defaultValue": "primary"
  },
  "permissions": {
    "database": [
      "create",
      "read",
      "update",
      "delete"
    ],
    "network": [],
    "filesystem": [
      "logs",
      "cache"
    ]
  }
}
