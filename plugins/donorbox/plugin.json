{
  "name": "donorbox",
  "version": "1.0.0",
  "description": "Donorbox donation data sync with webhook handling",
  "author": "nself",
  "license": "Source-Available",
  "homepage": "https://github.com/acamarata/nself-plugins/tree/main/plugins/donorbox",
  "repository": "https://github.com/acamarata/nself-plugins",
  "minNselfVersion": "0.4.8",
  "category": "commerce",
  "tags": [
    "donations",
    "fundraising",
    "campaigns",
    "donorbox",
    "webhooks"
  ],
  "tables": [
    "np_donorbox_campaigns",
    "np_donorbox_donors",
    "np_donorbox_donations",
    "np_donorbox_plans",
    "np_donorbox_events",
    "np_donorbox_tickets",
    "np_donorbox_webhook_events"
  ],
  "webhooks": {
    "donation.created": "Sync new donation to database"
  },
  "actions": {
    "sync": "Sync all Donorbox data to database",
    "reconcile": "Re-sync recent data to catch gaps from missed webhooks",
    "server": "Start the Donorbox plugin server",
    "status": "Show sync status and statistics"
  },
  "envVars": {
    "required": [
      "DATABASE_URL",
      "DONORBOX_API_KEY",
      "DONORBOX_EMAIL"
    ],
    "optional": [
      "DONORBOX_EMAILS",
      "DONORBOX_API_KEYS",
      "DONORBOX_ACCOUNT_LABELS",
      "DONORBOX_WEBHOOK_SECRET",
      "DONORBOX_WEBHOOK_SECRETS",
      "DONORBOX_SYNC_INTERVAL"
    ]
  },
  "multiApp": {
    "supported": true,
    "isolationColumn": "source_account_id",
    "pkStrategy": "single",
    "defaultValue": "primary"
  },
  "config": {
    "syncInterval": 3600,
    "webhookPath": "/webhooks/donorbox",
    "retryAttempts": 3,
    "retryDelay": 1000,
    "port": 3005
  },
  "hooks": {
    "postInstall": "install.sh",
    "preUninstall": "uninstall.sh",
    "postSync": null
  },
  "permissions": {
    "database": [
      "create",
      "read",
      "update",
      "delete"
    ],
    "network": [
      "donorbox.org"
    ],
    "filesystem": [
      "logs",
      "cache"
    ]
  }
}
