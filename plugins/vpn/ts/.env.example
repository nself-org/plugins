# VPN Plugin Environment Configuration
# Copy this file to .env and configure with your values

# ============================================================================
# Database Configuration (REQUIRED)
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/nself

# ============================================================================
# VPN Provider Configuration (OPTIONAL)
# ============================================================================

# Default provider to use (nordvpn, surfshark, pia, mullvad, etc.)
VPN_PROVIDER=nordvpn

# Default region/country for connections (US, GB, NL, etc.)
VPN_REGION=

# ============================================================================
# Download Configuration (OPTIONAL)
# ============================================================================

# Path for torrent downloads
DOWNLOAD_PATH=/tmp/vpn-downloads

# ============================================================================
# Security Settings (OPTIONAL)
# ============================================================================

# Enable kill switch by default (true/false)
ENABLE_KILL_SWITCH=true

# Enable automatic reconnection on dropout (true/false)
ENABLE_AUTO_RECONNECT=true

# ============================================================================
# Server Carousel Settings (OPTIONAL)
# ============================================================================

# Enable automatic server rotation (true/false)
SERVER_CAROUSEL_ENABLED=false

# Minutes between server rotations
CAROUSEL_INTERVAL_MINUTES=60

# ============================================================================
# API Server Settings (OPTIONAL)
# ============================================================================

# Port for REST API server
PORT=3010

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# ============================================================================
# Encryption Key for Credentials (REQUIRED in production)
# ============================================================================

# Used to encrypt credentials in database
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=CHANGE_THIS_TO_A_RANDOM_32_CHARACTER_STRING

# ============================================================================
# Provider-Specific Credentials
# ============================================================================
# These are typically stored in the database via CLI commands
# But can be set here for initial setup

# NordVPN Access Token (get from: https://my.nordaccount.com/dashboard/nordvpn/manual-configuration/)
# NORDVPN_TOKEN=your_token_here

# Surfshark Service Credentials
# SURFSHARK_USERNAME=your_service_username
# SURFSHARK_PASSWORD=your_service_password

# Private Internet Access
# PIA_USERNAME=your_pia_username
# PIA_PASSWORD=your_pia_password

# Mullvad Account Number
# MULLVAD_ACCOUNT=1234567890123456

# Proton VPN
# PROTONVPN_USERNAME=your_protonvpn_username
# PROTONVPN_PASSWORD=your_protonvpn_password

# ExpressVPN Activation Code
# EXPRESSVPN_ACTIVATION_CODE=your_activation_code

# AirVPN Credentials
# AIRVPN_USERNAME=your_airvpn_username
# AIRVPN_PASSWORD=your_airvpn_password
# AIRVPN_API_KEY=your_api_key

# CyberGhost Credentials
# CYBERGHOST_USERNAME=your_cyberghost_username
# CYBERGHOST_PASSWORD=your_cyberghost_password

# Windscribe Credentials
# WINDSCRIBE_USERNAME=your_windscribe_username
# WINDSCRIBE_PASSWORD=your_windscribe_password

# KeepSolid VPN Unlimited (not recommended for P2P - only 5 servers)
# KEEPSOLID_ID=your_keepsolid_id
# KEEPSOLID_PASSWORD=your_password
