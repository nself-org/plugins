{
  "name": "sports-data",
  "version": "1.0.0",
  "description": "Sports data aggregation with live scores, schedules, standings, and team/player information",
  "author": "nself",
  "license": "Source-Available",
  "homepage": "https://github.com/acamarata/nself-plugins/tree/main/plugins/sports-data",
  "repository": "https://github.com/acamarata/nself-plugins",
  "minNselfVersion": "0.4.8",
  "category": "data-services",
  "tags": [
    "sports",
    "scores",
    "standings",
    "schedule",
    "nfl",
    "nba",
    "live-data"
  ],
  "tables": [
    "sports_leagues",
    "sports_teams",
    "sports_games",
    "sports_standings",
    "sports_players",
    "sports_favorites",
    "sports_sync_state",
    "sports_webhook_events"
  ],
  "webhooks": {},
  "actions": {
    "leagues": "List leagues",
    "teams": "List teams",
    "games": "View games and scores",
    "scores": "View latest scores",
    "standings": "View standings",
    "sync": "Trigger data sync",
    "sync-status": "Check sync status",
    "stats": "Show sports data statistics"
  },
  "envVars": {
    "required": [
      "DATABASE_URL",
      "SPORTS_PROVIDER"
    ],
    "optional": [
      "SPORTS_PLUGIN_PORT",
      "SPORTS_APP_IDS",
      "SPORTS_ESPN_API_KEY",
      "SPORTS_LEAGUE_IDS",
      "SPORTS_LIVE_GAME_POLL_SECONDS"
    ]
  },
  "config": {
    "defaultPort": 3030,
    "liveGamePollSeconds": 30,
    "scheduleSyncCron": "0 6 * * *",
    "standingsSyncCron": "0 */6 * * *",
    "notifyGameStartMinutesBefore": 15
  },
  "hooks": {
    "postInstall": null,
    "preUninstall": null,
    "postSync": null
  },
  "multiApp": {
    "supported": true,
    "isolationColumn": "source_account_id",
    "pkStrategy": "uuid",
    "defaultValue": "primary"
  },
  "permissions": {
    "database": [
      "create",
      "read",
      "update",
      "delete"
    ],
    "network": [
      "*"
    ],
    "filesystem": [
      "logs",
      "cache"
    ]
  }
}
